1
00:00:16,490 --> 00:00:18,330
...الثّروة والشّهرة والسّلطة

2
00:00:18,630 --> 00:00:20,500
،الرّجل الّذي نال كلّ شيء في العالم

3
00:00:20,500 --> 00:00:22,400
.ملك القراصنة، غولد روجر

4
00:00:22,800 --> 00:00:26,570
قادت كلماته الّتي ألقاها قبل
.موته بالنّاس إلى البحار

5
00:00:26,570 --> 00:00:30,170
!كنزي؟ سأعطيكم إيّاه إن أردتموه

6
00:00:30,440 --> 00:00:34,040
جدوه! تركت كلّ ما هو موجود
!في هذا العالم فيه

7
00:00:36,650 --> 00:00:40,720
وبهذا، يتوجّه الرّجال نحو
!الغراند لاين لملاحقة أحلامهم

8
00:00:41,350 --> 00:00:44,290
!دخل العالم في عصر قراصنة عظيم

9
00:00:45,190 --> 00:00:49,790
سنجمع كل أحلامنا

10
00:00:50,790 --> 00:00:56,230
ونبحر باحثين عن شيء، باحثين عن

11
00:00:56,630 --> 00:01:02,270
!ون بيس

12
00:01:02,770 --> 00:01:07,610
لا تجلب البوصلات سوى التّأخيرات

13
00:01:08,440 --> 00:01:13,050
أهذي بالحمّى، أمسك بمقود السّفينة

14
00:01:14,150 --> 00:01:19,120
إن تمّ التّحقّق من خريطة الكنز المغبرة

15
00:01:19,450 --> 00:01:24,990
!فإنّها ليست أسطورة إذًا

16
00:01:26,190 --> 00:01:31,870
،عندما يتعلّق الأمر بالأعاصير الشّخصيّة

17
00:01:31,930 --> 00:01:36,770
فاركب إيقاع أحدهم الحيويّ فحسب

18
00:01:37,070 --> 00:01:39,670
!وتظاهر أنّها غير موجودة

19
00:01:40,640 --> 00:01:45,510
سنجمع كلّ أحلامنا

20
00:01:46,510 --> 00:01:51,690
ونبحر باحثين عن شيء

21
00:01:52,020 --> 00:01:54,920
،عملة في جيبي

22
00:01:55,020 --> 00:01:58,190
وتريد أن تصبح صديقي؟

23
00:01:58,290 --> 00:02:02,800
!إنّنا، إنّنا في رحلة بحريّة

24
00:02:03,660 --> 00:02:04,830
!إننا كذلك

25
00:02:13,470 --> 00:02:15,680
.تفضّل يا غين. أطعمه إيّاه

26
00:02:15,680 --> 00:02:16,840
...سانجي-سان

27
00:02:17,310 --> 00:02:18,340
!شكرًا لك

28
00:02:32,420 --> 00:02:34,590
.يا له من مطعم جيّد

29
00:02:35,530 --> 00:02:37,130
.سآخذ هذه السّفينة

30
00:02:39,200 --> 00:02:42,130
...إذًا... هذا ما تريد

31
00:02:42,130 --> 00:02:45,570
!كرات لحم الهلاك

32
00:02:56,010 --> 00:02:57,980
!أنتم مزعجون

33
00:03:04,060 --> 00:03:06,460
!لا تتحدّوني

34
00:03:07,020 --> 00:03:09,490
،عندما آمركم بتحضير الطّعام

35
00:03:09,490 --> 00:03:12,000
!كلّ ما عليكم فعله هو إطاعة الأوامر

36
00:03:12,560 --> 00:03:14,730
!لا تتحدّوني

37
00:03:18,040 --> 00:03:20,540
يوجد هنا ما يكفي لمئة
.وجبة على الأرجح

38
00:03:20,540 --> 00:03:22,770
.خذه إلى سفينتك في الحال

39
00:03:22,770 --> 00:03:24,010
!أيّها المالك زيف

40
00:03:26,280 --> 00:03:29,610
أ... أقلتم زيف؟

41
00:03:30,110 --> 00:03:32,680
!حماية باراتيي! القرصان العظيم زيف ذو السّاق الحمراء

42
00:03:32,680 --> 00:03:37,150
!حماية باراتيي"
"!القرصان العظيم زيف ذو السّاق الحمراء

43
00:03:51,300 --> 00:03:53,900
!ما الّذي تفعله؟
!هل فقدت عقلك؟

44
00:03:54,400 --> 00:03:56,870
،إن أعدنا الحياة لأولئك الّذين على السّفينة

45
00:03:56,870 --> 00:03:59,740
!فإنّهم سيستولون على مطعمنا بالكامل

46
00:03:59,740 --> 00:04:03,550
...هذا إن كانوا يملكون الإرادة للقتال

47
00:04:05,150 --> 00:04:08,880
أليس كذلك يا محارب
الغراند لاين المهزوم؟

48
00:04:11,950 --> 00:04:13,860
...أ... أيعقل

49
00:04:13,860 --> 00:04:16,190
...الدّون كريغ محارب مهزوم

50
00:04:16,660 --> 00:04:19,560
إذًا فحتّى المسيطر على
...الأزرق الشّرقيّ لم يستطع

51
00:04:19,560 --> 00:04:23,870
حتّى أسطول القراصنة ذو الخمسين
...سفينة لم يستطع الإبحار فيه

52
00:04:24,370 --> 00:04:25,830
الغراند لاين؟

53
00:04:26,970 --> 00:04:32,440
!لا... لا بدّ أنّك زيف ذو السّاق الحمراء

54
00:04:34,210 --> 00:04:36,480
...أن حيّ إذًا

55
00:04:36,480 --> 00:04:41,050
قرصان لا مثيل له كان طبّاخًا
...قبطان سفينة أيضًا

56
00:04:41,720 --> 00:04:44,290
وماذا إن كنتُ حيًّا؟

57
00:04:44,290 --> 00:04:46,920
.لا علاقة لذلك بك أنت

58
00:04:46,920 --> 00:04:51,060
.أعيش حياتي كطبّاخ الآن كما ترى

59
00:04:54,560 --> 00:04:57,160
يبدو هذا جيّدًا عندما تصفه
...بهذه الطّريقة

60
00:04:57,160 --> 00:05:00,930
،لكن بدل العيش كطبّاخ

61
00:05:00,930 --> 00:05:04,140
.يبدو أنّك لا تستطيع العيش إلاّ كطبّاخ

62
00:05:04,710 --> 00:05:11,650
زيف ذو السّاق الحمراء سيّد الرّكلات
.لم يستعمل يديه أبدًا في معركة

63
00:05:12,180 --> 00:05:16,150
سمعتُ أنّ ساقيه القويّتين
قادرتان على سحق الصّخور

64
00:05:16,150 --> 00:05:19,450
.وترك آثار حتّى على الفولاذ

65
00:05:20,320 --> 00:05:23,660
ولقب السّاق الحمراء يشير لأحذيتك
الّتي كانت مغطّاة دائمًا بالدّماء

66
00:05:23,660 --> 00:05:26,390
.الّتي تطايرت بينما تركل أعداءك

67
00:05:29,400 --> 00:05:34,130
لكن ما عدت تملك تلك
...السّاق العزيزة عليك

68
00:05:35,100 --> 00:05:37,670
...سمعتُ الإشاعة

69
00:05:37,670 --> 00:05:40,970
يا لحظّك السّيّئ الّذي تسبّب
...لك بحادثة في البحر

70
00:05:41,610 --> 00:05:47,710
بالنّسبة لك، لا بدّ أنّ خسارة إحدى ساقيك
.عنت أنّك غير قادر على القتال

71
00:05:48,550 --> 00:05:50,720
وما دخل القتال؟

72
00:05:50,720 --> 00:05:55,720
أستطيع الطّبخ بدون ساق
.ما دمتُ أملك هاتين اليدين

73
00:05:55,720 --> 00:05:59,630
فما الّذي تحاول قوله؟
!قل ما لديك دون مماطلة

74
00:06:01,360 --> 00:06:03,360
.يا زيف ذا السّاق الحمراء

75
00:06:03,360 --> 00:06:08,800
أنت الرّجل الّذي دخل الغراند لاين
...سابقًا وخرج سالمًا معافى

76
00:06:09,470 --> 00:06:12,940
لا بدّ أنّه ثمّة سجلّ للسّنة الكاملة

77
00:06:12,940 --> 00:06:15,610
...الّتي خضت رحلتك فيها

78
00:06:15,610 --> 00:06:17,340
!أعطني إيّاه

79
00:06:18,940 --> 00:06:23,250
مذهل! سبق وزرت الغراند لاين أيّها العمّ؟

80
00:06:23,250 --> 00:06:24,150
...صحيح

81
00:06:25,050 --> 00:06:30,190
.قلتَ سجلّي؟ لديّ واحد بالفعل

82
00:06:30,720 --> 00:06:33,320
.لكن لا أستطيع إعطاءك إيّاه

83
00:06:34,690 --> 00:06:39,760
سجلّ السّفينة هو فخر كلّ أفراد
.الطّاقم الّذين أبحرتُ معهم

84
00:06:39,760 --> 00:06:44,070
.إنّه أهمّ من أن أعطيه لك

85
00:06:44,770 --> 00:06:47,300
.في تلك الحالة، سآخذه منك بالقوّة

86
00:06:48,110 --> 00:06:51,540
.صحيح أنّني فشلت في الغراند لاين

87
00:06:51,540 --> 00:06:55,280
،ورغم ذلك، ما أزال الدّون كريغ
.الرّجل الأقوى

88
00:06:56,080 --> 00:06:59,980
.إنّها مجرّد طريقة بحريّة مظلمة
...لديّ القوّة الكافية لأبحر فيها

89
00:06:59,980 --> 00:07:02,650
!كما لديّ الرّجال والطّموح

90
00:07:04,490 --> 00:07:08,760
الشّيء الوحيد الّذي ندمت عليه
.هو افتقاري للمعلومات

91
00:07:08,760 --> 00:07:11,130
...تنقصني معرفة بعض الأشياء فحسب

92
00:07:12,230 --> 00:07:14,730
.سآخذ سجلّك

93
00:07:14,730 --> 00:07:20,370
وسأشكّل أسطول قراصنة كبيرًا
."ثانية وأضع يديّ على "ون بيس

94
00:07:20,800 --> 00:07:24,070
وحينها، سأقف على قمّة
!عصر القراصنة العظيم هذا

95
00:07:35,650 --> 00:07:37,120
!مهلًا لحظة

96
00:07:37,120 --> 00:07:39,190
!أنا هو من سيصبح ملك القراصنة

97
00:07:40,490 --> 00:07:41,020
!الفتى العامل

98
00:07:42,260 --> 00:07:46,630
!تراجع أيّها الفتى العامل
!أنت لست ندًّا له

99
00:07:46,630 --> 00:07:49,330
.لا أستطيع التّراجع عن ذلك

100
00:07:51,330 --> 00:07:53,800
هل قلتَ شيئًا ما يا ولد؟

101
00:07:54,570 --> 00:07:56,870
...أستطيع تجاهل ما قلتَه

102
00:07:56,870 --> 00:08:00,780
.ليس عليك ذلك
.أخبرتك بالحقيقة فحسب

103
00:08:01,710 --> 00:08:03,740
.هذه ليست لعبة

104
00:08:04,350 --> 00:08:07,720
.بالطّبع لا. سأقهر الغراند لاين

105
00:08:08,520 --> 00:08:10,620
!هذه ليست مزحة أيّها الشّقيّ

106
00:08:10,620 --> 00:08:12,520
،صحيح أنّنا لم نملك المعلومات الكافية

107
00:08:12,520 --> 00:08:15,660
لكنّ أسطولًا بخمسة آلاف رجل
!أُبيد في سبعة أيّام فقط

108
00:08:15,660 --> 00:08:16,720
!إنّه بحر شيطانيّ

109
00:08:16,720 --> 00:08:18,790
من المستحيل لشخص مثلك
!أن يستطيع الإبحار فيه

110
00:08:18,790 --> 00:08:20,990
!سـ-سبعة أيّام؟

111
00:08:20,990 --> 00:08:23,700
أُبيدت سفن قراصنة كريغ
!في سبعة أيّام فقط؟

112
00:08:24,400 --> 00:08:26,030
ما الّذي حدث يا ترى؟

113
00:08:26,730 --> 00:08:30,640
لسوء الحظّ، لا أجد هذا النّوع
.من المزاح مضحكًا

114
00:08:31,340 --> 00:08:33,770
،إن كنتَ لن تتراجع عن كلامك

115
00:08:33,770 --> 00:08:36,040
...فما رأيك أن أسحقك ها هنا

116
00:08:36,640 --> 00:08:38,610
...يمكنك أن تحاول

117
00:08:41,180 --> 00:08:42,620
.لا مانع لي

118
00:08:43,320 --> 00:08:46,950
.سأرسلك إلى حتفك كما ترغب

119
00:09:03,170 --> 00:09:06,210
ستقاتل يا لوفي؟ أتحتاج مساعدة؟

120
00:09:06,210 --> 00:09:08,370
لا-لا بأس أيضًا إن كنتَ
...لن تـ-تحتاج المساعدة

121
00:09:10,810 --> 00:09:14,110
زورو! أوسوبّ! أتيتما أيضًا؟

122
00:09:14,110 --> 00:09:15,780
.لا تقلقا. شاهدا فحسب

123
00:09:15,780 --> 00:09:18,220
،فـ-فعلًا؟ هـ-هذا مؤسف

124
00:09:18,220 --> 00:09:20,490
...لكن ما بيدنا حيلة بعد ما قلتَه

125
00:09:20,490 --> 00:09:23,190
،لـ-لكن إن تطلّب الأمر تدخّلنا
.فسنساعدك

126
00:09:23,190 --> 00:09:24,790
!لـ-لـ-لذلك، حظًّا سـ-سعيدًا

127
00:09:26,660 --> 00:09:28,760
!لماذا فعلتَ ذلك يا زورو؟

128
00:09:28,760 --> 00:09:30,900
!اخرس! الزم الصّمت فحسب

129
00:09:33,900 --> 00:09:36,430
هل هما من طاقمك؟

130
00:09:37,070 --> 00:09:39,440
!ياله من طاقم صغير

131
00:09:39,840 --> 00:09:42,540
!ماذا قلت؟! لديّ عضوان آخران

132
00:09:42,540 --> 00:09:44,410
!أنت! قمتَ بعدّي أيضًا، صحيح؟

133
00:09:50,850 --> 00:09:53,220
.سأتعامل معكم لاحقًا

134
00:09:53,980 --> 00:09:56,920
.سأذهب لإطعام رجالي

135
00:09:59,760 --> 00:10:04,630
بإمكان من لا يرغبون في الموت
.مغادرة المطعم والنّجاة بحياتهم

136
00:10:05,400 --> 00:10:10,000
كلّ ما أسعى إليه هو السّجلّ
.وهذه السّفينة

137
00:10:13,500 --> 00:10:16,640
...لكن إن كنتم تتمنّون الموت بلا فائدة

138
00:10:17,810 --> 00:10:20,740
فسأدفنكم في البحر
.وإن كان ذلك مزعجًا

139
00:10:21,440 --> 00:10:22,810
.أُعذر من أنذر

140
00:10:39,530 --> 00:10:41,830
.أصبح الوضع هادئًا

141
00:10:41,830 --> 00:10:45,500
.ذهب أخي الكبير زورو إلى هناك
.يجب أن نكون بخير

142
00:10:45,500 --> 00:10:48,400
نعم... لكن هل هم بخير بالفعل؟

143
00:10:48,400 --> 00:10:50,210
...بعد التّفكير في الأمر

144
00:10:50,210 --> 00:10:54,080
،أخبرينا يا أختي الكبيرة نامي
هل علينا الدّخول أيضًا؟

145
00:10:58,610 --> 00:10:59,650
!يا أختي الكبيرة؟

146
00:10:59,650 --> 00:11:00,580
!مهلًا، مهلًا

147
00:11:10,560 --> 00:11:12,790
أ-أختي الكبيرة نامي؟

148
00:11:13,800 --> 00:11:16,760
نعم، ماذا؟ هل من خطب؟

149
00:11:31,950 --> 00:11:33,910
.آسف يا سانجي-سان

150
00:11:33,910 --> 00:11:36,750
...لم أتخيّر أبدًا حدوث هذا

151
00:11:36,750 --> 00:11:40,520
هذا ليس شيئًا يجب
.أن تعتذر بسببه أيّها التابع

152
00:11:42,390 --> 00:11:48,630
يتصرّف كلّ طبّاخ في هذا المطعم
.حسبما يعتبرونه صوابًا. هذا كلّ شيء

153
00:11:48,630 --> 00:11:54,900
أيّها المالك! لماذا تتصرّف وكأنّك
!موافق على ما فعله سانجي؟

154
00:11:54,900 --> 00:11:58,840
هذا صحيح! إنّه مسؤول
!عن كلّ ما يحدث

155
00:11:59,510 --> 00:12:02,380
!سوف يتسبّب بإفلاس مطعمك الغالي

156
00:12:02,380 --> 00:12:04,210
!اخرسوا أيّها الأغبياء

157
00:12:05,550 --> 00:12:11,380
هل سبق وجرّبتم شعور أن تكونوا
!على حافّة الموت بسبب الجوع؟

158
00:12:11,880 --> 00:12:17,290
فقدان الماء والطّعام في هذا
...المحيط الواسع

159
00:12:17,290 --> 00:12:22,160
!هل تدركون كم أنّ ذلك مخيف؟
!هل تدركون كم ذلك صعب؟

160
00:12:22,160 --> 00:12:25,660
ماذا؟! ماذا تعني أيّها المالك؟

161
00:12:26,060 --> 00:12:28,370
الفرق بين سانجي وبينكم جميعًا

162
00:12:28,370 --> 00:12:30,770
.هو معرفتكم لذلك الشّعور أم لا

163
00:12:33,340 --> 00:12:35,610
ماذا؟ ماذا يعني؟

164
00:12:35,610 --> 00:12:38,080
ماذا يقصد أن سانجي يعرف؟

165
00:12:41,110 --> 00:12:43,750
،إن كان لديكم وقت للتّذمّر

166
00:12:43,750 --> 00:12:46,580
!غادروا المطعم من الباب الخلفيّ بسرعة

167
00:12:49,350 --> 00:12:51,790
.أنا باقٍ لأقتال

168
00:12:51,790 --> 00:12:55,090
.لن أتحمّل إن ضُربتُ ولم أردّ القتال

169
00:12:55,090 --> 00:12:59,130
!أنا باقٍ أيضًا! هذا هو المطعم حيث أعمل

170
00:12:59,130 --> 00:13:01,500
لا مكان آخر لدينا لنذهب إليه
!على أيّ حال

171
00:13:08,910 --> 00:13:14,040
!ما الّذي تعتقدون أنفسكم فاعلين؟
!رأيتم كم أنّ دون قويّ، صحيح؟

172
00:13:14,040 --> 00:13:14,910
!اسمع يا غين

173
00:13:16,050 --> 00:13:17,650
.دعني أخبرك بشيء ما

174
00:13:17,650 --> 00:13:22,450
إطعام شخص جائع أمر
.تمليه عليّ أخلاقي

175
00:13:22,450 --> 00:13:23,250
...ولكن

176
00:13:28,630 --> 00:13:31,930
من سنتعامل معهم هم
.مجموعة لصوص ببطون ممتلئة

177
00:13:32,830 --> 00:13:37,570
لن أدعك تشتكي حتّى بعد
.أن أهزم رفاقك القراصنة

178
00:13:37,570 --> 00:13:39,440
إن وُجد من يريد الاستيلاء
،على هذا المطعم

179
00:13:39,440 --> 00:13:43,140
!فسأقتله بدون أيّ تردّد وإن كان أنت

180
00:13:43,810 --> 00:13:44,870
أتدرك ذلك؟

181
00:13:48,240 --> 00:13:52,380
سمحتَ له بالعيش والآن قد تقتله؟
...حالتك ميؤوس منها يا سانجي

182
00:13:52,380 --> 00:13:53,820
!اخرس أيّها الطّبّاخ اللّعين

183
00:13:54,280 --> 00:13:56,750
أرأيتما؟ إنّه رائع، صحيح؟

184
00:13:56,750 --> 00:13:58,920
!من يهتمّ لأمره الآن؟

185
00:13:58,920 --> 00:14:01,090
!من الأفضل أن نهرب في الحال

186
00:14:01,090 --> 00:14:05,290
اهدأ! إنّه في حالة ميؤوس منها
!ومصاب، حتّى وإن كان كريغ

187
00:14:07,030 --> 00:14:11,300
غين! قلتَ أنّك لا تدري شيئًا
.عن الغراند لاين

188
00:14:11,300 --> 00:14:13,170
رغم أنّك ذهبت إلى هناك؟

189
00:14:18,570 --> 00:14:21,110
.جهلي لما حدث حقيقة

190
00:14:22,140 --> 00:14:26,210
ما حدث في اليوم السّابع
...بعد دخولنا للغراند لاين

191
00:14:26,210 --> 00:14:29,920
...لا أدري إن كان حلمًا أم حقيقة

192
00:14:30,890 --> 00:14:34,760
ما زلت غير قادر على إدراك
...ما حدث

193
00:14:35,720 --> 00:14:38,160
...ما زلت لا أصدّق

194
00:14:39,960 --> 00:14:42,800
...أنّ أسطولًا من خمسين سفينة

195
00:14:44,570 --> 00:14:47,840
...أُبيد على يد رجل واحد

196
00:14:52,840 --> 00:14:55,110
!ماذا؟

197
00:15:17,730 --> 00:15:19,530
...حدث الأمر فجأة

198
00:15:21,170 --> 00:15:26,810
،بمجرّد أن ظهر هذا الرّجل
.أغرق السّفن الواحدة تلو الأخرى

199
00:15:31,210 --> 00:15:34,710
،لولا أنّ الحظّ حالفنا بتلك العاصفة

200
00:15:34,710 --> 00:15:38,320
لكانت سفينتنا الرّئيسيّة
...قد دُمّرت بالكامل أيضًا

201
00:15:45,860 --> 00:15:49,130
...لا أدري كم سفينة بقيت لنا

202
00:15:49,790 --> 00:15:54,130
كنت غارقًا في حزني لدرجة أنّني
...لم أرد تقبّل أنّ ذلك هو الواقع

203
00:15:54,130 --> 00:15:56,370
...لا أريد تذكّره

204
00:15:57,240 --> 00:15:59,070
...ذلك الرّجل

205
00:15:59,070 --> 00:16:05,310
كانت له عينان حادّتان كعيني الصّقر
.نظراتهما مرعبة حتّى الموت

206
00:16:06,010 --> 00:16:07,040
...ما

207
00:16:08,950 --> 00:16:10,550
!ما الّذي قاله للتّوّ؟

208
00:16:14,590 --> 00:16:16,490
...لا بدّ

209
00:16:17,020 --> 00:16:20,090
...أنّه كان عين الصّقر

210
00:16:20,090 --> 00:16:21,090
ماذا؟

211
00:16:21,760 --> 00:16:27,560
إنّ شعورك أنّ عينيه كانتا كعيني
،الصّقر ليس دليلًا أنّه هو

212
00:16:28,000 --> 00:16:33,670
لكنّ ما فعله هذا الرّجل دليل
...كافٍ على أنّه هو بالفعل

213
00:16:34,400 --> 00:16:36,040
!عين الصّقر

214
00:16:36,040 --> 00:16:38,380
ماذا؟ هل تعرفه يا زورو؟

215
00:16:39,810 --> 00:16:43,350
.نعم... إنّه الرّجل الّذي أبحث عنه

216
00:16:43,980 --> 00:16:47,120
.دخلت غمار البحر لألتقي به

217
00:16:49,290 --> 00:16:53,290
أليس ممكنًا أنّ ذلك الرّجل لديه
ضغينة كبيرة ضدّكم؟

218
00:16:53,290 --> 00:16:55,360
!لن نفعل أيّ شيء له

219
00:16:55,360 --> 00:16:57,790
ربّما أقلقتم راحته وهو يأخذ
...قيلولة أو ما شابه

220
00:16:57,790 --> 00:16:59,560
!لا تكن سخيفًا

221
00:16:59,560 --> 00:17:02,630
من المستحيل أنّه سحق أسطولنا
!بأكمله لذلك السّبب

222
00:17:04,100 --> 00:17:07,600
.لا تتحمّس كثيرًا. إنّه مجرّد مثال

223
00:17:08,440 --> 00:17:13,580
أنا أعطي مثالًا فحسب لما
.هو عليه الحال في الغراند لاين

224
00:17:13,940 --> 00:17:16,250
أيّ نوع من الأماكن هو هذا؟

225
00:17:16,250 --> 00:17:18,910
.على الأرجح أنّه يعني أنّ كلّ شيء وارد

226
00:17:20,050 --> 00:17:23,350
!يا لوفي! دعنا لا نذهب لمكان كهذا

227
00:17:23,350 --> 00:17:24,950
!لوفي

228
00:17:29,060 --> 00:17:31,030
يا لوفي؟

229
00:17:33,030 --> 00:17:34,960
!يبدو هذا محمّسًا

230
00:17:34,960 --> 00:17:37,030
!هكذا يجب أن يكون

231
00:17:37,030 --> 00:17:39,330
"عليك أن تقحم مفهوم "الخطر
!في جمجمتك الثّخينة تلك

232
00:17:39,330 --> 00:17:44,110
لكنّ هدفي الآن أصبح مركّزًا
.بالكامل على الغراند لاين

233
00:17:46,070 --> 00:17:50,440
ذلك الرّجل... بإمكاني لقاء ذلك
...الرّجل إن ذهبتُ إلى هناك

234
00:17:52,550 --> 00:17:54,250
هل أنتم أغبياء أم ماذا؟

235
00:17:55,120 --> 00:17:57,450
.يموت أمثالكم قبل البقيّة

236
00:17:57,890 --> 00:18:01,290
صحيح، لكن لم يكن هنالك داعٍ
."لوصفنا بـ"الأغبياء

237
00:18:02,490 --> 00:18:05,230
،عندما قرّرتُ أن أصبح أقوى سيّاف

238
00:18:05,230 --> 00:18:07,260
.قرّرتُ أيضًا تكريس حياتي لذلك الهدف

239
00:18:07,790 --> 00:18:11,970
بما أنّه كان قراري، فالوحيد الّذي
.بإمكانه وصفي بالغبيّ هو أنا

240
00:18:14,130 --> 00:18:16,470
!نعم! أنا أيضًا، أنا أيضًا

241
00:18:16,470 --> 00:18:19,570
وأنا كذلك! ذلك طبيعيّ
!بصفتي رجل بحر

242
00:18:19,570 --> 00:18:20,940
.هذه كذبة في حالتك أنت

243
00:18:23,440 --> 00:18:25,140
...يا له من هراء

244
00:18:29,650 --> 00:18:31,020
!مهلًا، مهلًا

245
00:18:31,620 --> 00:18:36,190
!هل تدركون الوضع الحاليّ أيّها الأغبياء؟

246
00:18:36,190 --> 00:18:39,960
ثمّة سفينة شراعيّة ضخمة
،راسية أمام المطعم الآن

247
00:18:39,960 --> 00:18:42,900
،وهي للدّون كريغ
!أميرال أسطول قراصنة

248
00:18:42,900 --> 00:18:45,030
،إن كنتم تريدون الهرب من الواقع

249
00:18:45,030 --> 00:18:47,230
فافعلوا ذلك بعد النّجاة
!من هذه الأزمة المميتة

250
00:18:58,510 --> 00:19:01,280
!لقد نجونا

251
00:19:01,280 --> 00:19:03,280
!ممتاز! ما زلنا أحياء

252
00:19:03,280 --> 00:19:04,750
!وكأنّه كان حلمًا

253
00:19:04,750 --> 00:19:07,390
!تحرّرنا من ذلك الكابوس

254
00:19:07,390 --> 00:19:11,820
!عدنا أحياءً من مقبرة القراصنة

255
00:19:13,960 --> 00:19:14,930
...صحيح

256
00:19:15,760 --> 00:19:20,000
ممّا يعني أنّ بإمكاننا الآن
.التّوجّه للغراند لاين ثانية

257
00:19:23,070 --> 00:19:25,740
ماذا؟ ما هذه الوجوه؟

258
00:19:26,470 --> 00:19:28,670
هـ-هل ما زلت تريد الذّهاب إلى هناك؟

259
00:19:35,450 --> 00:19:39,180
لا اعتراضات أخرى، صحيح؟

260
00:19:50,890 --> 00:19:56,030
أوّلًا، لنتخلّى عن هذه السّفينة المحطّمة
!الّتي قد تغرق في أيّة لحظة

261
00:19:56,030 --> 00:19:58,030
.ونستولي على المطعم

262
00:19:58,030 --> 00:20:01,470
.عدوّنا مجرّد مجموعة طبّاخين أشقياء

263
00:20:01,470 --> 00:20:03,910
،حتّى إن استخففتم بخصمكم
...فما زال ذلك أكثر من كافٍ

264
00:20:15,920 --> 00:20:16,890
!هجوم

265
00:20:22,320 --> 00:20:24,790
!ها هم قادمون
!بإمكاننا سماع صراخهم

266
00:20:24,790 --> 00:20:28,930
!سنحمي هذه السّفينة حتّى النّهاية
!هذا مطعمنا

267
00:20:33,800 --> 00:20:36,340
!ابتعدوا عن طريقنا أيّها الطّبّاخون

268
00:20:56,720 --> 00:20:57,590
!ما هذا؟

269
00:20:58,990 --> 00:21:00,600
!ما الّذي حدث؟

270
00:21:01,160 --> 00:21:03,130
!الدّون كريغ

271
00:21:03,530 --> 00:21:07,070
!السّفينة الرّئيسيّة... قُطّعت

272
00:21:07,070 --> 00:21:10,070
!قُطّعت؟! أقلت قُطّعت؟

273
00:21:10,070 --> 00:21:12,710
!مع أنّها سفينة شراعيّة ضخمة؟

274
00:21:12,710 --> 00:21:18,580
!مستحيل أن يكون ذلك صحيحًا

275
00:21:25,550 --> 00:21:29,560
ارفعوا المرساة وإلاّ ابتلعَنا
!البحر مع تلك السّفينة

276
00:21:29,560 --> 00:21:30,390
!حاضر

277
00:21:32,830 --> 00:21:36,960
هذا سيّئ! نامي ويوساكو وجوني
!ما زالوا على سفينتنا هناك

278
00:21:37,960 --> 00:21:40,470
!سُحقًا! ربّما يكون الأوان قد فات

279
00:21:49,140 --> 00:21:53,250
!أخي الكبير! أخي الكبير

280
00:21:53,250 --> 00:21:55,780
!يوساكو! جوني

281
00:21:55,780 --> 00:21:57,320
هل أنتما بخير؟

282
00:21:57,320 --> 00:21:59,790
!أين السّفينة؟! لا أراها
!ماذا حدث لنامي؟

283
00:21:59,790 --> 00:22:04,360
.ذلك... أنا آسف يا أخي الكبير
.لقد غادرت

284
00:22:04,990 --> 00:22:07,530
...مع السّلامة! أخبراهم

285
00:22:07,530 --> 00:22:09,600
...أختي الكبيرة نامي

286
00:22:09,600 --> 00:22:11,630
،إن كان القدر يربط بيننا
.فسنلتقي ثانية

287
00:22:12,330 --> 00:22:16,270
!أخذت كلّ الكنز وهربت

288
00:22:16,270 --> 00:22:19,570
!ما-ما الّذي قلته؟

289
00:22:31,950 --> 00:22:33,580
...ذلك الرّجل

290
00:22:46,460 --> 00:22:50,800
!ذ-ذلك الوغد! لقد تبعنا

291
00:23:02,780 --> 00:23:05,920
...أيعقل... أنّه

292
00:23:06,720 --> 00:23:08,750
!المدعوّ عين الصّقر؟

293
00:23:09,790 --> 00:23:24,030
عندما كنت صغيرًا، راودتني رؤية عن خريطة كنز

294
00:23:24,030 --> 00:23:30,970
ولطالما بحثت عن ذلك المكان الإعجازيّ

295
00:23:30,970 --> 00:23:38,150
لكي لا يسبقني أحد آخر إليه

296
00:23:40,680 --> 00:23:52,160
إن كان العالم سيتغيّر

297
00:23:52,160 --> 00:23:59,170
قبل أن أحقّق حلمي

298
00:23:59,170 --> 00:24:06,240
فخذوني إلى الوقت الّذي كنت فيه جاهلًا

299
00:24:06,240 --> 00:24:19,620
لكي لا تمحى ذكرياتي

300
00:24:25,090 --> 00:24:26,390
من يكون؟

301
00:24:26,390 --> 00:24:29,830
الرّجل الّذي أبحث عنه. لم أتوقّع
.أن أتمكّن من لقائه بهذه السّرعة

302
00:24:29,830 --> 00:24:31,060
هل ستقاتله؟

303
00:24:31,060 --> 00:24:33,300
.نعم. لهذا السّبب دخلت غمار البحر

304
00:24:33,300 --> 00:24:34,970
يا زورو، ما الخطب؟

305
00:24:34,970 --> 00:24:36,600
هل أنا بعيد كلّ هذا البعد
من الأقوى في العالم؟

306
00:24:36,600 --> 00:24:39,040
...هذا هو الأقوى في العالم إذًا

307
00:24:39,040 --> 00:24:40,240
!زورو

308
00:24:40,240 --> 00:24:41,610
:في الحلقة القادمة من ون بيس

309
00:24:41,610 --> 00:24:45,150
!عين الصّقر ميهوك"
".السّيّاف الّذي دفع زورو للإبحار

310
00:24:45,150 --> 00:24:46,540
!ملك القراصنة، لن يكون إلاّ أنا

311
00:24:46,540 --> 00:24:50,050
.عين الصّقر ميهوك! السّيّاف الّذي دفع زورو للإبحار