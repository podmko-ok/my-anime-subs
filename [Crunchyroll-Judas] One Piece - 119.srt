1
00:00:07,720 --> 00:00:10,760
!العالم... نعم

2
00:00:11,290 --> 00:00:12,960
...اسعوا نحو الحرّيّة

3
00:00:12,960 --> 00:00:17,000
.وسيمتدّ العالم بأسره أمام أنظاركم

4
00:00:17,460 --> 00:00:20,800
،إن كانت أحلامكم اللاّمتناهية هي مرشدكم

5
00:00:21,330 --> 00:00:22,800
!فتجاوزوها

6
00:00:23,100 --> 00:00:26,070
!تحت راية ما تؤمنون به

7
00:00:30,540 --> 00:00:36,150
بدأتُ بحثي للتّوّ، محدثًا رذاذ مياه

8
00:00:36,150 --> 00:00:39,380
متّجهًا نحو عالم بلا نهاية

9
00:00:40,790 --> 00:00:45,660
بقلبٍ يتدفّق حماسًا، سأذهب حتّى نهاية الأرض

10
00:00:45,660 --> 00:00:54,070
باحثًا عن ضياء لم يرها أحد بعد

11
00:00:54,070 --> 00:00:59,800
عندما تُأرجح شمس الصّيف أشرعة قلبي

12
00:00:59,800 --> 00:01:04,240
"حلّق بعيدًا أيّها البحر الأزرق الكئيب"

13
00:01:04,240 --> 00:01:09,880
تكون تلك إشارة لفتح الباب نحو عالم جديد

14
00:01:09,880 --> 00:01:13,750
"حلّقي بعيدًا أيّتها السّماء الزّرقاء الكئيبة"

15
00:01:13,750 --> 00:01:18,690
نبحر عبر أمواج اليأس الوعرة

16
00:01:18,690 --> 00:01:26,430
متّجهين نحو الأفق

17
00:01:26,430 --> 00:01:31,940
بدأتُ بحثي للتّوّ، محدثًا رذاذ مياه

18
00:01:31,940 --> 00:01:36,640
متّجهًا نحو عالم بلا نهاية

19
00:01:36,640 --> 00:01:41,880
بقلبٍ يتدفّق حماسًا، سأذهب حتّى نهاية الأرض

20
00:01:41,880 --> 00:01:48,150
باحثًا عن ضياء لم يرها أحد بعد

21
00:01:50,460 --> 00:01:53,120
المجمّع الغربي
المجمّع الشمالي
مملكة ألاباستا
المجمّع الشرقيّ
المجمّع الجنوبيّ

22
00:01:53,120 --> 00:01:54,760
مشاعر أولئك الّذين يعانون من كرب

23
00:01:54,760 --> 00:01:57,030
.لاقت سحقًا من سحابة الرّمال الجافّة

24
00:01:57,930 --> 00:02:01,330
،هنالك من في الأمل ساعٍ
.وهنالك من فيه متشبّث

25
00:02:01,730 --> 00:02:03,870
تشابكت مشاعرهم وهم في ريبةٍ من أمرهم

26
00:02:04,200 --> 00:02:07,970
.واسمةً حقبةً من التّاريخ يختمها الحزن

27
00:02:09,410 --> 00:02:12,840
تستمرّ فيفي وأصدقاؤها في القتال
.من أجل إنقاذ ألاباستا من أزمتها

28
00:02:15,280 --> 00:02:18,350
...إضافةً لانتصار أوسوبّ وتشوبّر

29
00:02:20,150 --> 00:02:23,720
.تمكّن سانجي من سحق السّيّد 2 بون كوري

30
00:02:35,470 --> 00:02:39,770
في نفس الأثناء، خاضت نامي
،قتالاً حاميًا ضدّ الآنسة دبلفينغر

31
00:02:39,770 --> 00:02:41,510
.الّتي تملك قوى فاكهة الأشواك

32
00:02:42,110 --> 00:02:43,810
!خذي هذه

33
00:02:44,180 --> 00:02:46,180
!جوّ الزّوبعة

34
00:03:01,960 --> 00:03:02,890
ماذا؟

35
00:03:02,890 --> 00:03:04,730
!...شبكت الحمامتان على جسدي

36
00:03:26,820 --> 00:03:31,260
وفي النّهاية، استطاعت نامي الفوز بالمعركة
.بفضل اختراع أوسوبّ، عصا الطّقس

37
00:03:32,820 --> 00:03:37,600
ليبقى قتال واحد قائم
.بين السّيّد 1 وزورو

38
00:03:40,800 --> 00:03:44,100
.إذًا أساسًا، جسدك صلب كالفولاذ

39
00:03:44,100 --> 00:03:47,270
،ما لم أكن قادرًا على قطع حتّى الفولاذ
فلن أستطيع الإطاحة بك، صحيح؟

40
00:03:47,710 --> 00:03:49,610
.كلامك صحيح

41
00:03:50,410 --> 00:03:52,840
.هجمات التّحطيم والقطع لا تفلح ضدّي

42
00:03:54,250 --> 00:03:56,710
.فهمت. هذا مزعج

43
00:03:56,710 --> 00:04:00,220
،بما أنّني لا أستطيع قطع الفولاذ بعد
.لا أستطيع أن أهزمك في الوقت الرّاهن

44
00:04:01,290 --> 00:04:02,590
وماذا ستفعل إذًا؟

45
00:04:02,590 --> 00:04:05,690
.لنرَ... سأتعاطف معك

46
00:04:05,690 --> 00:04:06,660
ماذا؟

47
00:04:07,560 --> 00:04:10,060
.كنتُ منتظرًا لوضع صعب كهذا

48
00:04:10,830 --> 00:04:14,670
فكّرتُ أنّه حان الوقت
.لأتقدّم بمستواي خطوةً

49
00:04:15,700 --> 00:04:17,840
،عندما أهزمك

50
00:04:18,170 --> 00:04:21,970
سأكون الرّجل الّذي يستطيع
.قطع حتّى الفولاذ

51
00:04:23,880 --> 00:04:26,480
!سرّ المسايفة القويّة
القدرة على قطع الفولاذ ونفَس كلّ شيء

52
00:04:26,480 --> 00:04:31,680
سرّ المسايفة القويّة! القدرة"
".على قطع الفولاذ ونفَس كلّ شيء

53
00:04:34,690 --> 00:04:37,360
عندما تهزمني؟

54
00:04:37,960 --> 00:04:40,290
،قد يُحبط هذا حماسك

55
00:04:41,230 --> 00:04:44,860
،لكن مذ حصلتُ على قوى فاكهة القطع

56
00:04:44,860 --> 00:04:48,400
لم أتكبّد ولو خدشًا ممّن
.يسمّون أنفسهم سيّافة

57
00:04:49,470 --> 00:04:53,070
.لا يستطيع أيّ سيّاف هزيمتي

58
00:04:53,370 --> 00:04:55,910
...فهمت ما تقصد

59
00:04:55,910 --> 00:04:59,310
لكن يمكنك أن تحتفظ
.بكلّ حكاياتك لنفسك

60
00:04:59,710 --> 00:05:03,310
،لا أدري كم واجهت من سيّاف في الماضي

61
00:05:04,450 --> 00:05:07,550
.لكنّنا لم نتواجه من قبل

62
00:05:11,920 --> 00:05:14,230
.يبدو أنّ لسانك حادّ على الأقلّ

63
00:05:15,430 --> 00:05:17,630
.شكرًا يا أصلع

64
00:05:22,500 --> 00:05:24,340
.سنرى إلى متى ستصمد

65
00:05:24,700 --> 00:05:25,800
.وأنت أيضًا

66
00:06:09,050 --> 00:06:09,780
...قاطع

67
00:06:11,820 --> 00:06:13,020
!الغول

68
00:06:17,590 --> 00:06:18,740
...صيد

69
00:06:19,220 --> 00:06:20,460
!النّمور

70
00:06:52,620 --> 00:06:53,860
أولم أخبرك؟

71
00:06:58,330 --> 00:07:02,270
.من المفاجئ أنّك لم تتلقّ ولو خدشًا واحدًا

72
00:07:02,770 --> 00:07:06,040
هذه أوّل مرّة أيضًا يظلّ
...خصمي واقفًا

73
00:07:06,040 --> 00:07:07,840
.بعد أن ظننتُ أنّني أصبته بشدّة

74
00:07:08,440 --> 00:07:10,240
.بالطّبع

75
00:07:10,810 --> 00:07:14,450
.بما أنّنا لم نتواجه من قبل

76
00:07:24,290 --> 00:07:25,090
!صحيح

77
00:07:26,290 --> 00:07:28,830
.جسده كلّه من سيوف

78
00:07:28,830 --> 00:07:31,800
!لذا فإنّ سيوفه لا تملك مقدّمة أو مؤخّرة

79
00:07:35,770 --> 00:07:38,000
!الأقحوان المتلألئ

80
00:07:45,180 --> 00:07:47,550
...هـ-هذا

81
00:07:49,510 --> 00:07:50,520
.سأعصف بك

82
00:08:32,160 --> 00:08:34,860
،إن تعلّق الأمر بالتّدريب
.لقد تدرّبتُ أكثر من الجميع

83
00:08:38,360 --> 00:08:42,770
كما مررتُ بالكثير من المواقف
.الّتي كادت تودي بحياتي

84
00:08:45,070 --> 00:08:51,240
عندما أهزمك، سأكون الرّجل
.الّذي يستطيع قطع حتّى الفولاذ

85
00:08:51,610 --> 00:08:56,480
لم أتكبّد ولو خدشًا ممّن
.يسمّون أنفسهم سيّافة

86
00:08:58,020 --> 00:09:00,550
!ما الّذي ينقصني؟

87
00:09:03,020 --> 00:09:05,960
!سينسي! سينسي

88
00:09:06,990 --> 00:09:07,860
نعم؟

89
00:09:09,190 --> 00:09:13,870
أصحيحٌ أنّه يوجد في هذا العالم من
يستطيع قطع أيّ شيء، حتّى الفولاذ؟

90
00:09:16,570 --> 00:09:18,740
.نعم، ذلك صحيح

91
00:09:20,510 --> 00:09:23,880
.والآن، راقب هذه الورقة بإمعان يا زورو

92
00:09:30,480 --> 00:09:32,780
.سينسي، لم تقطعها

93
00:09:32,780 --> 00:09:34,620
.اسمع يا زورو

94
00:09:34,620 --> 00:09:40,160
.هنالك سيّافة لا يستطيعون قطع أيّ شيء

95
00:09:42,360 --> 00:09:48,300
،لكن بوسعهم قطع أيّ شيء أيضًا
.حتّى الفولاذ... وباستخدام السّيف عينه

96
00:09:49,630 --> 00:09:53,810
أقوى السّيافة يمكنهم حماية
ما يريدون حمايته

97
00:09:53,810 --> 00:09:56,110
.كما قطع ما يريدون قطعه

98
00:09:57,210 --> 00:10:01,380
...أمّا المسايفة الّتي تؤذي أيّ ما تمسّه

99
00:10:01,380 --> 00:10:03,480
.لا أعتبرها مسايفة حقيقيّة

100
00:10:03,880 --> 00:10:05,280
هل فهمت؟

101
00:10:28,140 --> 00:10:31,640
سينسي، سأكون سيّافًا
!يستطيع قطع أيّ شيء

102
00:10:32,710 --> 00:10:35,810
زورو، هل أصغيت لما قلت؟

103
00:10:49,020 --> 00:10:51,830
.أسرع وحاول قطعي

104
00:10:52,530 --> 00:10:56,000
.لا يمكنك قطعي بالدّفاع وحده

105
00:10:57,240 --> 00:11:03,310
مع الأسف، لا أظنّك تستطيع
...رؤية بسالتي وأنا أقطع الفولاذ

106
00:11:08,110 --> 00:11:13,050
.لأنّي عندما أقطعه، ستموت

107
00:11:14,520 --> 00:11:16,020
.كلامك منطقيّ

108
00:11:24,760 --> 00:11:28,630
!سأقطّع كلّ شيء... إربًا

109
00:11:30,840 --> 00:11:35,240
المسايفة الّتي لا تقطع أيّ شيء؟

110
00:11:54,560 --> 00:11:56,090
...لا فائدة

111
00:11:57,730 --> 00:12:01,470
!سأقطّع كلّ شيء... إربًا

112
00:12:02,800 --> 00:12:05,200
المسايفة الّتي لا تقطع أيّ شيء؟

113
00:12:06,200 --> 00:12:09,570
...لا أقطع أيّ شيء، لكن أقطع الفولاذ

114
00:12:09,570 --> 00:12:11,840
!لا أفهم ما يعنيه ذلك على الإطلاق

115
00:12:13,310 --> 00:12:14,750
!اطعن واطعن

116
00:12:14,750 --> 00:12:17,220
!هذا هو سرّ المسايفة القويّة

117
00:12:17,620 --> 00:12:19,680
!القطع الذّريّ

118
00:12:22,290 --> 00:12:23,820
!سأقطعك فحسب

119
00:12:52,650 --> 00:12:53,850
...قبضة

120
00:12:53,850 --> 00:12:54,790
!السّلطعون

121
00:13:16,540 --> 00:13:18,840
!يا لك من وغدٍ خبيث

122
00:13:20,150 --> 00:13:21,810
.وأنت أيضًا

123
00:13:22,580 --> 00:13:26,720
...دعني أخبرك شيئًا
.لا تعتبرني سيّافًا

124
00:13:27,420 --> 00:13:31,520
.أملك أسلحة كثيرة تستطيع تمزيقك إربًا

125
00:13:37,630 --> 00:13:39,000
!الحافر اللّولبيّ

126
00:13:43,770 --> 00:13:46,910
!إلّم تكن سيّافًا... هل أنت حفّار؟

127
00:13:47,310 --> 00:13:48,540
!أنا قاتل

128
00:13:54,010 --> 00:13:57,880
!شرارات؟! ما مدى سرعة دورانها؟

129
00:14:00,290 --> 00:14:01,450
!ستُصدّ

130
00:14:03,860 --> 00:14:06,090
...لا يمكنني أن أحفر

131
00:14:06,940 --> 00:14:09,260
.لأنّني سأقطع كلّ شيء إن حفرت

132
00:14:10,560 --> 00:14:11,460
!سحقًا

133
00:14:26,910 --> 00:14:29,680
...أسئ تقدير خصمك للحظة وسوف

134
00:14:31,380 --> 00:14:32,220
!تموت

135
00:15:03,650 --> 00:15:05,050
...ما زلتَ تتنفّس

136
00:15:10,890 --> 00:15:13,560
...لن أري ظهري له

137
00:15:15,690 --> 00:15:18,230
كيف ستكافح بيديك العاريتين؟

138
00:15:24,300 --> 00:15:29,610
.لستَ سيّافًا أساسًا
.لذا لن تفهم حتّى إن شرحت لك

139
00:15:31,110 --> 00:15:33,340
.لستُ مهتمًّا أساسًا

140
00:15:36,280 --> 00:15:38,950
!القاطع الفوضويّ

141
00:15:56,800 --> 00:15:58,400
...ارقد بسلام

142
00:16:01,470 --> 00:16:06,140
...حظّي سيّئ مع الصّخور اليوم

143
00:16:37,410 --> 00:16:42,010
يا رفاق! احرصوا على إرجاع
!فيفي إلى ديارها

144
00:16:42,750 --> 00:16:44,680
!لنتقابل في قصر ألوبارنا

145
00:16:49,250 --> 00:16:52,860
أهم بخير... جميعًا؟

146
00:17:08,640 --> 00:17:10,210
أنّى له أن يقف؟

147
00:17:10,880 --> 00:17:12,640
...بعد أن قطعتُه عدّة مرّات

148
00:17:13,180 --> 00:17:15,110
هل تجنّب كلّ تلك الصّخور المتساقطة؟

149
00:17:21,850 --> 00:17:24,660
تجنّبتُ... الصّخور؟

150
00:17:25,460 --> 00:17:26,290
...لا

151
00:17:27,330 --> 00:17:31,760
بل عرفتُ... المكان الّذي
...لن تسقط فيه

152
00:17:36,670 --> 00:17:37,800
...السّيوف

153
00:17:38,770 --> 00:17:42,440
...يمكنني أن أعرف أنّ إحداها
...تحت تلك الصّخرة

154
00:17:46,240 --> 00:17:47,610
ما الّذي يفعله؟

155
00:17:56,690 --> 00:17:59,220
...سبق وأن اختبرتُ هذا الشّعور

156
00:18:03,430 --> 00:18:05,430
...حيث يخيّم الصّمت من حولي

157
00:18:07,070 --> 00:18:09,600
...وأسمع دقّات قلبي بوضوح

158
00:18:13,370 --> 00:18:16,810
أهكذا... نشعر بالضّبط
عندما نكون على شفير الموت؟

159
00:18:19,740 --> 00:18:25,880
شعرتُ بتلميح من الصّخور
...المتساقطة وكأنّها كائنات حيّة

160
00:18:27,420 --> 00:18:30,860
...كلّا، لم يكن تلميحًا
...بل كان أكثر وضوحًا من ذلك

161
00:18:31,760 --> 00:18:32,960
...نفَس

162
00:18:34,530 --> 00:18:37,100
...نفس... الصّخور

163
00:18:37,900 --> 00:18:39,730
...للأشجار نفَسها

164
00:18:41,030 --> 00:18:42,930
...التّربة أيضًا

165
00:18:43,800 --> 00:18:45,540
أهذا ما في الأمر؟

166
00:18:46,770 --> 00:18:53,080
اسمع. هنالك سيّافة
.لا يستطيعون قطع أيّ شيء

167
00:18:55,450 --> 00:19:00,620
هل المقصود بـ"عدم قطع
أيّ شيء" هو معرفة النّفَس؟

168
00:19:01,820 --> 00:19:05,460
تلك هي... القدرة على
...قطع حتّى الفولاذ

169
00:19:07,330 --> 00:19:10,300
أيّها الوغد... ما الّذي فعلته؟

170
00:19:10,760 --> 00:19:13,100
...بعد أن تكبّدتَ هجومًا بليغًا

171
00:19:13,100 --> 00:19:15,330
...بعد أن نزفتَ كلّ هذا القدر

172
00:19:15,330 --> 00:19:17,500
!يستحيل أن تكون حيًّا

173
00:19:25,680 --> 00:19:30,180
...يمكنني سماع... نفَس فولاذه

174
00:19:31,480 --> 00:19:33,850
...إنّ إرادتي تتدفّق في السّيف

175
00:19:50,500 --> 00:19:55,440
فليكن... سأجهز عليه
.كليًّا بالهجوم التّالي

176
00:19:57,640 --> 00:19:58,780
...يبقى السّؤال

177
00:19:59,880 --> 00:20:04,680
.ما إن كنتُ قادرًا حقًّا على قطع الفولاذ

178
00:20:07,290 --> 00:20:11,190
من الصّعب أن أتخيّلك تدافع
.ضدّ هجومي بسيفٍ واحد فحسب

179
00:20:13,830 --> 00:20:17,160
.أصبت. اكتفيتُ من الدّفاع

180
00:20:18,230 --> 00:20:20,970
!أصبحت جاهزًا إذًا؟ فليكن

181
00:20:23,970 --> 00:20:28,340
:أسلوب السّيف الواحد
!أنشودة أسد الموت

182
00:20:29,010 --> 00:20:30,680
!التّدفّق الذّريّ

183
00:20:53,400 --> 00:20:54,800
...أشكرك

184
00:20:56,730 --> 00:20:59,300
!ما زال بوسعي أن أغدو أقوى

185
00:21:04,080 --> 00:21:10,350
...أصبح أقوى... في هذا القتال... بالفعل

186
00:21:14,750 --> 00:21:20,430
هل ستقطع... الماسّ أو ما شابه تاليًا؟

187
00:21:23,530 --> 00:21:25,500
...سيكون ذلك إسرافًا

188
00:21:28,030 --> 00:21:29,730
...لقد فزتَ

189
00:21:40,580 --> 00:21:47,400
ألوبارنا - المجمّع الشّمالي
قتال أمام قاعة اجتماعات ميدي

190
00:21:47,400 --> 00:21:51,460
الفائز: زورو

191
00:22:06,070 --> 00:22:12,180
إلى أيّ اتّجاه عليّ أن أركض
لأرى غدًا أروع بكثير؟

192
00:22:12,180 --> 00:22:18,120
أمسكت مقود السّفينة وفتحت الخريطة
الأعجوبيّة الّتي خزّنتُها في قلبي

193
00:22:18,120 --> 00:22:24,360
،جعلتُ السّماء هدفي وتبعت أحلامي
رغم أنّني أضيع أحيانًا

194
00:22:24,360 --> 00:22:29,790
،لم يكن حلمًا عندما التقيت بك
فقد اكتشفت الشّخص الرّائع بداخلي

195
00:22:29,790 --> 00:22:36,030
وببعض الشّجاعة، اكتسبتُ شيئًا عظيمًا

196
00:22:36,030 --> 00:22:41,470
والآن هو الوقت المناسب
لأمنيتي لتصبح عهدي

197
00:22:42,240 --> 00:22:45,240
أيّها الشّعاع اللاّمع! جد طريقك الجديد تمامًا

198
00:22:45,240 --> 00:22:49,010
دعنا نرسم قصّة المستقبل

199
00:22:49,310 --> 00:22:54,250
سأضع كلّ مشاعري
في رياح جديدة تمامًا الآن

200
00:22:54,250 --> 00:22:57,260
أيّها الشّعاع اللاّمع! جد طريقك الجديد تمامًا

201
00:22:57,260 --> 00:23:00,260
رحلة لا نهاية لها لنكون معًا

202
00:23:00,260 --> 00:23:05,460
سألحق بك أينما ذهبت أيّها الشّعاع اللاّمع

203
00:23:10,670 --> 00:23:12,070
لماذا تبكي؟

204
00:23:12,070 --> 00:23:14,970
لأنّ تلك الخلد الشّمطاء
...قالت أنّ لوفي مات

205
00:23:14,970 --> 00:23:16,110
!أهذا صحيح؟

206
00:23:16,110 --> 00:23:17,610
وهل تصدّقان ذلك؟

207
00:23:17,610 --> 00:23:19,210
!بالطّبع لا

208
00:23:19,210 --> 00:23:20,680
.امسحا مخاطكما إذًا

209
00:23:21,650 --> 00:23:24,050
!ما عدتم تملكون سببًا للقتال

210
00:23:24,050 --> 00:23:26,620
!استسلموا الآن! أيّها الجيش الملكيّ

211
00:23:26,620 --> 00:23:27,990
:في الحلقة القادمة من وان بيس

212
00:23:27,990 --> 00:23:31,490
!انتهت المعركة"
".يرفع كوزا راية الاستسلام

213
00:23:31,490 --> 00:23:35,430
!ملك القراصنة، لن يكون إلّا أنا
!انتهت المعركة
يرفع كوزا راية الاستسلام