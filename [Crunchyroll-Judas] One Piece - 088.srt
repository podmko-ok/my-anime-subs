1
00:00:14,030 --> 00:00:15,790
...إرادة موروثة

2
00:00:15,790 --> 00:00:18,130
...تعاقب الأزمنة... أحلام النّاس

3
00:00:18,560 --> 00:00:21,000
.لا رادع لهذه الأشياء

4
00:00:21,370 --> 00:00:24,540
ما دام النّاس يسعون باحثين
،عن جواب للحرّيّة

5
00:00:24,540 --> 00:00:27,270
!فلن تختفي هذه الأشياء عن الوجود

6
00:00:35,680 --> 00:00:42,050
لا أؤمن سوى بالمستقبل... ولا أهتمّ لضحك أيِّ كان

7
00:00:42,050 --> 00:00:47,560
يجعل ذلك الشّغفُ المتسارعُ المرءَ يتألّق

8
00:00:47,560 --> 00:00:53,560
إنّه شديد السّطوع، لكنّني أريد التّحديق به

9
00:00:53,560 --> 00:00:57,070
أشعر بـ"الجمال" في كلّ مكان

10
00:00:57,070 --> 00:01:00,370
أنا متمسّك بكم بشدّة بالفعل

11
00:01:00,370 --> 00:01:07,010
أنا أتبع وأتبع خطوات حلم
لا يشبه أيّ أحد

12
00:01:07,010 --> 00:01:10,310
إلى أن أحصل عليه بكلّ إثارة

13
00:01:10,310 --> 00:01:17,320
!آمنوا ببلاد العجائب

14
00:01:19,220 --> 00:01:25,430
سأمسك وأمسك بشكل حلم
لا يستطيع أحد رؤيته

15
00:01:25,430 --> 00:01:31,430
سوف أرافقك أيّتها المشاعر الشّغوفة

16
00:01:31,430 --> 00:01:34,540
لا أحتاج فعلاً ليكون كلّ شيء في مكانه

17
00:01:34,540 --> 00:01:37,870
،بل أريدها حياة عاديّة لا غير

18
00:01:37,870 --> 00:01:41,110
فاركضوا نحو النّعيم بدل ذلك

19
00:01:41,310 --> 00:01:51,050
!آمنوا ببلاد العجائب

20
00:01:51,320 --> 00:01:53,920
!لا يمكنك كسر هذا العلم

21
00:01:53,920 --> 00:01:57,900
!علامة الجمجمة رمز للإيمان

22
00:02:00,870 --> 00:02:01,670
!لوفي

23
00:02:02,100 --> 00:02:03,130
!إنّها إصابة مباشرة

24
00:02:05,970 --> 00:02:08,640
\h\h\h\h\h\h\h\h\h\h\h!فاكهة شيطان من نوع زون
تحوّلات شكل تشوبّر السّبعة\h\h\h

25
00:02:08,640 --> 00:02:13,110
!فاكهة شيطان من نوع زون"
".تحوّلات شكل تشوبّر السّبعة

26
00:02:16,350 --> 00:02:18,420
!لا بدّ أنّه نُسِف! يا للغبيّ

27
00:02:38,730 --> 00:02:41,010
!أرأيت؟ لم ينكسر

28
00:02:41,740 --> 00:02:44,940
!ماذا؟ !غـ-غير معقول! إنّه غبيّ

29
00:02:45,440 --> 00:02:49,910
لا أدري لمن ينتمي علم
...القراصنة هذا

30
00:02:50,280 --> 00:02:53,450
لكن بما أنّ هذا العلم يمثّل
...عهد رجلٍ ليخاطر بحياته

31
00:02:53,450 --> 00:02:55,820
!فلمْ يُرفع كمزحة

32
00:02:58,890 --> 00:03:05,030
هذا العلم ليس بشيءٍ يمكنك
!كسره وأنت تضحك بتفاهة

33
00:03:10,600 --> 00:03:12,100
...مذهل

34
00:03:13,070 --> 00:03:14,610
!هذا هو... القرصان إذًا

35
00:03:14,970 --> 00:03:20,040
!إنّها رمزٌ لمعتقد أنّ لا شيء مستحيل

36
00:03:20,040 --> 00:03:22,550
!سوف أنقذ هذه البلاد كطبيب

37
00:03:23,080 --> 00:03:27,220
برفعي لهذا العلم، سأقاتل
!كما يفعل القراصنة

38
00:03:27,220 --> 00:03:28,620
ما هم القراصنة؟

39
00:03:28,620 --> 00:03:31,490
.القراصنة أشخاص مذهلون في البحر

40
00:03:31,490 --> 00:03:36,490
!من الرّائع أن تكون قرصانًا
!ثمّة الكثير من الأشخاص المذهلين في البحر

41
00:03:36,490 --> 00:03:39,330
.تشوبّر، اذهب إلى البحر يومًا ما

42
00:03:44,740 --> 00:03:46,270
!أيّها الرّنّة

43
00:03:47,000 --> 00:03:50,740
.سأوسع هؤلاء ضربًا
ماذا تريد أن تفعل؟

44
00:03:51,540 --> 00:03:52,410
...أنا

45
00:03:52,410 --> 00:03:55,850
!ما الّذي تقوله؟ أيّها الغبيّ اللّعين

46
00:03:55,850 --> 00:04:00,480
،إن كنت مستميتًا لحماية ذلك العلم
!فلتبقَ هنالك وتحميه إلى الأبد

47
00:04:00,890 --> 00:04:03,420
!لم لا تتوقّف... الآن

48
00:04:08,190 --> 00:04:10,090
...يبدو أنّ عمودك الفقريّ أُنهِك

49
00:04:11,760 --> 00:04:14,720
!هذا طبيعيّ. لأنّك تتحرّك كثيرًا

50
00:04:15,130 --> 00:04:18,040
!توقّف، إنّها أوامر الطّبيبة

51
00:04:24,280 --> 00:04:26,580
!ماذا تفعلون أيّها الأغبياء؟

52
00:04:26,580 --> 00:04:30,780
!قفوا هناك وشاهدوا فحسب
!سأفتك به وذلك العلم

53
00:04:31,320 --> 00:04:34,150
!حان الوقت لتنفجر يا قبّعة القشّ

54
00:04:35,420 --> 00:04:37,990
!توقّف

55
00:04:39,060 --> 00:04:42,220
!أحسنت! عليك به أيّها الرّنّة

56
00:04:46,160 --> 00:04:48,630
!وابول-ساما! احذر

57
00:04:53,770 --> 00:04:57,540
ذلك الشّقيّ يظهر شجاعته
...وكأنّه أصبح رجلاً بلغ أشدّه

58
00:05:01,080 --> 00:05:05,520
!آسف. لن أدعك تمسّ وابول-ساما بسوء

59
00:05:11,790 --> 00:05:15,030
هنالك بعض المخلوقات
.الغريبة في هذا العالم حقًّا

60
00:05:15,030 --> 00:05:19,960
يبدو أنّك هو مخلوق "اليتّي" الّذي
.بثّ الذّعر بين المواطنين من قبل

61
00:05:21,470 --> 00:05:25,140
لا بدّ أنّك عشت حياتك
.كلّها منبوذًا من الجميع

62
00:05:25,140 --> 00:05:30,610
يا لك من وحشٍ مسكين. لِمَ قد
يريد وحيدٌ مثلك إنقاذ هذه البلاد؟

63
00:05:30,610 --> 00:05:31,880
!لا تدفعني للضّحك

64
00:05:31,880 --> 00:05:36,550
اخرس! حتّى إن كنت لا أملك
!أصدقاء، ما زال يمكنني أن أقاتل

65
00:05:37,420 --> 00:05:40,420
...ما دام علم الدّكتور موجودًا، سوف

66
00:05:40,420 --> 00:05:42,020
!بل تملك أصدقاء

67
00:05:45,460 --> 00:05:48,890
!أنا صديقك

68
00:06:01,960 --> 00:06:03,430
!يا قبّعة القشّ

69
00:06:08,410 --> 00:06:10,480
!هل أنت بخير؟

70
00:06:10,480 --> 00:06:12,650
.أنا بخير حال... بما أنّني مطّاطيّ

71
00:06:12,650 --> 00:06:13,380
!مطّاطيّ؟

72
00:06:15,020 --> 00:06:18,480
.أخبرني أيّها الرّنّة
أيمكنك القضاء على ذلك الشّخص؟

73
00:06:18,860 --> 00:06:20,960
.سيكون القضاء على شخصٍ مثله سهلاً

74
00:06:21,360 --> 00:06:22,960
.قُضي الأمر إذًا

75
00:06:23,730 --> 00:06:26,400
!خصمي هو ذاك الفم المزعج

76
00:06:27,900 --> 00:06:32,270
كيف تجرؤ على القفز
!في الأرجاء يا قبّعة القشّ؟

77
00:06:33,100 --> 00:06:35,010
!لن أتردّد أكثر

78
00:06:35,010 --> 00:06:39,080
!كيف يمكنك القضاء عليّ؟
!أخبرني أيّها الوحش

79
00:06:41,480 --> 00:06:42,850
...كيف تجرئين

80
00:06:43,750 --> 00:06:47,120
...أيّتها الشّمطاء! سأقاتل

81
00:06:47,120 --> 00:06:48,490
!اخرس وراقب

82
00:06:48,490 --> 00:06:52,120
إن واصلت التّحرّك، لن تستطيع
!السّير بنفسك بعد الآن

83
00:06:52,520 --> 00:06:57,090
،لا تقلق. عند الحاجة
.يمكن لرنّتي أن يتدبّر الأمر

84
00:07:03,270 --> 00:07:06,470
!اسمي توني توني تشوبّر

85
00:07:06,470 --> 00:07:09,340
إنّه اسم سمّاني به أعظم
!طبيب في العالم

86
00:07:10,010 --> 00:07:11,940
،حتّى إن سامحكم الدّكتور

87
00:07:11,940 --> 00:07:16,500
!لن أسامحكم على سخريتكم من موته

88
00:07:23,290 --> 00:07:27,020
!بل أنا من لن يسامحك! سأدهسك

89
00:07:28,990 --> 00:07:30,630
!كرة رامبل

90
00:07:33,550 --> 00:07:37,570
!دولتون-سان! دولتون-سان! أفق

91
00:07:37,570 --> 00:07:39,220
!رجاءً! دولتون-سان

92
00:07:39,540 --> 00:07:40,200
...فيفي

93
00:07:40,200 --> 00:07:43,640
!أفق! دولتون-سان! دولتون-سان

94
00:07:43,970 --> 00:07:45,780
.ما زال دولتون حيًّا

95
00:07:47,780 --> 00:07:49,560
!الأطبّاء العشرون

96
00:07:50,250 --> 00:07:52,950
.لقد تجمّد جسده فحسب

97
00:07:52,950 --> 00:07:55,550
هلاّ تركتموه تحت رعايتنا؟

98
00:07:58,320 --> 00:08:00,660
.مهلاً، هنالك أطبّاء

99
00:08:01,090 --> 00:08:03,960
ظننت أنّه لا يوجد أيّ أطبّاء
...في هذه البلاد

100
00:08:03,960 --> 00:08:09,170
هؤلاء الأشخاص يدعون الأطبّاء العشرين
.وهم يعملون حصرًا لدى وابول

101
00:08:09,170 --> 00:08:10,780
!بعبارة أخرى، إنّهم أطبّاء سيّئون

102
00:08:11,140 --> 00:08:13,170
!هذا صحيح! لا يمكننا الوثوق بكم

103
00:08:13,170 --> 00:08:18,940
هل نترك دولتون-سان تحت رعايتكم
!وأنتم من سلّم أمره لوابول... للملك؟

104
00:08:18,940 --> 00:08:21,010
!ما الّذي ستفعلونه لدولتون-سان؟

105
00:08:21,550 --> 00:08:24,500
افعلوا ما نقوله فحسب
!إن كنتم تريدون إنقاذه

106
00:08:27,220 --> 00:08:29,220
.ما زلنا أطبّاء

107
00:08:29,690 --> 00:08:32,920
مع أنّنا أرغمنا على الاستسلام
،أمام وابول وقوّة رجاله

108
00:08:33,160 --> 00:08:36,290
إلاّ أنّنا لطالما عملنا لتطوير
...بحثنا الطّبّيّ

109
00:08:36,290 --> 00:08:38,900
!لأجل مرضى هذه البلاد

110
00:08:42,200 --> 00:08:46,540
.ذلك لأنّ دجّالاً معيّنًا علّمنا ألاّ نستسلم

111
00:08:48,110 --> 00:08:53,910
...ما عاد يمكننا أن نفقد
!المزيد من الرّجال الأغبياء مثله

112
00:08:54,980 --> 00:08:57,280
.يستمرّ تأثير كرة رامبل ثلاث دقائق

113
00:08:57,850 --> 00:09:00,020
!سأهزمك خلال ثلاث دقائق

114
00:09:00,020 --> 00:09:01,850
!ثلاث دقائق؟

115
00:09:01,850 --> 00:09:05,290
،لا يمكنك هزيمتي بتاتًا
!فما بالك في ثلاث دقائق

116
00:09:05,290 --> 00:09:07,760
!ثلاث دقائق؟ هذا مذهل

117
00:09:07,760 --> 00:09:10,230
!ثلاث دقائق؟ هذا مذهل

118
00:09:13,130 --> 00:09:15,530
.سيتسنّى لنا مشاهدة شيءٍ شيّق

119
00:09:15,530 --> 00:09:19,170
!سحقًا! دعيني أقاتل أيضًا

120
00:09:19,170 --> 00:09:20,240
!رامبل

121
00:09:21,770 --> 00:09:25,910
!ماذا... قلت أنّك تستطيع فعله؟

122
00:09:31,180 --> 00:09:33,520
!سهم ماريمو المذيب للثّلج

123
00:09:36,350 --> 00:09:38,790
!نقطة تعزيز المشي

124
00:09:43,310 --> 00:09:45,830
!مجرّد تحوّل؟! توقّعتُ أكثر من هذا

125
00:09:45,830 --> 00:09:48,530
.بعبارة أخرى، تملك قوى فاكهة الشّيطان

126
00:09:48,530 --> 00:09:52,880
!من نّوع زون، مثل دولتون تمامًا
!رنّة إنسان إذًا؟

127
00:09:52,880 --> 00:09:55,410
!نقطة تعزيز الوزن

128
00:09:56,410 --> 00:09:58,320
!أنا إنسان رنّة

129
00:09:58,320 --> 00:09:59,680
!الأمر سيّان

130
00:09:59,680 --> 00:10:04,280
أعرف كلّ شيء بشأن التّحولات الثّلاثة
.الّتي تستخدمونها يا آكلي فاكهة زون

131
00:10:04,580 --> 00:10:07,800
!مطرقات ماريمو الأربع المفاجئة للغاية

132
00:10:08,750 --> 00:10:11,230
.رأيت كلّ تحوّلاتك

133
00:10:11,760 --> 00:10:14,960
.يبدو أنّك مقاتل قوّة مثل دولتون

134
00:10:14,960 --> 00:10:17,210
...لكن يستحيل عليك

135
00:10:17,210 --> 00:10:20,200
!نقطة تعزيز القفز

136
00:10:20,680 --> 00:10:23,430
!التّغلّب عليّ

137
00:10:27,770 --> 00:10:30,010
!لقد قفز! يستطيع القفز عاليًا

138
00:10:32,240 --> 00:10:35,780
!ماذا؟! ما ذلك التّحوّل؟

139
00:10:36,450 --> 00:10:40,150
ألم يكن "تحوّل الإنسان-الحيوان" خاصّته
!هو الرّنّة الصّغير ذاك؟ يا لوقاحته

140
00:10:40,920 --> 00:10:43,770
!نقطة تعزيز الحماية

141
00:10:56,730 --> 00:10:57,870
!ثانيةً؟

142
00:11:05,010 --> 00:11:07,750
لا يمكن... لقد وجّهتُ له
!إصابةً مباشرة

143
00:11:07,750 --> 00:11:09,250
!لن يفلح ذلك

144
00:11:09,610 --> 00:11:13,380
كنتُ واثقًا أنّ مستخدمي زون
.يملكون ثلاثة تحوّلات

145
00:11:13,380 --> 00:11:15,020
ماذا تكون بالضّبط؟

146
00:11:15,020 --> 00:11:20,090
كرة رامبل هي عقّار يتلاعب بالطّول
.الموجيّ لتحوّلات فاكهة الشّيطان

147
00:11:20,090 --> 00:11:24,430
،أثناء خمسة أعوام من البحث
.اكتشفتُ أربع نقاط تحوّل أخرى

148
00:11:24,430 --> 00:11:26,200
.ثلاثة تحوّلات بالإضافة إلى أربعة أخرى

149
00:11:27,030 --> 00:11:29,200
سبعة تحوّلات؟

150
00:11:29,530 --> 00:11:30,130
...سبـ

151
00:11:30,670 --> 00:11:33,100
!ما قصّة عدد تحوّلاتك؟

152
00:11:34,710 --> 00:11:38,080
!رنّة شيّق بسبعة تحوّلات

153
00:11:38,510 --> 00:11:40,480
ما خطبه؟

154
00:11:40,480 --> 00:11:44,080
يبدو أنّ سعادته أصبحت غامرة بعد
.أن سمع عن تحوّلاته السّبعة

155
00:11:44,080 --> 00:11:48,490
!أيّها الوغد... ماذا حلّ بقتالك ضدّي؟

156
00:12:04,800 --> 00:12:07,540
!تبًّا لك ولتحوّلاتك السّبعة

157
00:12:07,540 --> 00:12:10,840
!لن أنخدع بهكذا زيف

158
00:12:11,110 --> 00:12:12,740
!ليس زيفًا

159
00:12:20,920 --> 00:12:23,650
!نقطة تعزيز الذّراعين

160
00:12:40,710 --> 00:12:41,910
.دعني أطلعك على شيء

161
00:12:41,910 --> 00:12:45,880
يمكن لحوافري الحديديّة
!أن تحطّم حتّى الصّخر

162
00:12:45,880 --> 00:12:47,450
!مذهل

163
00:12:48,680 --> 00:12:51,350
!يا لوقاحتك أيّها الوغد

164
00:12:52,550 --> 00:12:55,320
...سألقّنك بهذه! فؤوس ماريمو

165
00:12:56,920 --> 00:12:58,290
!الأربعة المفاجئة

166
00:12:59,820 --> 00:13:01,760
!النّصل قاسم الثّلج

167
00:13:07,500 --> 00:13:10,800
!عجبًا... نقب جدار القلعة

168
00:13:14,140 --> 00:13:15,970
.تبًّا! لقد تفاداها

169
00:13:16,810 --> 00:13:20,010
!ما رأيك إذًا... بهذه؟

170
00:13:20,880 --> 00:13:23,180
!قاسم الثّلج الأحاديّ

171
00:13:34,560 --> 00:13:36,490
!ماذا حلّ بمعنويّاتك المرتفعة؟

172
00:13:36,490 --> 00:13:39,160
!لا يمكنك الفوز بالمراوغة وحدها

173
00:13:47,840 --> 00:13:49,870
!نقطة تعزيز العقل

174
00:13:51,380 --> 00:13:53,440
.ليس وكأنّني كنتُ أراوغ فحسب

175
00:13:56,110 --> 00:13:58,320
.بل كنتُ أبحث عن نقطة ضعفك

176
00:13:58,320 --> 00:13:59,150
!ماذا؟

177
00:13:59,150 --> 00:14:00,660
.سأنهيك بهذا

178
00:14:00,660 --> 00:14:01,620
!تشخيص

179
00:14:09,360 --> 00:14:12,100
!شـ... شعاع! سيطلق شعاعًا بالتّأكيد

180
00:14:12,360 --> 00:14:13,900
!لن يفعل أيّها الغبيّ

181
00:14:13,900 --> 00:14:16,600
!اخرس! إنّه شعاع حتمًا

182
00:14:16,770 --> 00:14:18,370
!لا أهتمّ لرأي أحد، إنّه شعاع

183
00:14:18,370 --> 00:14:20,500
!وما أدراك أنّه شعاع؟

184
00:14:20,500 --> 00:14:21,610
!أدري فحسب! إنّه شعاع

185
00:14:21,610 --> 00:14:22,710
!أيّ شعاع هو بالضّبط إذًا؟

186
00:14:22,710 --> 00:14:24,040
...يجب أن أنتهز هذه الفرصة

187
00:14:24,410 --> 00:14:27,480
!كنتَ تبحث عن نقطة ضعفي؟
!وماذا إذًا؟

188
00:14:35,390 --> 00:14:37,760
!لا أملك نقطة عمياء

189
00:14:37,760 --> 00:14:39,990
أنت مجرّد غبيّ متحوّل
!لا يمكنه حتّى الهجوم

190
00:14:39,990 --> 00:14:42,360
!أنت من سينتهي أمره

191
00:14:45,700 --> 00:14:46,330
!وجدتها

192
00:14:48,100 --> 00:14:49,070
!فكّه

193
00:15:06,980 --> 00:15:08,250
!أين ذهب؟

194
00:15:10,720 --> 00:15:11,960
...حوافر

195
00:15:20,870 --> 00:15:23,670
!أزهار الكرز القاطعة

196
00:15:39,150 --> 00:15:40,420
.ثلاث دقائق

197
00:15:40,820 --> 00:15:46,990
!أحسنت أيّها الرّنّة
!أنت مذهل حقًّا! مذهل

198
00:15:46,990 --> 00:15:48,830
!اخرس

199
00:16:03,110 --> 00:16:04,840
!دولتون-سان

200
00:16:06,580 --> 00:16:10,820
على كلّ حال، دعونا نصعد الجبل
!يا أوسوبّ-سان وسيّد بوشيدو

201
00:16:12,180 --> 00:16:13,650
!لا يمكنني الاكتفاء بالانتظار

202
00:16:13,650 --> 00:16:17,220
أنا قلقة بشأن ما حلّ بلوفي-سان
!والبقيّة إثر ذلك الانهيار الثّلجيّ الكبير

203
00:16:17,790 --> 00:16:21,660
!كما تعاني نامي-سان من حمّى شديدة
...إن حدث مكروه

204
00:16:21,660 --> 00:16:23,190
...أنت قلقة بشأن نامي

205
00:16:23,630 --> 00:16:28,170
وفوق ذلك، أنت قلقة
على دولتون-سان وألاباستا؟

206
00:16:30,530 --> 00:16:35,070
هوّني عليك يا فيفي! إنّك تحملين
!الكثير من العبء على كاهليك

207
00:16:37,510 --> 00:16:41,810
.إنّ نامي مع لوفي وسانجي
.أنا واثق أنّها بخير

208
00:16:41,810 --> 00:16:45,050
!سيكونون بخير! أنا أؤمن بهم

209
00:16:46,180 --> 00:16:48,320
...صحيح... معه حقّ

210
00:16:51,090 --> 00:16:54,160
.يؤمن أوسوبّ-سان بأصدقائه

211
00:16:54,160 --> 00:16:56,530
.لهذا يستطيع أن يكون هادئًا

212
00:16:58,300 --> 00:17:00,700
...شكرًا لك يا أوسوبّ-سان. أنا

213
00:17:00,700 --> 00:17:03,730
الحقيقة هي أنّك خائف من
صعود الجبل فحسب، أليس كذلك؟

214
00:17:04,400 --> 00:17:08,640
لكن سمعت أنّ في الجبل
!مخلوقات كاليتّي والأرانب الدّببة

215
00:17:08,640 --> 00:17:10,640
!قل ذلك من البداية إذًا

216
00:17:11,180 --> 00:17:14,280
سيكون الأمر بخير. إنّنا نتحدّث
.عن لوفي، لذا سيتدبّر الأمر

217
00:17:14,280 --> 00:17:16,610
لا أستطيع منع نفسي
!من الخوف! هل من مشكل؟

218
00:17:16,950 --> 00:17:17,850
!دولتون-سان

219
00:17:17,850 --> 00:17:19,220
!ا-انتظر

220
00:17:22,480 --> 00:17:23,390
.دولتون-سان

221
00:17:23,390 --> 00:17:24,590
!دولتون-سان

222
00:17:24,590 --> 00:17:26,820
هلاّ أخبرني أحدكم من يكون
!هذا الشّخص؟

223
00:17:28,090 --> 00:17:30,290
!دولتون-سان! لا يمكنك

224
00:17:30,590 --> 00:17:35,130
لا تعترضوا طريقي! لا يمكننا
!أن ندع وابول يدخل القلعة! أبدًا

225
00:17:35,130 --> 00:17:37,700
!لا يعقل أنّك ذاهب إلى القلعة

226
00:17:37,700 --> 00:17:39,640
!في حالتك هذه... هذا طيش

227
00:17:40,600 --> 00:17:43,310
متى سأقاتل إلّم أقاتل الآن؟

228
00:17:43,940 --> 00:17:48,610
،إن عاد وابول إلى عرشه
!ستصبح هذه البلاد فاسدة إلى الأبد

229
00:17:50,950 --> 00:17:53,480
!يتعذّر عليك القتال في حالتك هذه

230
00:17:53,480 --> 00:17:56,090
...كما أنّنا لسنا أندادًا لهم

231
00:17:56,890 --> 00:18:01,490
سأسوّي هذا الأمر! حتّى إن اضطررتُ
!لاستخدام الحيل الرّخيصة

232
00:18:18,180 --> 00:18:20,640
.اركب على ظهري. سأقلّك إلى القلعة

233
00:18:22,880 --> 00:18:24,780
!لست بحاجة للخجل

234
00:18:24,780 --> 00:18:27,120
.لا أريد إهدار عزمك فحسب

235
00:18:27,620 --> 00:18:28,920
...أوسوبّ-سان

236
00:18:30,860 --> 00:18:37,330
...تمسّك، اتّفقنا؟ سآخذك
...إلى القلعة الآن

237
00:18:39,700 --> 00:18:41,230
...أوسوبّ-سان

238
00:18:45,670 --> 00:18:49,210
.عذرًا يا أوسوبّ-كن
...لا أظنّ أنّ هذا سيفلح حقًّا

239
00:18:49,210 --> 00:18:52,610
!بلى سيفلح! سأقلّك إلى هناك

240
00:18:52,610 --> 00:18:57,180
!سوف تقاتل لأجل البلاد، صحيح؟
!سوف تسوّي هذه المسألة، صحيح؟

241
00:18:57,850 --> 00:19:01,690
!لا تقلق. سآخذك إلى هنالك حتمًا

242
00:19:04,560 --> 00:19:06,490
...يا للغبيّ

243
00:19:08,590 --> 00:19:11,060
علينا صعود الجبل فحسب، صحيح؟

244
00:19:12,530 --> 00:19:13,700
...زورو

245
00:19:16,130 --> 00:19:17,300
!أيّها النّذل! أيّها النّذل! لكمة أوسوبّ

246
00:19:17,300 --> 00:19:20,870
!مؤلم! مؤلم! ما الّذي تفعله؟

247
00:19:22,310 --> 00:19:25,540
!كنت على وشك استخدام قوّتي الجادّة

248
00:19:25,810 --> 00:19:28,510
.نعم... أعلم

249
00:19:28,510 --> 00:19:29,210
!قوّتي الجادّة

250
00:19:29,210 --> 00:19:30,950
...مذهل، مذهل

251
00:19:31,980 --> 00:19:35,220
انتظروا! إن كنتم ستصعدون
...حتّى هناك

252
00:19:37,250 --> 00:19:39,160
.فثمّة طريق حبليّ إلى القلعة

253
00:19:39,160 --> 00:19:43,390
لا يمكن. ما عاد هنالك
.حبل متّصل بالقلعة

254
00:19:43,890 --> 00:19:48,030
بلى هناك. قام أحدهم بإعادة
...وصل حبلٍ أبيض

255
00:19:48,030 --> 00:19:50,900
بشجرةٍ كبيرة بضواحي غياستا
!وحتّى القلعة

256
00:19:51,740 --> 00:19:53,000
غياستا؟

257
00:19:53,000 --> 00:19:56,470
إنّه اسم البلدة الّتي اتّجهت
.لها الطّبيبة كوريها آخر مرّة

258
00:19:57,410 --> 00:19:58,880
!يا لوفي

259
00:19:59,240 --> 00:19:59,910
ماذا؟

260
00:19:59,910 --> 00:20:01,010
أين ذلك الشّخص؟

261
00:20:01,010 --> 00:20:01,880
شخص؟

262
00:20:02,710 --> 00:20:04,020
!ليس هنا

263
00:20:04,020 --> 00:20:04,950
أيّ شخص؟

264
00:20:04,950 --> 00:20:07,250
!وغد الصّفيح ذاك! لقد اختفى

265
00:20:11,890 --> 00:20:16,260
.صعد على فرس النّهر المشعّر
.ما كان لينزل لوحده

266
00:20:16,590 --> 00:20:18,860
...متى قام بـ

267
00:20:18,860 --> 00:20:21,900
!عندما كنت مفتونًا بالتّحوّلات بالطّبع

268
00:20:22,140 --> 00:20:26,840
!ذلك الوغد! سأجده حالاً وأجهز عليه

269
00:20:27,540 --> 00:20:30,040
لا يمكن أنّه دخل إلى القلعة
...من مكانٍ ما

270
00:20:30,780 --> 00:20:32,310
...في تلك الحالة، نامي-سان ستكون

271
00:20:34,410 --> 00:20:36,850
،ذلك الوغد! إن تجرّأ على لمس نامي-سان

272
00:20:36,850 --> 00:20:37,150
!سأفرغ أحشاءه مائة مرّة

273
00:20:37,150 --> 00:20:37,880
!انتظر

274
00:20:39,480 --> 00:20:43,290
تبًّا، أيريد أن يموت؟

275
00:20:43,590 --> 00:20:44,920
...دكتورين

276
00:20:46,990 --> 00:20:49,260
...لقد دعاني

277
00:20:52,430 --> 00:20:54,130
...بصديقه

278
00:21:04,680 --> 00:21:08,480
!أين ذهبت يا ذا الفم المزعج؟

279
00:21:09,610 --> 00:21:12,120
.يبدو أنّ حمّتي همدت قليلاً

280
00:21:12,650 --> 00:21:16,250
على هذا الحال، من المرجّح
.أن أستطيع العودة إلى السّفينة قريبًا

281
00:21:18,490 --> 00:21:20,420
!ما الّذي أفعله؟

282
00:21:20,930 --> 00:21:25,160
لا أملك الوقت لأستريح في
!هذا السّرير! فيفي تنتظرني

283
00:21:29,070 --> 00:21:32,000
!ما الّذي يجري هنا؟

284
00:21:32,000 --> 00:21:34,570
أهذه قلعة درام خاصّتي حقًّا؟

285
00:21:36,370 --> 00:21:39,310
ما الّذي فعلوه لقلعتي؟

286
00:21:41,210 --> 00:21:43,910
!لن يفلتوا بفعلتهم هذه

287
00:21:44,980 --> 00:21:48,490
!سأمضغهم فردًا فردًا

288
00:22:01,400 --> 00:22:10,170
حتّى هذه البلدة الّتي لا تنام غفت الآن

289
00:22:11,710 --> 00:22:22,850
من اليوم فصاعدًا، سيتغيّر شيء

290
00:22:22,850 --> 00:22:32,630
أنا واثق أنّي أستطيع البدء
من جديد، بما أنّي لستُ لوحدي

291
00:22:33,100 --> 00:22:43,310
،بمجرّد كونكم إلى جانبي
أشعر أنّي أستطيع أن أغدو قويًّا

292
00:22:43,570 --> 00:22:54,050
،أتساءل إلى أيّ مدى يمكنني أن أصل
صوب المكان الّذي يقود إلى المستقبل

293
00:22:54,050 --> 00:23:02,390
إنّه يسطع من بعيد، غامرًا العالم

294
00:23:02,390 --> 00:23:06,060
قبل ضياء الفجر

295
00:23:11,270 --> 00:23:14,040
يجب أن أخرج من هنا بسرعة
!ما دامت دكتورين غائبة

296
00:23:14,040 --> 00:23:17,010
!ذاك الوغد! سأجده حالاً وأجهز عليه

297
00:23:17,010 --> 00:23:19,780
،إن تجرّأ على لمس نامي-سان
!سأفرغ أحشاءه مائة مرّة

298
00:23:19,780 --> 00:23:21,650
!مصيبة! يبدو كشخصٍ شرّير

299
00:23:21,650 --> 00:23:23,410
!حاصرتك يا ذا الفم المزعج

300
00:23:23,410 --> 00:23:24,920
!يملك دولتون-سان متفجرّات

301
00:23:24,920 --> 00:23:27,280
.لا أدري ما الّذي يجري هنا

302
00:23:27,280 --> 00:23:28,620
:في الحلقة القادمة من وان بيس

303
00:23:28,620 --> 00:23:32,420
!عندما ينتهي حكم المملكة"
".يرفرف علم الإيمان إلى الأبد

304
00:23:32,420 --> 00:23:32,710
!ملك القراصنة، لن يكون إلاّ أنا

305
00:23:32,710 --> 00:23:35,990
\h\h\h\h\h\h\h\h\h\h!عندما ينتهي حكم المملكة
يرفرف علم الإيمان إلى الأبد\h\h\h\h\h\h\h