1
00:00:07,720 --> 00:00:10,760
!العالم... نعم

2
00:00:11,290 --> 00:00:12,960
...اسعوا نحو الحرّيّة

3
00:00:12,960 --> 00:00:17,000
.وسيمتدّ العالم بأسره أمام أنظاركم

4
00:00:17,460 --> 00:00:20,800
،إن كانت أحلامكم اللاّمتناهية هي مرشدكم

5
00:00:21,330 --> 00:00:22,800
!فتجاوزوها

6
00:00:23,100 --> 00:00:26,070
!تحت راية ما تؤمنون به

7
00:00:30,540 --> 00:00:36,150
بدأتُ بحثي للتّوّ، محدثًا رذاذ مياه

8
00:00:36,150 --> 00:00:39,380
متّجهًا نحو عالم بلا نهاية

9
00:00:40,790 --> 00:00:45,660
بقلبٍ يتدفّق حماسًا، سأذهب حتّى نهاية الأرض

10
00:00:45,660 --> 00:00:54,070
باحثًا عن ضياء لم يرها أحد بعد

11
00:00:54,070 --> 00:00:59,800
عندما تُأرجح شمس الصّيف أشرعة قلبي

12
00:00:59,800 --> 00:01:04,240
"حلّق بعيدًا أيّها البحر الأزرق الكئيب"

13
00:01:04,240 --> 00:01:09,880
تكون تلك إشارة لفتح الباب نحو عالم جديد

14
00:01:09,880 --> 00:01:13,750
"حلّقي بعيدًا أيّتها السّماء الزّرقاء الكئيبة"

15
00:01:13,750 --> 00:01:18,690
نبحر عبر أمواج اليأس الوعرة

16
00:01:18,690 --> 00:01:26,430
متّجهين نحو الأفق

17
00:01:26,430 --> 00:01:31,940
بدأتُ بحثي للتّوّ، محدثًا رذاذ مياه

18
00:01:31,940 --> 00:01:36,640
متّجهًا نحو عالم بلا نهاية

19
00:01:36,640 --> 00:01:41,880
بقلبٍ يتدفّق حماسًا، سأذهب حتّى نهاية الأرض

20
00:01:41,880 --> 00:01:48,150
باحثًا عن ضياء لم يرها أحد بعد

21
00:01:51,620 --> 00:01:54,930
ماذا؟! سيُنسَف الميدان بقذيفة
!مدفعيّة بعد عشر دقائق؟

22
00:01:54,930 --> 00:01:56,560
.صحيح. سيحدث الهجوم على السّاعة 4:30

23
00:01:56,560 --> 00:01:57,430
!الـ4:30؟

24
00:01:57,730 --> 00:01:59,900
!وجدناك أيّتها الأميرة فيفي

25
00:01:59,900 --> 00:02:03,370
.أتساءل كم سيتمّ ترقيتي إن قتلتك

26
00:02:03,370 --> 00:02:04,440
!سنتقدّم قبلكما

27
00:02:04,440 --> 00:02:05,240
!سنتقدّم قبلكما

28
00:02:08,570 --> 00:02:09,610
!...عشر دقائق أخرى

29
00:02:09,610 --> 00:02:11,940
!هذه فعلاً... الفرصة الأخيرة

30
00:02:12,540 --> 00:02:16,920
...ستقرّر العشر دقائق القادمة
!مصير هذه البلاد

31
00:02:20,090 --> 00:02:22,720
!فاكهة المطّاط: البازوكا

32
00:02:26,390 --> 00:02:28,590
!لا نملك أدنى نيّة في إفساح الطّريق لك

33
00:02:29,490 --> 00:02:30,530
!لا تعترضوا طريقي

34
00:02:30,530 --> 00:02:32,160
!ثلاثون زهرة

35
00:02:33,700 --> 00:02:34,930
!خنق

36
00:02:34,930 --> 00:02:36,730
!أيّها الرّقيب الأوّل
!تلك المرأة هي... نيكو روبين

37
00:02:36,730 --> 00:02:38,000
مطلوب
حيّ أو ميت: نيكو روبين

38
00:02:38,000 --> 00:02:41,410
على رأسها مكافأة وكانت
!حديث العالم قبل عشرين سنة

39
00:02:48,180 --> 00:02:52,520
...يدي اليمنى تجفّ كلّ شيء

40
00:02:57,520 --> 00:02:59,590
!الأرض الميّتة

41
00:03:04,300 --> 00:03:08,070
!يبدو ذلك تمساحيًّا
!لوفي، اركض إلى الضّريح الملكيّ

42
00:03:08,070 --> 00:03:11,840
!يبدو ذلك تمساحيًّا"
"!لوفي، اركض إلى الضّريح الملكيّ

43
00:03:17,180 --> 00:03:18,880
!كان ذلك وشيكًا

44
00:03:18,880 --> 00:03:21,150
...يده اليمنى خطيرة

45
00:03:21,150 --> 00:03:24,120
!تحوّلت ساحة العشب إلى صحراء

46
00:03:24,780 --> 00:03:26,580
أين ذهب؟

47
00:03:27,090 --> 00:03:30,590
...جعلتني أهدر طاقتي

48
00:03:37,800 --> 00:03:39,400
...أخفقت

49
00:03:42,370 --> 00:03:44,070
...كروكو

50
00:03:44,770 --> 00:03:46,770
...خسرتَ

51
00:03:49,410 --> 00:03:51,240
...مجدّدًا

52
00:03:52,440 --> 00:03:56,210
يا قبّعة القشّ... هذه
...طريقة جيّدة لتموت

53
00:03:59,180 --> 00:04:03,150
،في غضون ستّ دقائق أو نحوها
.سيُفجّر هذا الفناء مع الميدان

54
00:04:03,560 --> 00:04:05,690
...آسف، لكنّي مستعجل

55
00:04:05,890 --> 00:04:11,660
استرخ هنا واحتفل بولادة
.ملك جديد لبلاد الرّمل

56
00:04:14,270 --> 00:04:15,230
...حسنًا

57
00:04:18,970 --> 00:04:20,640
...يجب أن أذهب أيضًا

58
00:04:20,970 --> 00:04:23,210
قال أنّه في المعبد الضّريحيّ
...غربًا من هنا

59
00:04:39,760 --> 00:04:42,760
!كان ذلك وشيكًا! خلتُ أنّني سأموت

60
00:04:48,070 --> 00:04:50,600
...ذلك الوغد... لقد ذهب

61
00:04:52,440 --> 00:04:54,570
!رأيتُه يحلّق في ذلك الاتّجاه

62
00:04:54,910 --> 00:04:58,040
!لن أدع ذلك التّمساح يهرب

63
00:04:58,040 --> 00:05:02,310
غرب القصر — المعبد الضّريحيّ
\h\h\h\h\h\h\h\h\h\h\h\h\h\h\h\h\h\h\h\h\h(الضّريح الملكيّ)

64
00:05:08,620 --> 00:05:10,050
...هذا هو إذًا

65
00:05:10,050 --> 00:05:14,260
الضّريح الملكيّ حيث ترقد جثث
.أجيالٍ من الملوك

66
00:05:16,800 --> 00:05:18,400
أين البونيغليف؟

67
00:05:30,980 --> 00:05:31,940
!درج خفيّ

68
00:05:33,410 --> 00:05:36,850
.يقبع البونيغليف عميقًا تحت الأرض

69
00:05:38,120 --> 00:05:41,950
عادةً، لا يعرف النّاس حتّى
...بوجود البونيغليف

70
00:05:41,950 --> 00:05:43,820
.العالم السّفليّ عميق

71
00:05:43,820 --> 00:05:46,160
حتّى إن كانت الدّول تخضع
،للحكومة العالميّة

72
00:05:46,160 --> 00:05:48,830
.لا يعني أنّ ملوكها يعلمون كلّ شيء

73
00:05:50,600 --> 00:05:52,230
...لا لوم عليك

74
00:05:53,230 --> 00:05:58,570
فلا بدّ أنّك لم تعلم أنّه يوجد في
.هذا العالم من يستطيع فكّ رموزه

75
00:05:58,740 --> 00:06:00,570
بإمكانك قراءة البونيغليف؟

76
00:06:00,570 --> 00:06:04,980
.نعم... لهذا تعاونت مع كروكودايل

77
00:06:04,980 --> 00:06:07,780
.وبسبب ذلك لا يستطيع قتلي

78
00:06:08,310 --> 00:06:13,420
من المرجّح أنّ البونيغليف الّذي
.في هذه البلاد يشير إلى مكان بلوتون

79
00:06:13,850 --> 00:06:14,720
أليس كذلك؟

80
00:06:15,250 --> 00:06:16,290
...لا أدري

81
00:06:16,550 --> 00:06:20,730
كانت عائلة ألاباستا المالكة
.ملزمة على حمايته لأجيال

82
00:06:20,730 --> 00:06:23,190
.هذا كلّ ما يمثّله الأمر لنا

83
00:06:23,360 --> 00:06:25,660
!حمايته؟! لا تدفعني للضّحك

84
00:06:32,270 --> 00:06:33,910
...يا له من مكان عجيب

85
00:06:34,170 --> 00:06:36,910
.إنّه يتواجد عميقًا خلف البوّابة

86
00:06:45,350 --> 00:06:46,850
...بالفعل

87
00:07:11,910 --> 00:07:13,680
...لن أدعك... تذهبين

88
00:07:14,850 --> 00:07:17,250
كم من مرّة يجب أن تواجهيني حتّى ترضي؟

89
00:07:35,030 --> 00:07:36,730
...نيكو روبين

90
00:07:40,110 --> 00:07:42,870
...سوف... أقبض عليك

91
00:08:03,860 --> 00:08:05,500
...كروكو... دايل

92
00:08:07,100 --> 00:08:09,270
.يبدو أنّ تلك المرأة أطاحت بك

93
00:08:09,830 --> 00:08:12,900
لم أتخيّل أنّكم ستتبعوني إلى
.هذه البلدة يا رجال البحريّة

94
00:08:14,070 --> 00:08:18,540
أين نقيبكم؟ هل هرب ذلك الوغد الدّخانيّ؟

95
00:08:22,850 --> 00:08:25,650
.لا يمكن للفاشلين أن يتحدّثوا عن العدالة

96
00:08:25,650 --> 00:08:28,090
.نحن في بحر من هذا القبيل

97
00:08:28,090 --> 00:08:32,320
عودي إلى قاعدتك وكرّسي
.وقتك في الحديث عن عدالتك

98
00:08:45,270 --> 00:08:46,500
!كروكودايل

99
00:08:57,720 --> 00:09:00,050
!...أيّها الحشرة

100
00:09:00,050 --> 00:09:01,190
!ما الّذي تفعله؟

101
00:09:01,490 --> 00:09:04,820
ما الّذي أفعله؟! إنّي أحاول وضع
!نفسي في مكان كروكودايل

102
00:09:04,820 --> 00:09:07,330
،مثلاً، إن كنتُ مكانه
...من أين سأُطلق قذيفة مدفعيّة

103
00:09:07,330 --> 00:09:09,660
!انس ذلك وابحث عن المدفعيّ
!بقيت أمامنا خمس دقائق فحسب

104
00:09:09,990 --> 00:09:13,330
خمس دقائق أخرى! ستُنسَف حياة
!مليون شخص بعد خمس دقائق

105
00:09:13,330 --> 00:09:16,630
!علينا الإسراع
!علينا أن نسرع ونجد المدفعيّ

106
00:09:16,630 --> 00:09:19,340
تشوبّر! ألا يمكنك إيجاده بحاسّة شمّك؟

107
00:09:19,340 --> 00:09:22,310
لا أستطيع. فرائحة البارود
!تغطّي البلدة بأكملها

108
00:09:22,540 --> 00:09:24,010
.إذًا... أصغِ

109
00:09:24,010 --> 00:09:27,850
جد رائحة "المدفعيّ الّذي
."ربّما يصوّب نحو مركز الميدان

110
00:09:27,850 --> 00:09:28,980
أيّ رائحة تلك؟

111
00:09:28,980 --> 00:09:30,780
!وما أدراني؟! ابذل جهدك

112
00:09:30,780 --> 00:09:31,750
!ماذا؟

113
00:09:34,920 --> 00:09:37,290
قذيفة مدفعيّة يمكنها تفجير
...ما في قطر 5 كيلومترات

114
00:09:38,720 --> 00:09:41,260
...مهلاً. لا بدّ أنّها كبيرة إذًا

115
00:09:41,260 --> 00:09:44,930
،إن كانت ستُطلق من مدفع
...لن يُنقَل بعيدًا

116
00:09:44,930 --> 00:09:47,230
يجدر أن يكون أقرب
!من الميدان في النّهاية؟

117
00:09:47,870 --> 00:09:50,740
!تبًّا! لا أملك الوقت للرّجوع

118
00:09:51,170 --> 00:09:52,570
!سأتّخذ طريقًا مختصرًا

119
00:09:53,810 --> 00:09:55,040
!كيف الوضع من السّماء يا بيل؟

120
00:09:55,410 --> 00:09:57,980
فتّشتُ في كلّ ركنٍ من
،أسطح المباني قرب الميدان

121
00:09:57,980 --> 00:09:59,680
لكن لم أرصد أيّ تجهيزات
.لإطلاق مدفع في أيّ مكان

122
00:09:59,910 --> 00:10:02,880
...قد يكون في مكان داخل بناية ما إذًا

123
00:10:03,080 --> 00:10:04,350
!سأفتشّها جميعًا

124
00:10:04,350 --> 00:10:05,350
!حسنًا

125
00:10:23,330 --> 00:10:24,540
!قبّعة القشّ

126
00:10:25,140 --> 00:10:27,510
أين ذهب... التّمساح؟

127
00:10:31,580 --> 00:10:34,050
وردنا تحذير أنّه على تمام السّاعة الـ4:30

128
00:10:34,050 --> 00:10:36,380
سيُنسف ميدان القصر حيث
!يجري التّمرّد بقذيفة مدفعيّة

129
00:10:36,380 --> 00:10:39,980
!أوقفوها بطريقةٍ ما رجاءً
!حياة مليون مواطن مهدّدة

130
00:10:44,320 --> 00:10:47,090
.لا يمكن للفاشلين أن يتحدّثوا عن العدالة

131
00:10:47,090 --> 00:10:49,560
.نحن في بحر من هذا القبيل

132
00:10:49,560 --> 00:10:53,800
عودي إلى قاعدتك وكرّسي
.وقتك في الحديث عن عدالتك

133
00:10:57,970 --> 00:11:00,240
!أخبريني! أين التّمساح؟

134
00:11:21,230 --> 00:11:23,730
.ذهب في اتّجاه المعبد الضّريحيّ

135
00:11:23,930 --> 00:11:25,700
!ذلك الاتّجاه؟! شكرًا

136
00:11:39,340 --> 00:11:41,110
...أيّ عدالة

137
00:11:58,300 --> 00:12:00,800
...بئسًا لمقرّ البحريّة

138
00:12:12,510 --> 00:12:15,380
...ماذا؟ لا أستطيع الحراك جيّدًا

139
00:12:17,380 --> 00:12:20,150
...هذا غريب... عندما آكل اللّحم

140
00:12:20,890 --> 00:12:22,890
ما الخطب؟ هذه جراح
...طفيفة فحسب

141
00:12:24,220 --> 00:12:26,520
...أتساءل إن كنتُ متعبًا قليلاً

142
00:13:00,590 --> 00:13:04,060
هل أخبرك بما أردت معرفته؟

143
00:13:13,540 --> 00:13:17,080
...فهمت... درج خفيّ

144
00:13:22,550 --> 00:13:25,080
!...أربع... بقيت أربع دقائق

145
00:13:47,540 --> 00:13:51,710
!ألا توجد أخرى؟
أهذا كلّ ما تخفيه هذه البلاد؟

146
00:13:51,940 --> 00:13:55,910
.ألم ترضي؟ وفيتُ بوعدي

147
00:13:57,820 --> 00:13:58,680
...نعم

148
00:14:00,920 --> 00:14:03,320
...هذا ما أتوقّعه من سرّ وطنيّ

149
00:14:03,690 --> 00:14:06,120
،مهما بحثت يائسًا

150
00:14:06,120 --> 00:14:08,790
.لا يمكنك إيجاده ما لم تكن تعرف مكانه

151
00:14:09,830 --> 00:14:12,560
هذا هو البونيغليف إذًا يا نيكو روبين؟

152
00:14:14,300 --> 00:14:15,500
...لم يستغرق ذلك طويلاً

153
00:14:16,330 --> 00:14:18,640
.إنّه غريب

154
00:14:18,800 --> 00:14:20,200
هل استطعت فكّ رموزه؟

155
00:14:20,940 --> 00:14:21,670
.نعم

156
00:14:22,210 --> 00:14:25,210
...هذا جيّد، والآن اقرئي
...هذا الشّيء المدعو بونيغليف

157
00:14:29,350 --> 00:14:34,350
غزت كاهيرا ألاباستا... في العام
.‫239 من التّقويم الفلكيّ السّماويّ

158
00:14:34,650 --> 00:14:38,460
وفي العام 260، حكم تايمر
.سلالة بيتيْن الحاكمة

159
00:14:39,260 --> 00:14:43,460
عام 306، تمّ تشييد كاتدرائيّة
.تاف في إيرومالو

160
00:14:43,960 --> 00:14:47,370
...عام 325، قام البطل مامدين من أولتيا

161
00:14:47,370 --> 00:14:51,000
!انتظري! انتظري! أهذا ما نريد معرفته؟

162
00:14:51,500 --> 00:14:54,070
من يهتمّ لتاريخ هذه البلاد؟

163
00:14:54,070 --> 00:14:58,080
"فقط دلّيني عن مكان "القوّة العسكريّة
!الأكثر فتكًا والّتي تقبع في هذه البلاد

164
00:14:58,580 --> 00:15:00,310
!أين هو بلوتون؟

165
00:15:02,450 --> 00:15:03,780
.لم يُذكر هنا

166
00:15:04,150 --> 00:15:05,180
!ماذا؟

167
00:15:05,180 --> 00:15:07,650
.نُحِت هنا التّاريخ فحسب

168
00:15:07,650 --> 00:15:08,650
!أهذا صحيح؟

169
00:15:08,650 --> 00:15:09,950
...بلوتون

170
00:15:09,950 --> 00:15:13,760
.لم أرَ هذه الكلمة تُذكر ولو مرّة

171
00:15:26,640 --> 00:15:30,680
...فهمت... هذا مؤسف

172
00:15:31,910 --> 00:15:34,810
...كنتِ شريكةً ممتازة لي، ولكن

173
00:15:35,780 --> 00:15:37,480
.أظنّني سأقتلك هنا

174
00:15:37,980 --> 00:15:38,680
!ما...؟

175
00:15:40,250 --> 00:15:44,190
لقد وفينا هنا بالاتّفاق الّذي
.أبرمناه قبل أربع سنوات

176
00:15:44,820 --> 00:15:47,430
.هذا ما قلته آنذاك

177
00:15:47,830 --> 00:15:50,200
،إن أخذتك إلى مكان البونيغليف

178
00:15:50,200 --> 00:15:53,160
ستخبريني بالمعلومات
...الّتي تخصّ السّلاح

179
00:15:53,870 --> 00:15:57,200
كان عملك في باروك وركس
في الأعوام الأربعة الماضية ممتازًا

180
00:15:57,200 --> 00:15:59,900
.من حيث القدرة العقليّة والقدرة القياديّة

181
00:16:00,710 --> 00:16:05,710
ذلك يكفيني لأقول
.أنّك كنتِ... امرأةً مفيدة

182
00:16:06,010 --> 00:16:10,080
!لكنّك... نكثت بوعدك لي في الأخير

183
00:16:12,950 --> 00:16:16,690
لا يضمّ البونيغليف في هذه
.البلاد أيّ دليل عن بلوتون

184
00:16:18,260 --> 00:16:22,890
أم أنّك... لم تكوني تنوين
،إخباري من البداية

185
00:16:22,890 --> 00:16:24,900
حتّى إن اكتشفت مكانه؟

186
00:16:33,300 --> 00:16:37,240
...لكن... لستُ غاضبًا منك بتاتًا

187
00:16:37,540 --> 00:16:40,380
هل تعلمين لماذا يا نيكو روبين؟

188
00:16:41,080 --> 00:16:43,680
.لا تتحدّث بغباء... كنّا فريقًا لأربع سنوات

189
00:16:43,680 --> 00:16:46,650
.عرفتُ أنّك ستفعل شيئًا كهذا

190
00:16:47,950 --> 00:16:48,750
!ماء؟

191
00:16:49,320 --> 00:16:51,160
يمكن للسّكين أن تطعنك
!إن ابتللتَ، صحيح؟

192
00:16:53,830 --> 00:16:55,290
...لقد تفاداها! أين

193
00:17:02,670 --> 00:17:06,070
سوف أسامحك على كلّ شيء
...يا نيكو روبين

194
00:17:13,180 --> 00:17:20,790
.لأنّني لم أثق بأيّ أحد... من البداية

195
00:17:26,060 --> 00:17:30,030
بتّ أعرف من ردّ فعل كوبرا
.أنّ بلوتون موجود

196
00:17:30,530 --> 00:17:34,030
.لستُ بحاجة للاعتماد على البونيغليف
.سوف أجده بنفسي

197
00:17:34,030 --> 00:17:37,040
،فور أن تصبح هذه البلاد تحت سيطرتي
.فستكون تلك مسألة وقتٍ لا غير

198
00:17:39,500 --> 00:17:42,570
ما الّذي يجري؟! ما زال من
!المبكّر على الهجوم على الميدان

199
00:17:43,780 --> 00:17:45,640
!أنت... ماذا فعلت؟

200
00:17:45,940 --> 00:17:48,380
...لا شيء جلل

201
00:17:48,680 --> 00:17:52,680
تمّ بناء هذا المعبد التّحأرضيّ المقدّس
،بحيث إن سحبت ولو عمودًا صغيرًا

202
00:17:52,680 --> 00:17:56,550
،فسوف يخلّ ذلك بالتّوازن كلّه
.ما سيسفر عن تدمير المعبد

203
00:17:58,490 --> 00:18:02,590
.أنتما الاثنان... ستموتان هنا معي

204
00:18:03,330 --> 00:18:07,670
،بصفتي الملك الثّاني عشر لآل نيفيرتاري

205
00:18:07,670 --> 00:18:11,270
لا يمكنني أن أمنح مملكة
.الرّمال لشخصٍ مثلك

206
00:18:27,490 --> 00:18:30,360
...أين هو؟ بقيت ثلاث دقائق

207
00:18:30,360 --> 00:18:33,890
مدفع كبير بما يكفي لتفجير
...ما في قطر 5 كيلومترات

208
00:18:33,890 --> 00:18:37,260
...لن يتّسع إلاّ في أماكن محدّدة

209
00:18:37,260 --> 00:18:40,200
فلمَ لا نستطيع إيجاده
مع أنّنا بحثنا بهذا القدر؟

210
00:18:41,200 --> 00:18:43,500
فضاء مفتوح يمكنه احتواء
...مدفع كبير

211
00:18:45,000 --> 00:18:45,600
!رصاصة طائشة

212
00:18:47,440 --> 00:18:48,710
...فضاء مفتوح

213
00:18:51,110 --> 00:18:54,380
!هذا ليس عدلاً يا كوزا
!هل كنت تختبئ في مكان كهذا؟

214
00:18:54,380 --> 00:18:56,210
!هذا ليس عادلاً أيّها القائد

215
00:18:56,850 --> 00:18:59,250
...صحيح... يمكن لذلك المكان

216
00:18:59,780 --> 00:19:02,350
!هذا خطير أيّها الوغد

217
00:19:02,350 --> 00:19:03,350
!نجم الدّخان

218
00:19:03,370 --> 00:19:05,960
مكانٌ لا يلفت انتباه النّاس
.وكبير في نفس الوقت

219
00:19:05,960 --> 00:19:08,590
!أيّها الغبيّ! لستُ من جيش المتمرّدين

220
00:19:08,590 --> 00:19:09,830
!مطرقة أوسوبّ

221
00:19:09,830 --> 00:19:11,430
!شريط أوسوبّ المطّاطي الهالك

222
00:19:11,900 --> 00:19:16,130
!ليلقّنك ذلك درسًا أيّها الوغد
تبًّا... من يحسبونني؟

223
00:19:16,130 --> 00:19:18,600
.لا تتفاجؤوا عندما أخبركم بهذا
!لا، بل تفاجؤوا

224
00:19:18,600 --> 00:19:21,940
...أنا القائد المشهور... أو

225
00:19:21,940 --> 00:19:25,110
ماذا؟ أ-أهذه أنت يا فيفي؟
!هل وجدت المدفعيّ؟

226
00:19:25,110 --> 00:19:27,050
!اكتشفت مكانه! لا بدّ أنّه هناك

227
00:19:27,050 --> 00:19:30,550
!ماذا؟! حقًّا؟! حسنًا! دعينا نبلغهم إذًا

228
00:19:30,780 --> 00:19:33,520
!على أيّ حال، سأستدعي الجميع
واثقة من مكانه، صحيح؟

229
00:19:35,120 --> 00:19:38,120
!القتل المؤكّد: نجم الثّعبان الأحمر

230
00:20:14,530 --> 00:20:16,330
.عجبًا، نمتُ جيّدًا

231
00:20:18,800 --> 00:20:19,800
...صحيح

232
00:20:19,800 --> 00:20:22,330
أصبح جسدي غير قادر
...على الحراك فجأةً

233
00:20:22,330 --> 00:20:26,140
لذا قرّرت أن أخاطر وآخذ
.قيلولة بما أنّه ما كان باليد حيلة

234
00:20:26,540 --> 00:20:29,110
...والآن أشعر أنّي بخير، لذا

235
00:20:30,410 --> 00:20:31,210
!صحيح

236
00:20:32,410 --> 00:20:35,110
!التّمساح! سأهزمه

237
00:20:44,620 --> 00:20:46,220
...تلك الحفرة

238
00:20:50,200 --> 00:20:51,660
...تبدو تمساحيّة

239
00:20:57,540 --> 00:21:00,000
...يا لك من ملك نموذجيّ

240
00:21:00,440 --> 00:21:05,340
هل تحاول أن تُدفنَ حيًّا
وتسحبني معك... لأجل البلاد؟

241
00:21:05,680 --> 00:21:07,810
...لكن... لا يمكنك قتلي

242
00:21:09,280 --> 00:21:12,950
يمكنني تغيير كلّ حجر أساس
.إلى رمل وأهرب من هنا

243
00:21:13,920 --> 00:21:16,220
.ستموت عبثًا يا كوبرا

244
00:21:17,290 --> 00:21:19,620
.بقيت أقلّ من ثلاث دقائق

245
00:21:19,620 --> 00:21:22,530
بعد انهيار هذا المعبد المقدّس
،وحدوث الانفجار الكبير في الميدان

246
00:21:22,530 --> 00:21:26,200
سينفجر كلّ من يعترض طريقي
.في طرفة عين

247
00:21:26,770 --> 00:21:31,600
في تلك اللّحظة... ستصبح
.هذه البلاد... دولتي

248
00:21:48,790 --> 00:21:51,390
!كروكودايل

249
00:21:51,390 --> 00:21:53,390
!أين أنت؟

250
00:22:06,070 --> 00:22:12,180
إلى أيّ اتّجاه عليّ أن أركض
لأرى غدًا أروع بكثير؟

251
00:22:12,180 --> 00:22:18,120
أمسكت مقود السّفينة وفتحت الخريطة
الأعجوبيّة الّتي خزّنتُها في قلبي

252
00:22:18,120 --> 00:22:24,360
،جعلتُ السّماء هدفي وتبعت أحلامي
رغم أنّني أضيع أحيانًا

253
00:22:24,360 --> 00:22:29,790
،لم يكن حلمًا عندما التقيت بك
فقد اكتشفت الشّخص الرّائع بداخلي

254
00:22:29,790 --> 00:22:36,030
وببعض الشّجاعة، اكتسبتُ شيئًا عظيمًا

255
00:22:36,030 --> 00:22:41,470
والآن هو الوقت المناسب
لأمنيتي لتصبح عهدي

256
00:22:42,240 --> 00:22:45,240
أيّها الشّعاع اللاّمع! جد طريقك الجديد تمامًا

257
00:22:45,240 --> 00:22:49,010
دعنا نرسم قصّة المستقبل

258
00:22:49,010 --> 00:22:54,250
سأضع كلّ مشاعري في رياح جديدة تمامًا الآن

259
00:22:54,250 --> 00:22:57,360
أيّها الشّعاع اللاّمع! جد طريقك الجديد تمامًا

260
00:22:57,360 --> 00:23:00,260
رحلة لا نهاية لها لنكون معًا

261
00:23:00,260 --> 00:23:04,660
سألحق بك أينما ذهبت أيّها الشّعاع اللاّمع

262
00:23:10,870 --> 00:23:12,340
!لقد حاصرتك أيّها التّمساح

263
00:23:12,340 --> 00:23:14,440
قبّعة القشّ... لمَ أنت حيّ؟

264
00:23:14,440 --> 00:23:16,470
كم من مرّة تريد أن تُقتَل؟

265
00:23:16,470 --> 00:23:18,880
ماذا؟ هل المدفعيّ
!في مثل ذلك المكان حقًّا؟

266
00:23:18,880 --> 00:23:20,950
نعم! لا يوجد مكان آخر
!يمكنني التّفكير فيه

267
00:23:20,950 --> 00:23:22,550
.حسنًا! يتّجه الجميع إلى هنا
!لذا سنترك رسالة

268
00:23:22,550 --> 00:23:23,750
!سأسبقك

269
00:23:23,750 --> 00:23:25,920
!ماذا؟! انتظري يا فيفي! انتظريني

270
00:23:25,920 --> 00:23:27,390
:في الحلقة القادمة من وان بيس

271
00:23:27,390 --> 00:23:30,860
يقترب الكابوس! هذه القاعدة"
".السّرّيّة لجماعة الرّمل

272
00:23:30,860 --> 00:23:31,530
!ملك القراصنة، لن يكون إلاّ أنا

273
00:23:31,530 --> 00:23:35,400
!يقترب الكابوس
هذه القاعدة السّرّيّة لجماعة الرّمل