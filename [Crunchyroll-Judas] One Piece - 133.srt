1
00:00:07,790 --> 00:00:10,860
!العالم... نعم

2
00:00:11,390 --> 00:00:13,060
...اسعوا نحو الحرّيّة

3
00:00:13,060 --> 00:00:17,200
.وسيمتدّ العالم بأسره أمام أنظاركم

4
00:00:17,560 --> 00:00:20,930
،إن كانت أحلامكم اللاّمتناهية هي مرشدكم

5
00:00:21,430 --> 00:00:22,800
!فتجاوزوها

6
00:00:23,200 --> 00:00:26,170
!تحت راية ما تؤمنون به

7
00:00:30,640 --> 00:00:36,250
بدأتُ بحثي للتّوّ، محدثًا رذاذ مياه

8
00:00:36,250 --> 00:00:39,480
متّجهًا نحو عالم بلا نهاية

9
00:00:40,890 --> 00:00:45,760
بقلبٍ يتدفّق حماسًا، سأذهب حتّى نهاية الأرض

10
00:00:45,760 --> 00:00:54,170
باحثًا عن ضياء لم يرها أحد بعد

11
00:00:54,170 --> 00:00:59,910
عندما تُأرجح شمس الصّيف أشرعة قلبي

12
00:00:59,910 --> 00:01:04,340
"حلّق بعيدًا أيّها البحر الأزرق الكئيب"

13
00:01:04,340 --> 00:01:09,980
تكون تلك إشارة لفتح الباب نحو عالم جديد

14
00:01:09,980 --> 00:01:13,850
"حلّقي بعيدًا أيّتها السّماء الزّرقاء الكئيبة"

15
00:01:13,850 --> 00:01:18,790
نبحر عبر أمواج اليأس الوعرة

16
00:01:18,790 --> 00:01:26,530
متّجهين نحو الأفق

17
00:01:26,530 --> 00:01:32,040
بدأتُ بحثي للتّوّ، محدثًا رذاذ مياه

18
00:01:32,040 --> 00:01:36,740
متّجهًا نحو عالم بلا نهاية

19
00:01:36,740 --> 00:01:41,980
بقلبٍ يتدفّق حماسًا، سأذهب حتّى نهاية الأرض

20
00:01:41,980 --> 00:01:48,250
باحثًا عن ضياء لم يرها أحد بعد

21
00:02:00,200 --> 00:02:02,930
سأغليه لثلاث ليالٍ ويومين
...لأزيل المذاق المرّ

22
00:02:04,040 --> 00:02:07,040
!انتظرا فحسب يا نامي-سان وروبين-تشان

23
00:02:07,040 --> 00:02:08,970
!سيكون هذا فطورًا مميّزًا

24
00:02:08,970 --> 00:02:12,210
!وصفة متوارثة
سانجي، رجل الكاري الحديديّ

25
00:02:12,210 --> 00:02:16,150
!وصفة متوارثة"
".سانجي، رجل الكاري الحديديّ

26
00:02:21,950 --> 00:02:23,320
،سُحقًا

27
00:02:23,320 --> 00:02:26,860
وكأنّ هنالك من سكب حليبًا على هذا
.الضّباب. لا يمكنني رؤية أيّ شيء

28
00:02:26,860 --> 00:02:28,560
لوفي، هل ترى أيّ شيء؟

29
00:02:33,670 --> 00:02:35,570
!مهلاً، أرى شيئًا ما

30
00:02:38,570 --> 00:02:41,840
!مصيبة! ثمّة سفينة ضخمة أمامنا

31
00:02:42,240 --> 00:02:44,710
!سانجي-كُن! تولّ المقود
!استدر إلى أقصى الميمنة

32
00:02:44,940 --> 00:02:46,710
!حالاً يا نامي-سان

33
00:02:47,150 --> 00:02:49,610
—حبّ سانجي المميّز سوف

34
00:02:51,180 --> 00:02:52,950
!هـ-هذا سيّئ

35
00:02:52,950 --> 00:02:55,950
!نحن محاصرون بسفن البحريّة، صحيح؟

36
00:02:55,950 --> 00:02:56,960
!مذهل

37
00:02:57,560 --> 00:03:01,630
حتّى البحريّة لا يستطيعون
التّحرّك في هذا الضّباب؟

38
00:03:01,990 --> 00:03:05,460
قد يكون من الأفضل لنا الهروب
.مستغلّين هذا الضّباب الكثيف

39
00:03:05,900 --> 00:03:07,070
.معك حقّ

40
00:03:07,070 --> 00:03:10,070
واصلوا التّوجّه للأمام
.ولنلزم الصّمت جميعًا

41
00:03:10,070 --> 00:03:11,070
.خاصّة أنت يا لوفي

42
00:03:11,070 --> 00:03:11,870
!حاضر

43
00:03:13,740 --> 00:03:14,740
...نامي-سان

44
00:03:16,070 --> 00:03:17,940
.انتظري للحظة

45
00:03:19,910 --> 00:03:22,610
.طفل؟ أتساءل ما الّذي يفعله

46
00:03:31,720 --> 00:03:32,720
!انتبه

47
00:03:32,720 --> 00:03:33,660
.دع الأمر لي

48
00:03:45,640 --> 00:03:48,440
إنّه بخير الآن. يبدو أنّ أملاح
.الشّمّ أدّت مفعولها

49
00:03:49,910 --> 00:03:51,180
أ-أين أنا؟

50
00:03:51,180 --> 00:03:53,650
.أنت على سفينة قراصنة لوفي

51
00:03:53,880 --> 00:03:55,250
!قـ-قراصنة؟

52
00:03:55,410 --> 00:03:56,280
.نعم

53
00:03:56,280 --> 00:04:00,120
هل تتذكّر أيّ شيء؟
.وقعتَ من سفينة البحريّة

54
00:04:03,820 --> 00:04:07,190
!تـ-تراجعوا! تنوون مهاجمة البحريّة، صحيح؟

55
00:04:07,490 --> 00:04:09,830
!ما باله؟ هل نسي أنّنا أنقذنا حياته؟

56
00:04:09,830 --> 00:04:11,900
.لا يمكنك لومه. إنّه من البحريّة

57
00:04:13,770 --> 00:04:15,230
.كُل شيئًا أوّلاً

58
00:04:15,230 --> 00:04:17,870
!لا أريده! لا أحتاج لمساعدة قراصنة

59
00:04:19,240 --> 00:04:22,570
ترفض شرب حساء أعدّه طبّاخ
على سفينة قراصنة، صحيح؟

60
00:04:23,040 --> 00:04:24,840
.إنّه ليس مسمومًا أو ما شابه

61
00:04:25,480 --> 00:04:28,780
.سترتاح بمجرّد أن تملأ معدتك ببعض الطّعام

62
00:04:30,920 --> 00:04:32,580
!هذا الحساء مذهل

63
00:04:33,020 --> 00:04:35,450
!لا أصدّق مدى صفاء هذا الكونسومي

64
00:04:51,970 --> 00:04:53,240
.شكرًا على الطّعام

65
00:04:53,740 --> 00:04:55,340
.بالهناء والشّفاء

66
00:04:55,340 --> 00:04:58,440
.أنا تاجيو. أنا طبّاخ متدرّب في البحريّة

67
00:04:58,680 --> 00:04:59,950
.أنا سانجي

68
00:05:00,110 --> 00:05:02,650
أنت طبّاخ إذًا؟

69
00:05:03,080 --> 00:05:07,020
سانجي-سان، إنّك تضيّع وقتك بالطّبخ
!على متن سفينة قراصنة متهالكة كهذه

70
00:05:07,020 --> 00:05:08,350
!مهاراتك لا مثيل لها

71
00:05:08,550 --> 00:05:11,820
ماذا قلت؟! هذه السّفينة
!ليست متهالكة

72
00:05:11,820 --> 00:05:15,090
نعم! هذه السّفينة من قرية
—سيروب حيث كنت أعيش

73
00:05:15,090 --> 00:05:16,190
أهي حلوة؟

74
00:05:16,190 --> 00:05:18,500
.لا، اسمها يعني شراب فحسب
،كانت هنالك فتاة تُدعى كايا

75
00:05:18,500 --> 00:05:21,670
،أعطتنا هذه السّفينة
!لذلك فهي غالية علينا
...مهلاً، مهلاً، مهلاً، على رسلك

76
00:05:25,600 --> 00:05:27,310
...في الحقيقة، أنا

77
00:05:35,310 --> 00:05:37,680
سكبتُ الكاري الّذي كانوا
.سيتناولونه على الغذاء

78
00:05:38,650 --> 00:05:39,750
!أنا جدّ آسف

79
00:05:41,320 --> 00:05:42,620
.ستعدّه أنت

80
00:05:43,990 --> 00:05:45,620
أنت من سكبه، صحيح؟

81
00:05:45,620 --> 00:05:48,030
،لذلك إن كنت آسفًا فعلاً حيال ذلك

82
00:05:48,030 --> 00:05:52,200
فقم بإعداد الكاري ثانية
.ليقدّم وقت الغداء

83
00:05:53,130 --> 00:05:55,270
.كان الطّاهي على حقّ
.لا شكّ في ذلك

84
00:05:55,270 --> 00:05:56,440
.نعم

85
00:05:56,800 --> 00:05:59,940
،لذلك حاولتُ إعداده مرارًا وتكرارًا

86
00:05:59,940 --> 00:06:01,470
.لكنّ النّتيجة لا تكون جيّدة

87
00:06:01,710 --> 00:06:04,110
تاجيو-كُن، هل لديك أيّ خبرة في الطّبخ؟

88
00:06:04,110 --> 00:06:07,650
بدأت كطبّاخ متدرّب قبل
.ستّة أشهر فحسب

89
00:06:08,050 --> 00:06:10,120
.يجب أن تكون تلك مدّة كافية

90
00:06:10,550 --> 00:06:14,350
لا أستطيع! كلّ ما أفعله كلّ يوم
!هو غسل الأطباق وتقشير الخضروات

91
00:06:14,350 --> 00:06:16,890
!لم أقم بطبخ أيّ طعام فعليّ

92
00:06:17,960 --> 00:06:19,060
...والأسوأ من ذلك

93
00:06:20,490 --> 00:06:23,500
لدى كلّ قادة السّفن عادة

94
00:06:23,500 --> 00:06:27,030
بحيث يجتمعون مرّة كلّ أسبوع
.ويتناولون الكاري على الغداء

95
00:06:27,330 --> 00:06:30,970
.وسفينتنا هي من ستستضيفهم هذا الأسبوع

96
00:06:31,400 --> 00:06:36,070
كيف يُفترض للكاري الّذي أعدّه
أن يرتقي لأذواق كبار البحريّة؟

97
00:06:36,680 --> 00:06:38,740
.كاري البحريّة مشهور

98
00:06:38,740 --> 00:06:41,610
سمعتُ أنّ الطّهاة من كلّ السّفن
،يتنافسون مع بعضهم

99
00:06:41,610 --> 00:06:44,080
.ولكلّ واحد نكهته الخاصّة بسفينته

100
00:06:44,280 --> 00:06:46,490
فعلاً؟ يبدو ذلك لذيذًا، صحيح؟

101
00:06:46,820 --> 00:06:48,420
،بعد قضائك ستّة أشهر في المطبخ

102
00:06:48,420 --> 00:06:50,490
،إن لم تمتلك أيّ ثقة بنفسك

103
00:06:50,490 --> 00:06:53,430
.فعد واعتذر لطاهيك ثانية

104
00:06:54,290 --> 00:06:55,190
.مستحيل

105
00:06:56,190 --> 00:06:58,930
!إن أخبرتُه بذلك، سيطردني من السّفينة

106
00:06:59,360 --> 00:07:01,400
وهل يجب أن تكون على
تلك السّفينة بالتّحديد؟

107
00:07:01,400 --> 00:07:03,040
هل من سبب لذلك أو ما شابه؟

108
00:07:03,570 --> 00:07:04,470
...في الواقع

109
00:07:05,170 --> 00:07:05,940
...الأزرق

110
00:07:07,970 --> 00:07:09,510
!هل تعرفون بشأن الأزرق الكامل؟

111
00:07:13,310 --> 00:07:15,580
الأزرق الشّرقيّ والأزرق الغربيّ

112
00:07:15,580 --> 00:07:17,350
...والأزرق الجنوبيّ والأزرق الشّماليّ

113
00:07:17,780 --> 00:07:21,090
إنّه حيث تجتمع كلّ مأكولات
.هذه البحار الأربعة اللّذيذة

114
00:07:21,990 --> 00:07:25,560
وبصفتي طبّاخًا، فإنّه بحر من الكنوز
.أودّ زيارته يومًا ما

115
00:07:26,360 --> 00:07:29,960
،يسخر الطّبّاخون الكبار من حلمي هذا

116
00:07:30,230 --> 00:07:31,860
!لكنّي أؤمن بوجوده

117
00:07:32,300 --> 00:07:34,430
!واثق أنّ الأزرق الكامل موجود

118
00:07:34,970 --> 00:07:38,870
،إن كنتُ على متن سفينة حربيّة للبحريّة
فستزداد فرصي بالذّهاب إليه، صحيح؟

119
00:07:39,000 --> 00:07:42,240
لذلك... لذلك لا أستطيع
!ترك هذه السّفينة

120
00:07:42,710 --> 00:07:45,040
الأزرق الكامل؟ أليس ذاك...؟

121
00:07:50,750 --> 00:07:53,320
كم أودّ مغادرة هذا المكان
...بأسرع ما يمكننا

122
00:07:53,320 --> 00:07:57,620
،صحيح، إن اكتشفوا وجودنا
...فسيطلقون وابل هجمات علينا

123
00:07:58,290 --> 00:08:00,460
،لكن ونظرًا للظّروف الرّاهنة

124
00:08:00,460 --> 00:08:02,960
،علينا إعادة هذا الفتى لسفينته
صحيح يا سانجي-كُن؟

125
00:08:05,600 --> 00:08:07,800
،سأعيده إلى سفينته فحسب
.لا أكثر ولا أقلّ

126
00:08:08,330 --> 00:08:10,400
.لوفي، ساعدنا للصّعود

127
00:08:12,200 --> 00:08:15,840
!فاكهة المطّاط: الحبل الرّابط

128
00:08:17,480 --> 00:08:19,340
.يا سانجي، أنا أمسك بالسّفينة الآن

129
00:08:19,680 --> 00:08:22,280
،بمجرّد حلول وقت الظّهيرة
.سينقشع هذا الضّباب

130
00:08:22,580 --> 00:08:25,420
.وإن تأخّرنا أكثر، فسنكون في خطر كبير

131
00:08:25,780 --> 00:08:26,920
.تلك مدّة كافية

132
00:08:27,950 --> 00:08:29,620
إلى أيّ حدّ تنوي مساعدته؟

133
00:08:29,920 --> 00:08:32,120
سألقي نظرة على الوضع بنفسي فحسب

134
00:08:32,120 --> 00:08:33,830
.لأرى كيف يبدو مطبخ سفينة تابعة للبحريّة

135
00:08:34,030 --> 00:08:35,160
!سانجي

136
00:08:36,530 --> 00:08:39,500
!حسنًا، تمسّكا جيّدًا

137
00:08:48,770 --> 00:08:51,340
بالمناسبة، لماذا أتيت معنا أيضًا؟

138
00:08:51,340 --> 00:08:53,110
وكيف كنتَ لتعود بدوني؟

139
00:08:53,450 --> 00:08:55,480
،إذًا انتظر هنا فحسب
.وأحسن التّصرّف

140
00:08:55,480 --> 00:08:56,350
.أ-أكيد

141
00:08:59,580 --> 00:09:00,190
مطبخ الأسطول الثّامن عشر

142
00:09:00,190 --> 00:09:01,520
.هذا هو المطبخ

143
00:09:02,020 --> 00:09:05,760
،نعم. أظنّني سألقي نظرة عليه
.بما أنّني هنا

144
00:09:12,900 --> 00:09:15,700
.هذا متوقّع من البحريّة
.هذه الأغراض غالية الثّمن

145
00:09:16,440 --> 00:09:18,600
.والأكثر من ذلك، جميعها في حالة جيّدة

146
00:09:20,470 --> 00:09:21,340
ما هذا؟

147
00:09:21,340 --> 00:09:22,810
.إنّه صادر من مخزن طعام السّفينة

148
00:09:26,610 --> 00:09:27,750
...أفزعني ذلك

149
00:09:28,310 --> 00:09:30,220
!لوفي! ما الّذي تفعله هنا؟

150
00:09:30,650 --> 00:09:33,150
!سانجي! أستطلع! أقوم بالاستطلاع

151
00:09:33,420 --> 00:09:35,850
.لا يحصل المرء على فرصة كهذه كلّ يوم

152
00:09:38,720 --> 00:09:41,260
.لذلك، سأقوم بالمزيد من الاستطلاع فحسب

153
00:09:41,260 --> 00:09:42,790
،افعل ما يحلو لك

154
00:09:42,790 --> 00:09:45,330
،لكن إن وجدتك البحريّة
.فلن يتساهلوا معك

155
00:09:45,330 --> 00:09:46,060
...وأيضًا

156
00:09:46,830 --> 00:09:48,870
.اترك ما حشوت به جيوبك هنا

157
00:09:49,800 --> 00:09:50,970
إنّه تفّاح، صحيح؟

158
00:09:54,770 --> 00:09:56,810
.هذا هو كاري البحريّة

159
00:10:03,250 --> 00:10:05,520
...عندما كنتُ في المطعم البحريّ

160
00:10:07,290 --> 00:10:10,390
.لم يُعلّمني المالك زيف أيّ شيء

161
00:10:14,190 --> 00:10:18,260
يومًا بعد آخر، كلّ ما جعلني
.أفعله هو غسل الأطباق

162
00:10:21,370 --> 00:10:22,670
!أيّها الشّقيّ

163
00:10:23,400 --> 00:10:26,870
.عليك فعل ما هو أكثر من بذل جهدك

164
00:10:27,270 --> 00:10:29,610
لِمَ تظنّ أنّني أسمح لك
بالتّواجد في مطبخي

165
00:10:29,610 --> 00:10:32,710
وأطلب منك القيام بأعمال روتينيّة
!لنصف سنة أو سنة تقريبًا؟

166
00:10:32,710 --> 00:10:34,550
!فاستعمل رأسك ذاك وفكّر مليًّا

167
00:10:40,650 --> 00:10:44,090
،ذلك ما أخبرني به زيف
.بينما كان عدم الرّضا باديًا عليّ

168
00:10:44,690 --> 00:10:49,530
فهمت. سمح لي الطّاهي بالتّواجد
.هنا لأتعلّم مهاراته في الطّبخ

169
00:10:50,900 --> 00:10:53,200
.الطّبخ ليس أمرًا يمكن تعليمه ببساطة

170
00:10:58,800 --> 00:11:01,210
!سانجي-سان، سوف أجرّب بنفسي

171
00:11:04,240 --> 00:11:08,250
لنرَ... ما الّذي كان يقوله الطّاهي؟

172
00:11:09,380 --> 00:11:12,880
الوصفة الأساسيّة للكاري هي
.المسحوق والحساء والمكوّنات

173
00:11:13,390 --> 00:11:15,920
!يمزج مسحوق الكاري خاصّته بعناية

174
00:11:18,160 --> 00:11:19,760
...يا لها من رائحة

175
00:11:20,560 --> 00:11:22,230
،يأخذون مسحوق كاري معدّ سلفًا

176
00:11:22,230 --> 00:11:25,230
.ويضيفون له بعض الغارام ماسالا الطّازج

177
00:11:31,770 --> 00:11:35,340
لا تكن كسولاً لدرجة أن تستعمل
!المسحوق المعدّ سلفًا فحسب

178
00:11:36,540 --> 00:11:39,380
!إنّ نكهة التّوابل تتناقص يومًا بعد يوم

179
00:11:40,910 --> 00:11:42,410
!إنّه الغارام ماسالا

180
00:11:50,890 --> 00:11:53,130
.حاسّة شمّه جيّدة

181
00:12:19,180 --> 00:12:21,020
!إنّها ضخمة

182
00:12:21,450 --> 00:12:22,790
...في هذا الضّباب

183
00:12:23,220 --> 00:12:24,890
.لن نتحرّك لوقت طويل

184
00:12:26,390 --> 00:12:28,530
.على الأرجح أنّه سينقشع عند الظّهيرة

185
00:12:28,960 --> 00:12:31,360
بالمناسبة، هل سمعت
عن اجتماع الغداء المعتاد؟

186
00:12:32,030 --> 00:12:35,330
نعم، وعن أنّ الطّبّاخ المتدرّب
تاجيو هو من يعدّه؟

187
00:12:35,330 --> 00:12:38,100
.أتساءل ما الّذي سيطعمه لنا بالتّحديد

188
00:12:38,240 --> 00:12:39,340
!لا شكّ في ذلك

189
00:12:43,110 --> 00:12:44,110
،بالنّسبة للمرق

190
00:12:44,110 --> 00:12:47,010
بإمكاني استعمال أشياء جاهزة
.سلفًا تمّ غليها بشكل مكثّف

191
00:12:48,550 --> 00:12:50,450
.والآن، حان وقت تجهيز المكوّنات

192
00:12:52,780 --> 00:12:55,650
.أوّلاً، عليّ تقطيع لحم البقر وأقليه

193
00:13:06,670 --> 00:13:10,500
ثمّة نوع من كاري لحم
البقر حيث نجد عصارته

194
00:13:10,500 --> 00:13:13,110
.مخزّنة في لحم البقر نفسه

195
00:13:13,770 --> 00:13:16,110
لكنّ استنادًا على نكهة
،الكاري الخفيفة هذه

196
00:13:16,110 --> 00:13:18,410
فإنّه ليس من النّوع الّذي يُبقي
،جوهر اللّحم بداخله

197
00:13:18,410 --> 00:13:21,010
.بل يسمح له بالذّوبان خارجًا في الحساء

198
00:13:21,880 --> 00:13:26,990
.في تلك الحالة، فإنّ الفتى أخطأ من البداية

199
00:13:29,860 --> 00:13:30,760
هل من خطب ما؟

200
00:13:34,760 --> 00:13:38,630
يا فتى، الطّبخ ليس شيئًا
.عليك القيام به بعجالة

201
00:13:40,070 --> 00:13:43,800
تذكّروا، يعتمد كلّ شيء
.في الطّبخ على التّحضيرات

202
00:13:44,370 --> 00:13:47,840
.التّأنّي ضروريّ. هذا كلّ شيء

203
00:13:56,350 --> 00:13:57,480
...سأضيف الثّوم

204
00:13:59,250 --> 00:14:00,250
...والزّنجبيل

205
00:14:02,220 --> 00:14:03,660
،والكركم

206
00:14:04,520 --> 00:14:06,560
.ثمّ بعض الزّبادي

207
00:14:41,960 --> 00:14:43,760
.بهذا أكون اهتممتُ بالتّحضيرات

208
00:14:45,500 --> 00:14:47,330
.والآن، عليّ قلي البصل

209
00:15:05,480 --> 00:15:07,450
!كيف تدخّن في مكان أعدُّ فيه الطّعام؟

210
00:15:07,890 --> 00:15:09,760
!هل تعتقد أنّ ذلك مقبول كطبّاخ؟

211
00:15:10,120 --> 00:15:12,920
قلتُ سابقًا أنّك أفضل بكثير
،من أن تطبخ على سفينة قراصنة

212
00:15:13,630 --> 00:15:14,730
!لكنّني أسحب كلامي

213
00:15:15,160 --> 00:15:18,700
.يا ويحي، لقد حرقت شعري

214
00:15:27,740 --> 00:15:30,980
تذكّروا أن تقلوا البصل
.بشكل وجيز على نار قويّة

215
00:15:31,480 --> 00:15:33,450
.واصلوا تحريكه، لكي لا يحترق

216
00:15:33,950 --> 00:15:36,280
،بمجرّد أن يصبح البصل ناعمًا
.قلّلوا من النّار تحته

217
00:15:36,750 --> 00:15:39,750
قوموا بذلك ببطء ولطف
،بينما يُطهى فوق نار خفيفة

218
00:15:39,750 --> 00:15:41,550
.إلى أن يكتسب لونًا ذهبيًّا بنّيًّا

219
00:15:41,550 --> 00:15:42,850
أفهمتم؟

220
00:15:44,660 --> 00:15:48,460
كان سانجي-سان يحذّرني
...بشأن مستوى النّار

221
00:16:04,580 --> 00:16:06,980
.كم هذا مرتفع

222
00:16:07,210 --> 00:16:09,950
.المنظر من هنا مختلف تمامًا

223
00:16:13,320 --> 00:16:14,490
!مـ-من أنت؟

224
00:16:14,490 --> 00:16:16,320
!كُشف أمري

225
00:16:16,560 --> 00:16:17,590
!تمهّل

226
00:16:17,590 --> 00:16:19,260
!لن أتمهّل أبدًا

227
00:16:22,630 --> 00:16:24,360
...سأذيب بعض شحم الخنزير

228
00:16:25,730 --> 00:16:27,330
...وأضيف الدّقيق

229
00:16:29,300 --> 00:16:32,170
...وأحرّك بلطف حتّى لا يحترق

230
00:16:37,410 --> 00:16:38,840
...ثمّ سأضيف مسحوق الكاري

231
00:16:39,910 --> 00:16:42,780
إضافة إلى غارام ماسالا لتعزيز النّكهة

232
00:16:48,390 --> 00:16:51,220
...ثمّ ولجمع كلّ المكوّنات معًا

233
00:16:54,590 --> 00:16:55,990
...سأضيف المرق

234
00:16:58,430 --> 00:16:59,330
...ثمّ الطّماطم

235
00:17:05,270 --> 00:17:06,770
...والبصل أيضًا

236
00:17:11,480 --> 00:17:13,180
.وسأضيف اللّحم المتبّل

237
00:17:36,470 --> 00:17:37,840
...ثمّة خطب ما

238
00:17:39,270 --> 00:17:40,470
.لا قوام له

239
00:17:44,410 --> 00:17:47,080
.واضح تمامًا أنّني عاجز

240
00:17:54,190 --> 00:17:55,450
!...نكهات خفيّة

241
00:17:56,620 --> 00:17:57,720
!سانجي-سان

242
00:18:04,030 --> 00:18:05,300
...يا لحلاوة

243
00:18:07,030 --> 00:18:08,170
.هذه التّفّاحة

244
00:18:10,200 --> 00:18:11,140
...سانجي-سان

245
00:18:12,900 --> 00:18:14,270
.شكرًا جزيلاً لك

246
00:18:14,270 --> 00:18:15,540
علام تشكرني؟

247
00:18:16,780 --> 00:18:20,110
.لم أفعل أيّ شيء يتطلّب الشّكر

248
00:18:20,610 --> 00:18:23,480
سانجي-سان، تظاهرت بمجيئك
،لتفقّد السّفينة فحسب

249
00:18:23,480 --> 00:18:25,620
.لكنّك كنت تحاول تعليمي

250
00:18:25,780 --> 00:18:27,120
.لا تسئ الفهم

251
00:18:27,120 --> 00:18:29,620
!هناك! لقد هرب إلى هناك

252
00:18:30,590 --> 00:18:33,290
!سانجي! لنذهب

253
00:18:33,560 --> 00:18:34,960
...ذلك الغبيّ

254
00:18:35,590 --> 00:18:36,730
!تمهّل

255
00:18:37,530 --> 00:18:39,160
...فاكهة المطّاط

256
00:18:39,400 --> 00:18:40,900
!الحبل الرّابط

257
00:18:42,930 --> 00:18:43,740
!حسنًا

258
00:18:43,940 --> 00:18:45,140
!تمسّك

259
00:18:47,510 --> 00:18:48,470
...تاجيو

260
00:18:49,270 --> 00:18:50,910
.أعتقد أنّه موجود أيضًا

261
00:18:51,980 --> 00:18:53,480
.الأزرق الكامل

262
00:18:54,650 --> 00:18:56,010
!سانجي! تمسّك

263
00:18:56,010 --> 00:18:56,780
!حالاً

264
00:19:07,260 --> 00:19:10,400
يا تاجيو، كان هنالك رجل
مريب هنا للتّوّ، صحيح؟

265
00:19:10,400 --> 00:19:11,400
إلى أين ذهب؟

266
00:19:11,400 --> 00:19:13,330
.ماذا؟ لا أدري

267
00:19:13,330 --> 00:19:15,100
أواثق أنّك لا تتخيّل الأمر فحسب؟

268
00:19:15,370 --> 00:19:18,070
واصلوا البحث! لا بدّ أنّه يختبئ
!في مكان ما على السّفينة

269
00:19:18,600 --> 00:19:19,910
!جدوه

270
00:19:26,240 --> 00:19:27,380
!...أيّها الـ

271
00:19:27,380 --> 00:19:29,750
هل تحمل ضغينة ما ضدّي؟

272
00:19:30,120 --> 00:19:31,050
.آسف

273
00:19:31,480 --> 00:19:34,090
!كلاّ، لا يبدو الأسف على وجهك

274
00:19:34,090 --> 00:19:35,150
.لذلك السّبب أنا آسف

275
00:19:35,420 --> 00:19:36,990
!...سأقطّعك لشرائح

276
00:19:38,690 --> 00:19:39,960
ما الخطب يا لوفي؟

277
00:19:40,690 --> 00:19:43,630
!لقد ألحقت ضررًا بغوينغ ميري ثانية

278
00:19:43,960 --> 00:19:46,230
!أوسوبّ، نامي، آسف

279
00:19:46,230 --> 00:19:49,400
كشفت البحريّة أمري، لذلك
.كان علينا المجيء بسرعة

280
00:19:49,770 --> 00:19:52,800
!ماذا؟! مـ-مهلاً، ما الّذي تقصده بذلك؟

281
00:19:52,800 --> 00:19:56,270
!إنّها سفينة غالية أهدتها لنا كايا

282
00:19:56,270 --> 00:19:58,580
!كم مرّة عليّ إخبارك بذلك؟

283
00:19:58,580 --> 00:19:59,680
!لا يمكننا البقاء هنا طويلاً

284
00:19:59,680 --> 00:20:01,850
،أوسوبّ، سانجي-كُن
!سنغادر في الحال

285
00:20:01,850 --> 00:20:03,350
!حالاً يا نامي-سان

286
00:20:03,350 --> 00:20:05,620
...كلاّ، لا يمكنني التّحرّك

287
00:20:21,000 --> 00:20:21,930
.قدّمه

288
00:20:22,230 --> 00:20:23,040
!حاضر

289
00:20:38,050 --> 00:20:40,350
.استمتعوا بوجبتكم رجاءً

290
00:20:52,460 --> 00:20:54,730
.هذا لذيذ

291
00:20:54,730 --> 00:20:56,440
إنّه كثيف بما يكفي والنّكهة الحارّة

292
00:20:56,440 --> 00:20:57,940
.تنتشر عبر فمي كلّه

293
00:20:57,940 --> 00:21:00,340
...اللّحم ناعم جدًّا

294
00:21:00,340 --> 00:21:02,270
!أريد المزيد في الحال

295
00:21:03,580 --> 00:21:04,540
...تاجيو

296
00:21:04,540 --> 00:21:05,710
!نعم أيّها الطّاهي

297
00:21:06,110 --> 00:21:08,810
.احرص على التّنظيف

298
00:21:09,680 --> 00:21:11,250
!حا-حاضر

299
00:21:23,230 --> 00:21:24,300
...سانجي-سان

300
00:21:27,870 --> 00:21:31,000
.أعتقد أنّه موجود أيضًا... الأزرق الكامل

301
00:21:42,110 --> 00:21:43,780
،سأعمل بجدّ أكبر

302
00:21:44,450 --> 00:21:48,020
ويومًا ما، سأصبح طبّاخًا جيّدًا
.مثلك يا سانجي-سان

303
00:21:54,560 --> 00:22:02,730
آه، خلف السّماء الّتي لا نهاية لها

304
00:22:02,730 --> 00:22:13,350
المستقبل الّذي رأيتُه مرّة أخذ يصبح واقعًا

305
00:22:21,220 --> 00:22:28,660
مرّت عليّ أيّام كدت أخسر فيها نفسي

306
00:22:28,660 --> 00:22:37,070
وعندما حدث ذلك، كان هنالك مكان
دافئ أستطيع أن أقصُده

307
00:22:37,070 --> 00:22:45,280
الأصدقاء الّذين افتخرتُ بهم
دائمًا وبلا أدنى شكّ

308
00:22:45,280 --> 00:22:54,120
دفعوا بي للأمام، أليس كذلك؟

309
00:22:54,120 --> 00:23:02,460
آه، إنّ النّجوم تهوي من السّماء

310
00:23:02,460 --> 00:23:05,560
...وهذه اللّحظة الفريدة

311
00:23:13,070 --> 00:23:16,440
إنّ الألعاب النّاريّة رائعة، صحيح؟
!إنّها جميلة جدًّا

312
00:23:16,440 --> 00:23:19,710
.كم أريد إطلاق بعض منها
ماذا؟ ستسمح لي بذلك؟

313
00:23:19,710 --> 00:23:23,620
،أنا جدّ سعيد! والأكثر من ذلك
!ستسمح لي بإطلاق الكبيرة؟

314
00:23:23,620 --> 00:23:26,220
مذهل! ولكن، أليست هذه كبيرة جدًّا؟

315
00:23:26,550 --> 00:23:27,920
:في الحلقة القادمة من وان بيس

316
00:23:27,920 --> 00:23:31,290
سأجعلها تتفتّح! الرّجل أوسوبّ"
".وكرة الثّمانية شاكو

317
00:23:31,290 --> 00:23:31,590
!ملك القراصنة، لن يكون إلاّ أنا

318
00:23:31,590 --> 00:23:35,530
!سأجعلها تتفتّح
الرّجل أوسوبّ وكرة الثّمانية شاكو