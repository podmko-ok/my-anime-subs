1
00:00:14,060 --> 00:00:15,590
...إرادة موروثة

2
00:00:15,590 --> 00:00:17,830
...تعاقب الأزمنة... أحلام النّاس

3
00:00:18,500 --> 00:00:21,330
.لا رادع لهذه الأشياء

4
00:00:21,330 --> 00:00:24,430
ما دام النّاس يسعون باحثين
،عن جواب للحرّيّة

5
00:00:24,430 --> 00:00:27,070
!فلن تختفي هذه الأشياء عن الوجود

6
00:00:35,680 --> 00:00:42,050
لا أؤمن سوى بالمستقبل... ولا أهتمّ لضحك أيِّ كان

7
00:00:42,050 --> 00:00:47,560
يجعل ذلك الشّغفُ المتسارعُ المرءَ يتألّق

8
00:00:47,560 --> 00:00:53,560
إنّه شديد السّطوع، لكنّني أريد التّحديق به

9
00:00:53,560 --> 00:00:57,070
أشعر بـ"الجمال" في كلّ مكان

10
00:00:57,070 --> 00:01:00,370
أنا متمسّك بكم بشدّة بالفعل

11
00:01:00,370 --> 00:01:07,010
أنا أتبع وأتبع خطوات حلم
لا يشبه أيّ أحد

12
00:01:07,010 --> 00:01:10,310
إلى أن أحصل عليه بكلّ إثارة

13
00:01:10,310 --> 00:01:17,320
!آمنوا ببلاد العجائب

14
00:01:19,220 --> 00:01:25,430
سأمسك وأمسك بشكل حلم
لا يستطيع أحد رؤيته

15
00:01:25,430 --> 00:01:31,430
سوف أرافقك أيّتها المشاعر الشّغوفة

16
00:01:31,430 --> 00:01:34,540
لا أحتاج فعلاً ليكون كلّ شيء في مكانه

17
00:01:34,540 --> 00:01:37,870
،بل أريدها حياة عاديّة لا غير

18
00:01:37,870 --> 00:01:41,110
فاركضوا نحو النّعيم بدل ذلك

19
00:01:41,310 --> 00:01:51,050
!آمنوا ببلاد العجائب

20
00:01:56,120 --> 00:01:59,830
بلدة ترحّب بالقراصنة؟
الوصول إلى ويسكي بيك

21
00:01:59,830 --> 00:02:04,030
بلدة ترحّب بالقراصنة؟"
".الوصول إلى ويسكي بيك

22
00:02:19,080 --> 00:02:21,480
ما قصّة هذا الثّلج؟

23
00:02:21,480 --> 00:02:24,050
.كان الجوّ ساخنًا قبل مدّة قصيرة

24
00:02:26,620 --> 00:02:28,220
!حسنًا! انتهيت

25
00:02:28,720 --> 00:02:31,960
هذا هو الرّجل الّذي سقط
!من السّماء، السّيد برميل الثّلج

26
00:02:33,490 --> 00:02:36,360
...يا له من رجل ثلج بشع

27
00:02:36,360 --> 00:02:37,000
!ماذا؟

28
00:02:37,960 --> 00:02:42,200
انظر لعمليّ الفنّيّ المليء
!بالرّوح، ملكة الثّلج

29
00:02:42,470 --> 00:02:44,200
!مذهل! ذلك رائع

30
00:02:44,200 --> 00:02:46,170
!حسنًا! لكمة برميل الثّلج

31
00:02:51,540 --> 00:02:53,780
!ما الّذي تفعله؟

32
00:02:54,410 --> 00:02:55,810
!السّيّد برميل الثّلج

33
00:02:55,810 --> 00:02:56,950
!كيف تجرؤ؟

34
00:02:57,280 --> 00:02:58,880
!سُحقًا لك! سُحقًا لك! سُحقًا لك

35
00:02:59,080 --> 00:03:01,190
!ما رأيك في هذه؟

36
00:03:01,190 --> 00:03:03,390
!أيّها الوغد! تمهّل يا لوفي

37
00:03:05,490 --> 00:03:09,190
لماذا هما مفعمان بالحيويّة
في هذا الجوّ البارد؟

38
00:03:13,600 --> 00:03:16,500
نامي-سان! كم من تجريف
ثلج الحبّ تريدين منّي أن أفعل؟

39
00:03:16,500 --> 00:03:19,100
واصل حتّى تتوقّف الثّلوج
!يا سانجي-كُن

40
00:03:19,100 --> 00:03:20,840
!حاضر يا نامي-سان

41
00:03:21,240 --> 00:03:25,180
أنتِ. ألا يوجد سخّان في هذه السّفينة؟

42
00:03:25,180 --> 00:03:26,680
.أشعر بالبرد

43
00:03:26,680 --> 00:03:31,150
!اخرسا! أنتما لستما ضيفين
!اخرجا لتجرفا الثّلج أو ما شابه

44
00:03:33,920 --> 00:03:34,920
!برق؟

45
00:03:35,890 --> 00:03:38,890
!ما الّذي يحدث مع هذا الطّقس هنا؟

46
00:03:43,260 --> 00:03:45,330
.كان الجوّ صحوًا قبل مدّة قصيرة

47
00:03:45,330 --> 00:03:48,460
...ثمّ بدأت السّماء تُثلج والآن تُبرق

48
00:03:48,460 --> 00:03:51,370
إنّ المواسم وكذلك الطّقس
.تحدث بشكل عشوائيّ

49
00:03:51,370 --> 00:03:53,340
.تمامًا كما قال كروكس-سان

50
00:03:53,600 --> 00:03:56,310
.هكذا هو الحال في الغراند لاين

51
00:03:56,310 --> 00:03:58,810
.يبدو أنّك جاهلة بأحوال الغراند لاين

52
00:03:59,510 --> 00:04:02,680
لم تقومي بوجيه السّفينة لمدّة طويلة
الآن. ألا بأس بذلك بالفعل؟

53
00:04:04,080 --> 00:04:06,250
.تحقّقتُ للتّوّ من الاتّجاه

54
00:04:10,150 --> 00:04:10,990
ماذا هناك؟

55
00:04:10,990 --> 00:04:12,090
ما الخطب؟

56
00:04:12,090 --> 00:04:13,920
!هل من خطب ما يا نامي-سان؟

57
00:04:15,190 --> 00:04:16,230
!مستحيل

58
00:04:16,590 --> 00:04:19,290
!أديروا السّفينة 180 درجة! بسرعة

59
00:04:19,290 --> 00:04:22,260
‫180 درجة؟! لماذا سنعود أدراجنا؟!

60
00:04:22,260 --> 00:04:23,430
هل نسينا شيئًا ما؟

61
00:04:23,770 --> 00:04:26,940
استدارت السّفينة وهي تسير
!الآن في الاتّجاه المعاكس

62
00:04:26,940 --> 00:04:29,740
عندما أبعدتُ نظري عن البوصلة
...المسجِّلة للحظة

63
00:04:30,370 --> 00:04:32,070
...كانت الأمواج هادئة قبل قليل

64
00:04:32,410 --> 00:04:35,210
هل أنت ملاّحة بالفعل؟

65
00:04:36,080 --> 00:04:41,880
لا يمكن الوثوق بالرّياح والسّماء والأمواج
...والغيوم أو أيّ شيء في هذا البحر

66
00:04:41,880 --> 00:04:46,120
الشّيء الوحيد الّذي لا يتغيّر هو الاتّجاه
.الّذي تشير إليه البوصلة المسجِّلة

67
00:04:46,120 --> 00:04:47,690
هل تفهمين ذلك؟

68
00:04:49,020 --> 00:04:52,660
كفاكما من أمرًا ونهيًا عليّ والبطّانيّات
!تلفّكما واخرجا للمساعدة

69
00:04:53,230 --> 00:04:54,560
!شدّوا عمود الشّراع

70
00:04:54,560 --> 00:04:57,970
!واجهوا الرّياح من الميمنة
!أديروا السّفينة 180 درجة يسارًا

71
00:04:57,970 --> 00:04:59,070
!أوسوبّ! تولّ الشّراع المثلّث

72
00:04:59,070 --> 00:04:59,400
!حاضر

73
00:04:59,400 --> 00:05:00,500
!سانجي-كُن! تولّ المقود

74
00:05:00,500 --> 00:05:01,370
!أنا لها يا نامي-سان

75
00:05:01,670 --> 00:05:03,140
!أنتما! أعتمد عليكما

76
00:05:03,140 --> 00:05:05,340
.إنّها تشغّلنا كالعبيد

77
00:05:05,870 --> 00:05:08,110
.مهلاً! تغيّرت الرّياح

78
00:05:08,110 --> 00:05:09,080
!مستحيل

79
00:05:12,980 --> 00:05:14,380
!إنّها أولى نفحات الرّبيع

80
00:05:14,380 --> 00:05:15,150
لماذا؟

81
00:05:15,480 --> 00:05:18,390
!لا تنم فحسب والثّلوج تتراكم عليك

82
00:05:20,720 --> 00:05:23,990
!يا رفاق! رأيتُ دلفينًا يقفز هناك
.لنذهب إليه

83
00:05:23,990 --> 00:05:25,460
!أنت اخرس

84
00:05:29,700 --> 00:05:31,500
!إنّ الأمواج ترتفع

85
00:05:31,500 --> 00:05:33,230
أرى جبلاً جليديًّا في اتّجاه
!السّاعة العاشرة

86
00:05:33,600 --> 00:05:35,070
!نامي-سان! الضّباب ينتشر

87
00:05:35,070 --> 00:05:37,340
!ما خطب هذا البحر؟

88
00:05:37,670 --> 00:05:40,910
!ما-ما... سنصطدم به

89
00:05:57,220 --> 00:05:59,320
اسمعي! ثمّة مياه تتسرّب
!من أسفل السّفينة

90
00:05:59,320 --> 00:06:00,460
!علينا ترقيع التّسرّب حالاً

91
00:06:00,460 --> 00:06:01,090
!أنا لها

92
00:06:05,230 --> 00:06:06,770
!تتحرّك السّحب بسرعة

93
00:06:11,600 --> 00:06:12,840
!ثمّة رياح قادمة

94
00:06:13,940 --> 00:06:14,510
!إنّها قويّة

95
00:06:15,240 --> 00:06:16,140
!إنّها قادمة

96
00:06:18,180 --> 00:06:20,550
!لفّوا الأشرعة! الرّياح قويّة جدًّا

97
00:06:20,550 --> 00:06:22,550
!سوف ننقلب إن واجهناها مباشرة

98
00:06:23,080 --> 00:06:25,680
!يا رفاق! وقت الطّعام
!لنستجمع قوّتنا

99
00:06:28,490 --> 00:06:30,120
!أنت تأكل الكثير

100
00:06:33,290 --> 00:06:35,430
!مصيبة! سيتمزّق الشّراع

101
00:06:35,430 --> 00:06:37,630
.انس بشأن الأمور هنا
!أصلح أسفل السّفينة

102
00:06:37,630 --> 00:06:39,360
!تضرّر جزء آخر من أسفل السّفينة

103
00:06:39,360 --> 00:06:40,530
!سُحقًا

104
00:07:06,590 --> 00:07:08,760
.كان ذلك جيّدًا

105
00:07:18,100 --> 00:07:22,540
،لا يهمّ كم أنّ الجوّ صحو
.لا يجب عليكم أن تتكاسلوا

106
00:07:23,540 --> 00:07:25,540
.من الأفضل أن نكون في الطّريق الصّحيح

107
00:07:25,910 --> 00:07:28,180
...يا لك من

108
00:07:29,780 --> 00:07:31,580
لماذا أنتما على متن هذه السّفينة؟

109
00:07:31,580 --> 00:07:32,750
!فهمك بطيء

110
00:07:33,580 --> 00:07:37,650
.نحن في طريقنا إلى بلدتهما الآن
.إنّها تدعى ويسكي بيك

111
00:07:37,650 --> 00:07:41,520
تقصد أنّنا سنعيدهما لبلدتهما؟
.لا تدين لهما بأيّ شيء

112
00:07:41,520 --> 00:07:43,120
.نعم، معك حقّ

113
00:07:43,830 --> 00:07:45,490
...حسنًا، ذلك لا يهمّني

114
00:07:46,330 --> 00:07:49,460
نعم، نعم، واضح من وجهيكما
.أنّكما لا تنويان على خير

115
00:07:49,830 --> 00:07:51,730
ما كانت أسماؤكما؟

116
00:07:52,570 --> 00:07:55,100
.أ-أنا سيّد 9

117
00:07:55,570 --> 00:07:57,440
.وأنا آنسة وينزداي

118
00:07:57,810 --> 00:08:03,010
صحيح... هنالك شيء ما يزعجني
...مذ أن سمعتُ باسميكما

119
00:08:03,540 --> 00:08:07,250
أشعر وكأنّني سمعتها من قبل
...أو ما شابه

120
00:08:08,480 --> 00:08:10,150
...حسنًا، في كلّ الأحوال

121
00:08:13,020 --> 00:08:17,160
كيف تجرؤ على النّوم بكلّ
راحة طوال هذا الوقت...؟

122
00:08:17,160 --> 00:08:20,260
...تواصل النّوم مهما حاولنا إيقاظك

123
00:08:20,260 --> 00:08:21,500
!ماذا؟

124
00:08:26,600 --> 00:08:30,570
!لا ترخوا دفاعاتكم يا رفاق
.لا ندري ما قد يحدث ثانية

125
00:08:30,940 --> 00:08:33,410
تمكّنت أخيرًا من إدراك
.خطر هذا البحر للتّوّ

126
00:08:33,840 --> 00:08:36,380
.تمكّنت من إدراك سبب تسميته بالغراند لاين

127
00:08:37,740 --> 00:08:42,620
لا شكّ في الأمر، بما أنّ مهاراتي
.الملاحيّة لا تفيد على الإطلاق

128
00:08:43,420 --> 00:08:46,920
يا للصّراحة... هل سنكون بخير؟

129
00:08:47,850 --> 00:08:50,860
.سنكون بخير! سننجح في رحلتنا بكلّ تأكيد

130
00:08:51,290 --> 00:08:52,960
...في الحقيقة

131
00:08:52,960 --> 00:08:56,430
.انظروا! انتهت رحلتنا الأولى

132
00:09:09,040 --> 00:09:10,510
!إنّها جزيرة

133
00:09:12,710 --> 00:09:14,550
...تلك هي ويسكي بيك

134
00:09:15,650 --> 00:09:18,550
.لكنّها جزيرة غريبة المظهر بالفعل

135
00:09:18,550 --> 00:09:20,820
!أشجار الصّبّار تلك ضخمة

136
00:09:24,920 --> 00:09:26,960
.سنغادر الآن

137
00:09:26,960 --> 00:09:29,260
.شكرًا لإيصالنا لموطننا يا أعزّائي

138
00:09:29,260 --> 00:09:30,900
!سنلتقي ثانية إن كان القدر سيجمعنا

139
00:09:31,830 --> 00:09:33,360
!مع السّلامة يا أعزّائي

140
00:09:39,940 --> 00:09:41,340
...لقد ذهبا

141
00:09:41,340 --> 00:09:43,640
من كانا من الأساس؟

142
00:09:43,640 --> 00:09:45,780
!من يهتمّ؟ سوف نُرسي

143
00:09:46,810 --> 00:09:50,580
ثمّة نهر أمامنا. يبدو أنّ بإمكاننا
.الإبحار فيه بالسّفينة

144
00:09:53,120 --> 00:09:56,620
هـ-هل ممكن أنّ هنالك
وحوشًا أو ما شابه؟

145
00:09:57,050 --> 00:10:00,690
.ذلك احتمال وارد بالتّأكيد
.نحن في الغراند لاين

146
00:10:00,690 --> 00:10:03,660
سنغادر الجزيرة ببساطة
.إن قابلنا وحوشًا

147
00:10:04,290 --> 00:10:05,700
.مهلاً لحظة

148
00:10:05,700 --> 00:10:10,630
لا تنس أنّ علينا البقاء على
.هذه الجزيرة لمدّة معيّنة

149
00:10:11,330 --> 00:10:12,340
لماذا؟

150
00:10:13,000 --> 00:10:16,340
ما لم نسجّل مجال هذه الجزيرة
،المغناطيسيّ في البوصلة المسجِّلة

151
00:10:16,340 --> 00:10:18,710
.فلن نستطيع الذّهاب للجزيرة التّالية

152
00:10:18,710 --> 00:10:21,840
بما أنّ كلّ جزيرة تحتاج لوقت
،مختلف لتسجيل مجالها

153
00:10:21,840 --> 00:10:24,810
تتطلّب بعض الجزر بضع
.ساعات فقط، بينما أخرى أيّامًا

154
00:10:25,280 --> 00:10:29,220
إ-إذًا حتّى إن كانت جزيرة وحوش
،نودّ الهرب منها في الحال

155
00:10:29,220 --> 00:10:33,260
فمن الممكن أن يكون علينا البقاء هنا
لعدّة أيّام إلى أن نسجّل المجال؟

156
00:10:33,260 --> 00:10:34,660
.هذا صحيح

157
00:10:35,390 --> 00:10:38,860
حسنًا، بإمكاننا التّفكير في ذلك
!عندما يحدث. فدعونا نذهب

158
00:10:39,190 --> 00:10:43,170
.لوفي على حقّ. فلنذهب
.لا يستحقّ الأمر التّفكير فيه

159
00:10:43,170 --> 00:10:46,870
.سأحمي نامي-سان مهما حدث

160
00:10:47,340 --> 00:10:51,310
...مـ-مهلاً يا رفاق. مرضي المزمن قد

161
00:10:51,310 --> 00:10:53,310
..."أعاني مرض "لا تذهب للجزيرة

162
00:10:53,310 --> 00:10:54,540
.لنذهب إذًا

163
00:10:54,540 --> 00:10:55,280
اسمعوا. كونوا متأهّبين للهرب
.كما أنتم متأهّبين للقتال

164
00:10:55,280 --> 00:10:55,980
...كلاّ

165
00:10:57,780 --> 00:11:02,520
...حسنًا... كما قلت، مرضي المزمن

166
00:11:02,520 --> 00:11:04,250
...أعتقد أنّكم لا تستمعون لي

167
00:11:04,550 --> 00:11:06,720
...أتساءل ما الّذي سيظهر

168
00:11:07,190 --> 00:11:09,120
...أ-أرجوك

169
00:11:22,040 --> 00:11:24,440
.انظروا، سفينة قراصنة

170
00:11:26,310 --> 00:11:28,140
!أتى القراصنة

171
00:11:57,170 --> 00:11:59,410
.ماذا؟ ثمّة شيء يتحرّك

172
00:11:59,740 --> 00:12:01,910
!بشر؟ إنّهم بشر

173
00:12:03,110 --> 00:12:04,680
.يا رفاق، كونوا حذرين

174
00:12:04,980 --> 00:12:08,380
،سُحقًا! بما أنّ الأمر آل إلى هذا
.فقد جهّزت نفسي

175
00:12:09,320 --> 00:12:13,450
،سواء كنتم وحوشًا أم لا
!فأظهروا أنفسكم

176
00:12:24,960 --> 00:12:26,800
!مرحبًا بكم في الغراند لاين

177
00:12:26,800 --> 00:12:28,530
!مرحبًا بكم في بلدتنا

178
00:12:28,530 --> 00:12:30,770
!إنّها البلدة المضيافة ويسكي بيك

179
00:12:31,340 --> 00:12:35,340
!لـ... ليسوا وحوشًا، إنّهم يرحّبون بنا

180
00:12:38,010 --> 00:12:39,510
ما الّذي يحدث؟

181
00:12:39,510 --> 00:12:42,280
!أيّها القراصنة! مرحبًا في بلدتنا

182
00:12:42,280 --> 00:12:45,580
!مرحى لأبطال البحار

183
00:12:50,020 --> 00:12:51,860
!ثمّة الكثير من الفتيات الجميلات

184
00:12:52,120 --> 00:12:54,930
!انظروا إلى هنا! إنّهم وسيمون

185
00:12:56,790 --> 00:13:01,400
.ربّما القراصنة هم أبطال النّاس

186
00:13:01,670 --> 00:13:03,570
!مرحبًا

187
00:13:07,640 --> 00:13:08,910
...مرحـ

188
00:13:11,280 --> 00:13:13,180
...ما-ما-ما

189
00:13:13,180 --> 00:13:14,540
.مرحبًا بكم

190
00:13:17,780 --> 00:13:22,750
.اسمي إيغارابّوي. أنا عمدة ويسكي بيك

191
00:13:22,750 --> 00:13:25,360
.أنا لوفي. سررت بلقائك

192
00:13:25,720 --> 00:13:27,590
.أيّها العمّ، لقد تماديت في لفّ شعرك

193
00:13:27,920 --> 00:13:31,660
ويسكي بيك بلدة تزدهر بصناعة
.الخمور والموسيقى

194
00:13:31,660 --> 00:13:34,060
.الضّيافة هي فخر بلدتنا

195
00:13:34,060 --> 00:13:36,700
،أمّا خمورنا الّتي نفخر بها
.فهي وفيرة وفرة مياه البحر

196
00:13:36,700 --> 00:13:39,670
هلاّ سمحتم لنا بإقامة حفلة لكم

197
00:13:39,670 --> 00:13:42,040
...لنستمع للقصص الّتي ستروونها

198
00:13:43,940 --> 00:13:46,640
...ما-ما-ما

199
00:13:47,240 --> 00:13:48,780
!عن مغامراتكم؟

200
00:13:49,110 --> 00:13:50,910
!سيسرّنا ذلك

201
00:13:52,050 --> 00:13:53,050
!ممتاز

202
00:13:53,420 --> 00:13:54,550
...ثلاثة أغبياء

203
00:13:55,120 --> 00:13:56,550
،بالمناسبة

204
00:13:56,550 --> 00:13:59,020
كم ستحتاج البوصلة إلى
أن يتمّ تسجيل المجال؟

205
00:13:59,020 --> 00:14:02,860
.تسجيل المجال؟ انسي تلك الأمور المملّة

206
00:14:02,860 --> 00:14:04,760
.ارتاحي فقط بعد رحلتكم الطّويلة

207
00:14:05,160 --> 00:14:10,030
!يا رفاق! استعدّوا للحفلة
!غنوّا للتّرفيه عن المغامرين

208
00:14:10,370 --> 00:14:13,130
!وقت الاحتفال

209
00:14:42,130 --> 00:14:45,070
،ثمّ قلتُ بكلّ روعة

210
00:14:45,070 --> 00:14:48,140
."يا ملوك البحر، لا تلمسوا أصدقائي"

211
00:14:48,670 --> 00:14:51,770
!أنت مذهل
!قائد أوسوبّ

212
00:14:52,140 --> 00:14:57,110
،ولكن بالنّسبة للحزام الهادئ
.فحتّى أنا ارتعشت

213
00:14:57,110 --> 00:14:58,280
!ارتعشتُ حماسًا

214
00:14:58,280 --> 00:14:59,350
!مذهل

215
00:14:59,350 --> 00:15:01,050
!في صّحة أوسوبّ-سان

216
00:15:01,050 --> 00:15:04,020
.حسنًا، اشربي ولا تتهاوني

217
00:15:04,020 --> 00:15:07,150
.لا، شكرًا. أفضّل ألاّ أشرب الكحول

218
00:15:07,150 --> 00:15:08,660
...لا تقلـ

219
00:15:09,860 --> 00:15:12,560
...ما-ما-ما

220
00:15:12,560 --> 00:15:14,030
.لا تقلقي

221
00:15:14,030 --> 00:15:19,170
إنّه مشروب خاصّ مُعدّ من عنب
.فاخر يُستعمل لصنع نبيذ فاخر

222
00:15:19,570 --> 00:15:23,500
،مذاقه كمذاق النّبيذ بعينه
.لكنّه لا يحتوي أيّ كحول

223
00:15:23,800 --> 00:15:25,140
...هكذا إذًا

224
00:15:26,470 --> 00:15:28,310
!معك حقّ! إنّه لذيذ

225
00:15:28,610 --> 00:15:30,910
.كان حصاد العنب وفيرًا هذه السّنة أيضًا

226
00:15:30,910 --> 00:15:35,310
والآن، سنقيم مسابقة تقديم النّخب
.الاعتياديّة احتفالاً بالحصاد

227
00:15:35,950 --> 00:15:41,220
سنقوم بتقديم نخب تلو الآخر
.وآخر المتبقّين هو الفائز

228
00:15:41,220 --> 00:15:42,520
.انضمّوا لمسابقتنا رجاءً

229
00:15:43,060 --> 00:15:45,920
.لا، شكرًا. لا يمكنني شرب كلّ ذلك

230
00:15:45,920 --> 00:15:49,590
!مبلغ جائزة الفائز هو 100 ألف بيري

231
00:15:50,900 --> 00:15:52,000
!كأس أخرى

232
00:15:52,500 --> 00:15:55,530
!زورو! شارك أنت أيضًا
لا مال لديك، صحيح؟

233
00:15:55,530 --> 00:15:56,330
!ماذا؟

234
00:15:56,330 --> 00:15:57,640
!في صحّتكم

235
00:16:01,510 --> 00:16:03,740
!مهلاً! هذا رائع! لقد أنهى الكأس العاشرة

236
00:16:04,410 --> 00:16:07,310
.يكفي. لا يمكنني شرب المزيد

237
00:16:08,380 --> 00:16:11,020
!أنهت الفتاة كأسها الثّاني عشر

238
00:16:12,620 --> 00:16:14,190
!أجل

239
00:16:14,190 --> 00:16:15,750
!المزيد من الطّعام

240
00:16:15,750 --> 00:16:19,220
!مذهل! أنهى القائد وجبة لعشرين شخص

241
00:16:19,220 --> 00:16:20,760
!انهار الطّبّاخ

242
00:16:21,460 --> 00:16:22,890
...لا يمكنني المواصلة

243
00:16:24,090 --> 00:16:28,000
يحاول هذا الشّابّ مغازلة
!عشرين فتاة في آن واحد

244
00:16:28,000 --> 00:16:29,900
!ما هذا الطّاقم؟

245
00:16:31,540 --> 00:16:33,200
...إنّهم مرحون فعـ

246
00:16:34,770 --> 00:16:37,310
...ما-ما-ما

247
00:16:37,310 --> 00:16:38,810
!مرحون فعلاً

248
00:16:38,810 --> 00:16:42,350
.أنا سعيد لأنّكم تبدون جميعًا مستمتعين

249
00:16:47,520 --> 00:16:50,690
...بل أنا جدّ سعيد بالفعل

250
00:16:51,690 --> 00:16:58,290
ولذلك السّبب، فشلنا في
...مهمّة تأمين الطّعام

251
00:16:58,290 --> 00:17:02,870
ولكن، نودّ أن نبلغكم أنّنا نجحنا

252
00:17:02,870 --> 00:17:08,270
في استدراج الطّاقم لجزيرة
.الصّبّار يا أعزّائي

253
00:17:08,270 --> 00:17:12,840
حسنًا! إن أرسلنا هذه، فسنكون قادرين
.على تبرئة اسمينا بطريقة ما

254
00:17:13,210 --> 00:17:15,810
صحيح. سأضعها في صندوق
.المشؤومين في الحال

255
00:17:21,480 --> 00:17:23,390
...سيوصلانه من أجلنا

256
00:17:24,690 --> 00:17:27,790
باروك

257
00:17:27,790 --> 00:17:28,960
...إلى الزّعيم

258
00:17:29,960 --> 00:17:31,860
.هذا يكفي. أستسلم. سأخلد للنّوم

259
00:17:32,730 --> 00:17:36,830
مهلاً! بلغ الشّابّ حدوده أخيرًا
.بعد الكأس الثّالث عشر

260
00:17:36,830 --> 00:17:40,170
!ماذا؟! لا أمل منك يا زورو

261
00:17:40,170 --> 00:17:41,640
.بقي اثنتان فحسب

262
00:17:41,640 --> 00:17:43,810
.لقد وصلا لكأسهما الخامس عشر
.إنّها تنافس الأخت

263
00:17:44,740 --> 00:17:47,340
،عليك أن تتوقّفي قريبًا أيضًا
.من أجل مصلحتك

264
00:17:47,340 --> 00:17:52,480
لا تكوني سخيفة! لن أستسلم بكلّ
.تأكيد حتّى أحصل على الجائزة

265
00:17:55,380 --> 00:17:58,520
.شكرًا على الطّعام
.لا يمكنني أكل المزيد

266
00:17:58,520 --> 00:18:00,720
!انهار ثلاثة طبّاخين أيضًا

267
00:18:00,720 --> 00:18:02,290
.سعيد لأنّ الطّعام أعجبك

268
00:18:04,420 --> 00:18:05,830
.لا يمكنني المواصلة

269
00:18:06,160 --> 00:18:07,930
!لقد فزت

270
00:18:10,700 --> 00:18:12,730
!كم هذا ممتع

271
00:18:12,730 --> 00:18:14,300
.انهارت أخيرًا

272
00:18:16,340 --> 00:18:18,610
...يا لها من بلدة رائعة

273
00:18:19,710 --> 00:18:22,180
.أنا في النّعيم

274
00:18:31,850 --> 00:18:34,220
إذًا فقد أنهكوا أنفسهم
...بالاحتفال وخلدوا للنّوم

275
00:18:37,790 --> 00:18:39,130
...أحلامًا سعيدة

276
00:18:40,930 --> 00:18:42,660
...أيّها المغامرون

277
00:18:44,730 --> 00:18:49,270
صخور الصّبّار جميلة اليوم أيضًا
.وهي ترقص تحت ضوء القمر

278
00:18:53,040 --> 00:18:57,840
.أنت شاعر بارع يا إيغارابّوي... بل يا سيّد 8

279
00:18:58,240 --> 00:18:59,440
...هذا أنتما

280
00:19:01,410 --> 00:19:02,350
ماذا حدث لهم؟

281
00:19:02,910 --> 00:19:04,150
...لقد انهاروا

282
00:19:08,090 --> 00:19:09,550
...وفي طريقهم للجحيم

283
00:19:12,560 --> 00:19:18,660
،يا إلهي... بما أنّهم كانوا عنيدين جدًّا
.أضفت القليل من الكحول لمشروباتهم

284
00:19:18,930 --> 00:19:21,230
وإلاّ لكانوا لا يزالون مستيقظين
.ويستمتعون بوقتهم

285
00:19:21,600 --> 00:19:26,370
لكن هل كان من الضّروريّ فعلاً
...التّخطيط لكلّ هذا بالتّفصيل

286
00:19:29,510 --> 00:19:32,040
من أجل خمسة ضعفاء فحسب؟

287
00:19:32,510 --> 00:19:38,350
.كان علينا هزيمتهم في الميناء
.تفتقر البلدة للطّعام من الأساس

288
00:19:38,820 --> 00:19:41,290
وأيضًا، لم ترتفع آمالنا من أجل
.لحم الحوت من البداية

289
00:19:41,290 --> 00:19:44,690
!لا داعي لقول ذلك
!لقد بذلنا كلّ ما بوسعنا

290
00:19:45,090 --> 00:19:49,660
.اهدآ. انظروا لهذا
.تحقّقت من أمرهم مسبقًا

291
00:19:50,860 --> 00:19:53,030
!ثـ-ثلاثون مليون بيري؟

292
00:19:53,030 --> 00:19:54,360
!هؤلاء؟

293
00:19:54,660 --> 00:19:59,470
من الغباء الحكم على قدرات القراصنة
...من مظهرهم فحسب يا آنسة مانـ

294
00:20:01,870 --> 00:20:03,610
...ما-ما-ما

295
00:20:03,610 --> 00:20:05,240
.يا آنسة مانداي

296
00:20:05,640 --> 00:20:07,610
.آ-آسفة

297
00:20:08,280 --> 00:20:10,750
.لكنّنا اهتممنا بالأمر سلفًا

298
00:20:10,750 --> 00:20:12,920
يبدو أنّ بإمكاننا إرسال
.تقرير جيّد للزّعيم

299
00:20:12,920 --> 00:20:15,990
صادروا كلّ المال والأشياء الثّمينة
.الّتي على سفينتهم في الحال

300
00:20:15,990 --> 00:20:17,790
وماذا عنهم؟

301
00:20:17,790 --> 00:20:18,690
ماذا سنفعل؟

302
00:20:19,260 --> 00:20:22,160
إن قتلناهم، ستنقص المكافأة
.بنسبة 30 بالمائة

303
00:20:22,520 --> 00:20:25,860
.تسعى الحكومة دائمًا للإعدامات العلنيّة

304
00:20:28,730 --> 00:20:30,870
!اذهبوا! أمسكوهم أحياء

305
00:20:31,670 --> 00:20:34,340
...عفوًا... أنا آسف

306
00:20:36,570 --> 00:20:39,110
لكن هلاّ تركتموهم نائمين؟

307
00:20:39,110 --> 00:20:41,510
.إنّهم متعبون جرّاء رحلتهم هذا المساء

308
00:20:47,650 --> 00:20:49,150
!سيّد 8! آنسة مانداي

309
00:20:49,150 --> 00:20:51,550
لقد هرب الرّجل ذو حزام الهاراماكي
!من الغرفة في غفلةٍ منّا

310
00:20:52,550 --> 00:20:53,720
.إنّه يقف هناك

311
00:20:54,160 --> 00:20:57,430
!وغد! ظننتُ أنّك تغطّ في نوم عميق

312
00:20:58,260 --> 00:21:02,900
إنّ السّيّافين لا يخطئون أبدًا
.ويرخون دفاعاتهم لذلك الحدّ

313
00:21:03,460 --> 00:21:07,370
.لذلك، دعوني أرى إن كنتُ محقًّا
.هذا وكر لصيّادي المكافآت

314
00:21:08,700 --> 00:21:14,140
تخدعون القراصنة ذوي الرّوح العالية
.جرّاء دخولهم توًّا للغراند لاين

315
00:21:15,080 --> 00:21:18,250
.يبدو أنّ ثمّة حوالي 100 صائد مكافآت هنا

316
00:21:19,650 --> 00:21:23,450
!سأقاتلكم جميعًا... يا باروك وركس

317
00:21:23,720 --> 00:21:26,420
!أيّها الوغد! كيف تعرف اسم شركتنا؟

318
00:21:27,290 --> 00:21:32,560
تمّ تجنيدي من طرف شركتكم إحدى
.المرّات عندما كنتُ أمارس نفس عملكم

319
00:21:32,560 --> 00:21:34,390
.لكنّني رفضتُ طبعًا

320
00:21:34,660 --> 00:21:39,300
لا يعرف العاملون هويّات بعضهم
.بعضًا ويستعملون أسماء رمزيّة

321
00:21:39,300 --> 00:21:43,100
وطبعًا يظلّ مخبأ الزّعيم
.وهويّته سرًّا حتّى لهم

322
00:21:43,100 --> 00:21:48,110
الباروك وركس جماعة إجراميّة
.تنفّذ أوامرها بكلّ إخلاص

323
00:21:49,880 --> 00:21:50,940
أكان ذلك سرًّا؟

324
00:21:52,510 --> 00:21:54,350
...هذا مفاجئ

325
00:21:55,610 --> 00:21:59,420
إن كنت تعرف أسرارنا، فلا خيار
.آخر أمامنا سوى قتلك

326
00:22:02,590 --> 00:22:03,960
...سيُضاف شاهد قبر آخر

327
00:22:05,260 --> 00:22:07,930
...لمقبرة صخور الصّبّار

328
00:22:33,680 --> 00:22:34,850
!اقتلوه

329
00:22:40,120 --> 00:22:41,990
!...لـ... لقد اختفى

330
00:22:56,910 --> 00:23:00,740
!أنا إلى جانبك

331
00:23:00,740 --> 00:23:04,450
آهٍ يا لها من أغنية رقيقة

332
00:23:04,450 --> 00:23:10,790
تصل إلى كلينا

333
00:23:11,690 --> 00:23:17,860
هدمت الأمواج تلك القلعة الرّمليّة الصّغيرة

334
00:23:19,300 --> 00:23:26,740
ونظرتَ إلى الغيوم المارّة بابتسامة كئيبة

335
00:23:27,470 --> 00:23:34,710
،حتّى إن امتلأ العالم بأعداء لنا

336
00:23:35,080 --> 00:23:38,380
فأنا أحمي ظهرك دائمًا

337
00:23:38,810 --> 00:23:46,820
فلا تفقد ثقتك

338
00:23:46,820 --> 00:23:50,690
!أنا إلى جانبك

339
00:23:50,690 --> 00:23:54,400
آهٍ يا حبّي

340
00:23:54,400 --> 00:24:00,600
سأمسك بك بين ذراعيّ للأبد

341
00:24:02,300 --> 00:24:06,070
!أنا إلى جانبك

342
00:24:11,380 --> 00:24:13,580
البلدة المضيافة هي
.وكر لصيّادي المكافآت

343
00:24:13,580 --> 00:24:15,550
هل أنت واثق أنّ عليك
إضافة شاهد قبر واحد؟

344
00:24:15,550 --> 00:24:17,950
ألن يأكل أحد ذلك اللّحم؟
.أريد أكله

345
00:24:17,950 --> 00:24:20,520
إنّها فرصة جيّدة لتجربة
كيتتسو الثّالث ويوباشيري

346
00:24:20,520 --> 00:24:21,860
اللّذين حصلتُ عليهما
.في لوغتاون

347
00:24:21,860 --> 00:24:23,920
.يا آنساتي، اقتربن أكثر

348
00:24:23,920 --> 00:24:25,890
!أنا القائد أوسوبّ

349
00:24:25,890 --> 00:24:28,000
!سأقدّم كلّ ما لديّ

350
00:24:28,260 --> 00:24:29,700
:في الحلقة القادمة من وان بيس

351
00:24:29,700 --> 00:24:32,370
!أسلوب السّيوف الثّلاثة المتفجّر"
