1
00:00:07,720 --> 00:00:10,760
!العالم... نعم

2
00:00:11,290 --> 00:00:12,960
...اسعوا نحو الحرّيّة

3
00:00:12,960 --> 00:00:17,000
.وسيمتدّ العالم بأسره أمام أنظاركم

4
00:00:17,460 --> 00:00:20,800
،إن كانت أحلامكم اللاّمتناهية هي مرشدكم

5
00:00:21,330 --> 00:00:22,800
!فتجاوزوها

6
00:00:23,100 --> 00:00:26,070
!تحت راية ما تؤمنون به

7
00:00:30,540 --> 00:00:36,150
بدأتُ بحثي للتّوّ، محدثًا رذاذ مياه

8
00:00:36,150 --> 00:00:39,380
متّجهًا نحو عالم بلا نهاية

9
00:00:40,790 --> 00:00:45,660
بقلبٍ يتدفّق حماسًا، سأذهب حتّى نهاية الأرض

10
00:00:45,660 --> 00:00:54,070
باحثًا عن ضياء لم يرها أحد بعد

11
00:00:54,070 --> 00:00:59,800
عندما تُأرجح شمس الصّيف أشرعة قلبي

12
00:00:59,800 --> 00:01:04,240
"حلّق بعيدًا أيّها البحر الأزرق الكئيب"

13
00:01:04,240 --> 00:01:09,880
تكون تلك إشارة لفتح الباب نحو عالم جديد

14
00:01:09,880 --> 00:01:13,750
"حلّقي بعيدًا أيّتها السّماء الزّرقاء الكئيبة"

15
00:01:13,750 --> 00:01:18,690
نبحر عبر أمواج اليأس الوعرة

16
00:01:18,690 --> 00:01:26,430
متّجهين نحو الأفق

17
00:01:26,430 --> 00:01:31,940
بدأتُ بحثي للتّوّ، محدثًا رذاذ مياه

18
00:01:31,940 --> 00:01:36,640
متّجهًا نحو عالم بلا نهاية

19
00:01:36,640 --> 00:01:41,880
بقلبٍ يتدفّق حماسًا، سأذهب حتّى نهاية الأرض

20
00:01:41,880 --> 00:01:48,150
باحثًا عن ضياء لم يرها أحد بعد

21
00:01:50,460 --> 00:01:55,160
المجمّع الغربي
المجمّع الشمالي
مملكة ألاباستا
المجمّع الشرقيّ
المجمّع الجنوبيّ

22
00:01:55,160 --> 00:01:56,800
مشاعر أولئك الّذين يعانون من كرب

23
00:01:56,800 --> 00:01:59,200
.لاقت سحقًا من سحابة الرّمال الجافّة

24
00:01:59,830 --> 00:02:03,640
،هنالك من في الأمل ساعٍ
.وهنالك من فيه متشبّث

25
00:02:03,640 --> 00:02:05,840
تشابكت مشاعرهم وهم في ريبةٍ من أمرهم

26
00:02:05,840 --> 00:02:09,670
.واسمةً حقبةً من التّاريخ يختمها الحزن

27
00:02:14,750 --> 00:02:16,650
،في ظلّ هذه المجريات
،في البوّابة الجنوب شرقيّة

28
00:02:16,650 --> 00:02:20,520
كان أوسوبّ وتشوبّر يواجهان المرأة
،الخلد، الآنسة ميري كريسماس

29
00:02:21,020 --> 00:02:23,860
،والضّارب الرّابع، السّيّد 4
.في قتال حياة أو موت

30
00:02:24,420 --> 00:02:28,860
بفضل فطنتهما، تمكّن أوسوبّ
.وتشوبّر من هزيمة خصميهما أخيرًا

31
00:02:30,260 --> 00:02:34,230
في نفس الأثناء، التحم سانجي مع
.السّيّد 2 بون كوري، في قتالٍ مباشر

32
00:02:34,230 --> 00:02:37,470
واجه سانجي خطرًا وشيكًا
من قبل مونتاج النّسخ

33
00:02:37,470 --> 00:02:39,370
.الّذي قام به السّيّد 2، بون كوري

34
00:02:43,170 --> 00:02:45,280
!يـ-يا لظرافتك

35
00:02:51,050 --> 00:02:54,220
!التّحوّل إلى نامي
كينبو باليه بون كوري السّريع المتتابع

36
00:02:54,220 --> 00:02:58,660
التّحوّل إلى نامي! كينبو باليه"
".بون كوري السّريع المتتابع

37
00:03:01,260 --> 00:03:04,060
ينطبق عليك مثل
"!كثير الكلام قليل الفعل"

38
00:03:04,060 --> 00:03:07,130
لا تملك من القوّة ما يكفيك
لتنهض، أليس كذلك؟

39
00:03:09,130 --> 00:03:12,400
إيّاك أن تظنّ أنّني سأرضى
!بالاستلقاء هكذا وأدعك تضربني

40
00:03:12,400 --> 00:03:14,970
،مهما كنت تبدو كنامي-سان

41
00:03:14,970 --> 00:03:17,010
.ما زلت ذلك التّافه في الدّاخل

42
00:03:17,610 --> 00:03:20,780
...أيّها الوغد اللّعين! لا تتبجّح كثيرًا

43
00:03:27,120 --> 00:03:29,650
!سحقًا! إنّها ظريفة حقًّا

44
00:03:30,290 --> 00:03:33,660
يا إلهي، جوّ هذه البلاد
.حارّ جدًّا بالنّسبة لي

45
00:03:34,230 --> 00:03:36,630
.يجعلني أرغب بخلع كلّ ثيابي

46
00:03:37,160 --> 00:03:39,730
!سأساعدك

47
00:03:39,730 --> 00:03:40,500
!صفعة الباليه

48
00:03:42,100 --> 00:03:43,230
!عيناي

49
00:03:43,230 --> 00:03:45,470
!أيّها الغبيّ

50
00:03:46,500 --> 00:03:48,170
!نقطة الرّكل

51
00:03:56,280 --> 00:03:58,250
!لا تجيد سوى الكلام، أليس كذلك؟

52
00:04:00,590 --> 00:04:02,120
!...أيّها الوغد

53
00:04:04,160 --> 00:04:05,620
!هل تعبث معي؟

54
00:04:06,090 --> 00:04:08,390
!خذوف الرّموش المرتدّ

55
00:04:11,660 --> 00:04:12,560
!إلى الجحيم

56
00:04:13,970 --> 00:04:14,870
.لا تركلني

57
00:04:23,880 --> 00:04:26,410
عليّ إرجاع رموشي، أليس كذلك؟

58
00:04:26,980 --> 00:04:32,620
،اللّعب معك ممتع
.لكن لا أملك الوقت للّهو كثيرًا

59
00:04:32,620 --> 00:04:35,920
.إنّ من واجبي قتل الأميرة في النّهاية

60
00:04:38,120 --> 00:04:41,360
.سأعجّل في القضاء عليك

61
00:04:42,260 --> 00:04:46,160
!دوران، دوران، إنّي أدور دورانًا

62
00:04:49,330 --> 00:04:52,600
!ماذا؟! نفجّر القصر الملكيّ؟

63
00:04:52,600 --> 00:04:56,610
نعم. جاءتنا أوامر بتفجير
.القصر الملكيّ

64
00:04:56,610 --> 00:04:59,180
!سوف نفجّر القصر الملكيّ

65
00:05:00,080 --> 00:05:01,610
.هذا غير معقول

66
00:05:01,610 --> 00:05:04,120
.يضمّ القصر تاريخَ 4،000 سنة

67
00:05:09,990 --> 00:05:11,190
...لساني عاجزٌ

68
00:05:12,260 --> 00:05:14,260
.عن التّعبير عن وضعنا الرّاهن

69
00:05:14,660 --> 00:05:16,230
.لا بأس، أفهمك

70
00:05:17,030 --> 00:05:20,970
لم يكن في مقدورك فعل شيء
.عدا صدّ جيش المتمرّدين

71
00:05:21,600 --> 00:05:23,070
،بغضّ النّظر عن إيغارام

72
00:05:23,070 --> 00:05:26,140
أحسنتم صنعًا في قمع
.التّمرّد لأكثر من عامين

73
00:05:26,940 --> 00:05:29,340
.لكنّي لم أكن مخطئة

74
00:05:29,340 --> 00:05:34,250
قابلتُ أصدقاء حقيقيّين
.سينقذون ألاباستا

75
00:05:38,150 --> 00:05:41,890
!اسبقوني يا رفاق! يمكنني التّكفّل بهذا

76
00:05:42,420 --> 00:05:46,490
احرصوا على إرجاع فيفي
!إلى ديارها! احرصوا على ذلك

77
00:05:46,830 --> 00:05:47,890
.اسمعي يا فيفي

78
00:05:47,890 --> 00:05:51,100
.سيُبقي كروكودايل قيد السّيطرة

79
00:05:51,530 --> 00:05:54,100
،فور بدء جيش المتمرّدين بالرّكض

80
00:05:54,100 --> 00:05:56,270
.حُدّدت المهلة الزّمنيّة لهذه البلاد

81
00:05:57,770 --> 00:06:00,510
فور اصطدام الجيش الملكيّ
،مع جيش المتمرّدين

82
00:06:00,510 --> 00:06:02,240
.ستفنى هذه البلاد

83
00:06:02,870 --> 00:06:05,980
،إن كنتِ الأمل الوحيد لمنع ذلك

84
00:06:06,610 --> 00:06:08,480
.فعليك إذًا أن تنجي، مهما كان

85
00:06:09,210 --> 00:06:15,050
وبغضّ النّظر عمّا يحصل
!لأيّ منّا هنا من الآن فصاعدًا

86
00:06:18,260 --> 00:06:20,790
يا من أنتم مستعدّون
،حتّى للتّضحية بحياتكم

87
00:06:21,490 --> 00:06:23,090
كيف حالكم الآن؟

88
00:06:23,090 --> 00:06:24,000
...فيفي-ساما

89
00:06:24,500 --> 00:06:26,500
في غضون العامين اللّذين
،لم أرك فيهما

90
00:06:26,500 --> 00:06:29,030
.أصبحتِ في غاية الجمال

91
00:06:30,970 --> 00:06:33,670
،فور أن تنتهي هذه الحرب

92
00:06:33,670 --> 00:06:37,280
سأحرص بنفسي على إقامة مأدبة
.كبيرة لأجل أولئك القراصنة

93
00:06:38,110 --> 00:06:39,040
...تشاكا

94
00:06:41,610 --> 00:06:43,580
.أعطني طعامًا

95
00:06:44,380 --> 00:06:49,220
،إن أبرحت كروكودايل ضربًا
!فأطعميني إلى حدّ الموت

96
00:06:52,020 --> 00:06:55,560
نعم. أنا مؤمنة بك
.يا لوفي-سان، أنت بخير

97
00:06:55,560 --> 00:06:58,930
.أنا واثقة أنّك هزمت كروكودايل

98
00:07:00,130 --> 00:07:01,370
!تشاكا-ساما

99
00:07:01,370 --> 00:07:02,370
ماذا هناك؟

100
00:07:02,900 --> 00:07:05,970
!هل صحيحٌ أنّك ستفجّر القصر الملكيّ؟

101
00:07:05,970 --> 00:07:08,140
!همّ الجنود بإحضار المتفجّرات بالفعل

102
00:07:08,140 --> 00:07:09,710
!لا بدّ أنّ هنالك سوء فهم

103
00:07:10,010 --> 00:07:12,680
.أنا من أصدر الأوامر

104
00:07:13,380 --> 00:07:14,010
!فيفي-ساما

105
00:07:14,550 --> 00:07:17,420
استخدموا كلّ ما لدينا
.من المتفجّرات رجاءً

106
00:07:17,420 --> 00:07:19,720
،من أجل إيقاف القتال العقيم

107
00:07:19,720 --> 00:07:22,490
،ومن أجل إنقاذ أرواح شعب ألاباستا

108
00:07:23,150 --> 00:07:26,120
!سنفجّر القصر الملكيّ

109
00:07:26,860 --> 00:07:30,530
تماسك! لا تملك إصابة
!خطيرة يا أوسوبّ

110
00:07:30,530 --> 00:07:33,000
!حطّمت عظم فخذك فحسب

111
00:07:33,000 --> 00:07:36,670
ربّما كسرت أنفك وعظام
،عضدك وعظام ترقوتك

112
00:07:36,670 --> 00:07:40,710
لكنّك لم تفقد الكثير من الدّم
.لدرجة مميتة

113
00:07:40,710 --> 00:07:42,740
قد يكون ضغط دمك
،كضغط دم زومبي

114
00:07:42,740 --> 00:07:44,310
!لكن لا تقلق

115
00:07:45,710 --> 00:07:48,780
...حاليًّا، إنّي أشعر بشعور رائع

116
00:07:48,780 --> 00:07:51,680
...أرى حقول أزهار جميلة

117
00:07:52,020 --> 00:07:55,650
!لا تقصد النّعيم، أليس كذلك؟
!أيمكنك رؤية النّعيم؟

118
00:07:56,420 --> 00:07:58,720
،مهما كنتَ قرصانًا عظيمًا

119
00:07:59,220 --> 00:08:02,030
...سيحين أجلك لا محالة

120
00:08:02,660 --> 00:08:06,560
!لـ-لا تمت رجاءً يا أوسوبّ
!أرجوك، لا أريدك أن تموت

121
00:08:06,560 --> 00:08:13,040
...وداعًا يا تشوبّر
...أترك كنزي الهائل في رعايتك

122
00:08:13,040 --> 00:08:17,480
...‫15 قطعة ذهبيّة وفضيّة
...اغدُ طبيبًا جيّدًا

123
00:08:19,440 --> 00:08:21,050
!أوسوبّ

124
00:08:21,280 --> 00:08:25,750
افتح عينيك! هناك ما يجب
!أن أعتذر منك بشأنه

125
00:08:26,020 --> 00:08:27,150
...كعكة المانجو هذه

126
00:08:28,520 --> 00:08:32,790
هذه كعكة المانجو الّتي
.أردتها وأخفيتها عنك

127
00:08:33,660 --> 00:08:37,430
،لو أنّي أعلم أنّك ستموت
.لأعطيتك نصفها

128
00:08:37,430 --> 00:08:40,800
.كنتُ رجلاً صغيرًا وضيّق الأفق

129
00:08:43,970 --> 00:08:45,470
!كعكة المانجو؟

130
00:08:45,470 --> 00:08:46,870
...كعكة المانجو

131
00:08:49,010 --> 00:08:53,180
سحقًا لتلك الغبيّة! أين ذهبت؟

132
00:08:53,180 --> 00:08:55,280
لهذا أخبرتها أن تصمت
.وتختبئ في مكانٍ ما

133
00:08:55,880 --> 00:08:59,750
!لا تجيد سوى عرقلتي
!تلك المرأة الغبيّة

134
00:09:06,120 --> 00:09:10,100
!ما عدتُ أستطيع الرّكض
!عليّ أن أقاتل

135
00:09:16,430 --> 00:09:17,300
!مستحيل

136
00:09:18,570 --> 00:09:20,170
.هذه مضيعة للوقت

137
00:09:21,910 --> 00:09:23,110
.إنّه قليل الصّبر

138
00:09:30,820 --> 00:09:31,580
!زورو

139
00:09:37,260 --> 00:09:39,090
!العمود الحجريّ! انقسم طولاً

140
00:09:41,490 --> 00:09:48,500
.انقسم؟ كلاّ، لم ينقسم
.من الواضح أنّه من صنيع سيّاف

141
00:09:50,600 --> 00:09:51,400
.تنحّ عن طريقي

142
00:09:56,640 --> 00:09:59,240
لقد قطعته، أليس كذلك؟
بذراعيك هاتين؟

143
00:10:02,110 --> 00:10:04,780
،تملك جسدًا غريبًا بالفعل
أليس كذلك؟

144
00:10:05,680 --> 00:10:06,650
.بالفعل

145
00:10:07,290 --> 00:10:10,760
أكلتُ فاكهة القطع، ما يخوّلني
.صنع سيوفًا من جسدي بكامله

146
00:10:11,360 --> 00:10:12,720
أنت هو، أليس كذلك؟

147
00:10:12,720 --> 00:10:16,060
السّيّاف الّذي قيل أنّه قطع
مائة رجل في ويسكي بيك؟

148
00:10:16,930 --> 00:10:21,800
وأيضًا، صائد القراصنة الّذي رفض
عرض الانضمام لباروك وركس

149
00:10:21,800 --> 00:10:25,070
.في الأزرق الشّرقيّ وقام بقطع السّيّد 7

150
00:10:25,740 --> 00:10:26,910
كان أنت، صحيح؟

151
00:10:28,210 --> 00:10:30,410
.تلك قصّة تشعرني بالحنين

152
00:10:30,410 --> 00:10:34,910
.كان خطأكم لأنّكم لم تقبلوا بشروطي

153
00:10:35,710 --> 00:10:38,920
:أخبرت كشّافكم بهذا حينها

154
00:10:40,050 --> 00:10:42,750
،إن أردتموني أن أنضمّ لكم"
".اجعلوني زعيمكم

155
00:10:44,160 --> 00:10:45,860
.يا لك من رجل مضحك

156
00:10:46,460 --> 00:10:49,860
،وبدلاً من الموافقة على شروطي
.حاول مهاجمتي

157
00:10:49,860 --> 00:10:51,630
.لذا أوقفته عند حدّه

158
00:10:52,700 --> 00:10:54,570
هل تريدان أن تجرّبا دعوتي أيضًا؟

159
00:10:55,100 --> 00:10:56,770
،لكنّكم في حالة مزرية حقًّا الآن

160
00:10:56,770 --> 00:10:59,300
.ما كنتُ لأقبل حتّى أن أكون زعيمكم

161
00:11:04,410 --> 00:11:06,980
أنت تستهزئ بي حقًّا، أليس كذلك؟

162
00:11:09,710 --> 00:11:13,250
...أنت، سيّاف من طاقم قراصنة وضيع

163
00:11:13,850 --> 00:11:17,220
في تلك الحالة، من تخالون أنفسكم؟

164
00:11:17,220 --> 00:11:20,020
،دمى مجرّدة من إرادة خاصّة

165
00:11:20,020 --> 00:11:22,190
تمّ إغواؤها لصنع مدينة
فاضلة بالاسم فقط؟

166
00:11:22,590 --> 00:11:24,830
...أم أنّكم في الحقيقة مجرّد جنود صفيح

167
00:11:28,370 --> 00:11:29,770
دون أيّ جوهر؟

168
00:11:30,500 --> 00:11:32,140
...آنسة دبلفينغر

169
00:11:33,040 --> 00:11:36,210
ستخبرني أنّك تريد
أن تتخلّص منه، صحيح؟

170
00:11:36,210 --> 00:11:40,180
.افعل ما تشاء
.وسأتكفّل بتلك الفتاة

171
00:11:40,650 --> 00:11:41,580
!نامي

172
00:11:41,780 --> 00:11:42,880
!لقد ذهبت

173
00:11:51,590 --> 00:11:56,530
